{% extends 'base.html.twig' %}

{% block title %}All Posts — JavaBlog{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Blog Posts</h1>
    <a href="{{ path('app_post_new') }}" class="btn btn-primary">+ New Post</a>
</div>

{% if posts is empty %}
    <div class="text-center py-5 text-muted">
        <h3>No posts yet.</h3>
        <a href="{{ path('app_post_new') }}" class="btn btn-primary mt-2">Write the first post</a>
    </div>
{% else %}
    <div class="row g-4">
        {% for post in posts %}
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 p-3">
                <div class="mb-2">
                    <span class="badge-post">Post #{{ post.id }}</span>
                </div>
                <h4 class="card-title mt-2">
                    <a href="{{ path('app_post_show', {id: post.id}) }}" class="text-decoration-none text-dark">
                        {{ post.title }}
                    </a>
                </h4>
                <p class="text-muted small">
                    By <strong>{{ post.author ?? 'Anonymous' }}</strong>
                    &bull; {{ post.createdAt|date('M d, Y') }}
                </p>
                <p class="text-truncate">{{ post.content|slice(0, 120) }}...</p>
                <div class="mt-auto d-flex gap-2 pt-2">
                    <a href="{{ path('app_post_show', {id: post.id}) }}" class="btn btn-sm btn-outline-dark">Read</a>
                    <a href="{{ path('app_post_edit', {id: post.id}) }}" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <form method="post" action="{{ path('app_post_delete', {id: post.id}) }}" class="ms-auto"
                          onsubmit="return confirm('Delete this post and all its comments?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ post.id) }}">
                        <button class="btn btn-sm btn-outline-danger">Delete</button>
                    </form>
                </div>
                <small class="text-muted mt-2">💬 {{ post.comments|length }} comment(s)</small>
            </div>
        </div>
        {% endfor %}
    </div>
{% endif %}
{% endblock %}

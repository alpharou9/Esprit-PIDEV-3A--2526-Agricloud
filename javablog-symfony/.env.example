# .env — copy this to .env.local and fill in your credentials

# Database: javablog
DATABASE_URL="mysql://root:YOUR_PASSWORD@127.0.0.1:3306/javablog?serverVersion=8.0&charset=utf8mb4"

# For MariaDB use:
# DATABASE_URL="mysql://root:YOUR_PASSWORD@127.0.0.1:3306/javablog?serverVersion=mariadb-10.6.0&charset=utf8mb4"

APP_ENV=dev
APP_SECRET=change_this_to_a_random_32_char_string

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>AgriCloud — Smart Farming Platform</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Philosopher:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="{{ asset('theme/agriculture-farm/css/font-awesome.min.css') }}" rel="stylesheet">
    <style>
        * { box-sizing: border-box; }
        body { font-family: 'Philosopher', sans-serif; margin: 0; padding: 0; }

        /* ── Navbar ── */
        .agri-nav {
            background: #77b81e;
            position: fixed; top: 0; left: 0; width: 100%; z-index: 9999;
            padding: 0 40px; height: 64px;
            display: flex; align-items: center; justify-content: space-between;
            box-shadow: 0 2px 16px rgba(0,0,0,.18);
        }
        .agri-nav .brand { font-size: 1.7rem; font-weight: 700; color: #fff; text-decoration: none; display: flex; align-items: center; gap: 8px; white-space: nowrap; }
        .agri-nav .nav-links { display: flex; align-items: center; gap: 28px; }
        .agri-nav .nav-links a { color: rgba(255,255,255,.85); text-decoration: none; font-size: 1rem; transition: color .2s; white-space: nowrap; }
        .agri-nav .nav-links a:hover { color: #fff; }
        .agri-nav .nav-actions { display: flex; align-items: center; gap: 10px; }
        .btn-login { border: 2px solid #fff; border-radius: 8px; padding: 6px 20px; color: #fff !important; text-decoration: none; font-size: .95rem; transition: all .2s; white-space: nowrap; }
        .btn-login:hover { background: #fff; color: #77b81e !important; }
        .btn-start { background: rgba(255,255,255,.2); border: 2px solid #fff; border-radius: 8px; padding: 6px 20px; color: #fff !important; text-decoration: none; font-size: .95rem; transition: all .2s; white-space: nowrap; }
        .btn-start:hover { background: #fff; color: #77b81e !important; }

        /* ── Hero ── */
        .hero {
            min-height: 100vh;
            background:
                radial-gradient(ellipse at 70% 50%, rgba(119,184,30,.18) 0%, transparent 60%),
                radial-gradient(ellipse at 10% 80%, rgba(50,100,10,.3) 0%, transparent 50%),
                linear-gradient(145deg, #0d1f05 0%, #1a3a08 35%, #2d5c10 65%, #1a3a08 100%);
            display: flex; align-items: center;
            padding: 100px 40px 60px;
            position: relative; overflow: hidden;
        }
        .hero::before {
            content: '';
            position: absolute; inset: 0;
            background-image:
                radial-gradient(circle at 1px 1px, rgba(119,184,30,.07) 1px, transparent 0);
            background-size: 40px 40px;
            pointer-events: none;
        }
        .hero::after {
            content: '';
            position: absolute; right: -100px; top: 50%; transform: translateY(-50%);
            width: 600px; height: 600px; border-radius: 50%;
            background: radial-gradient(circle, rgba(119,184,30,.12) 0%, transparent 70%);
            pointer-events: none;
        }
        .hero h1 { font-size: clamp(2.2rem, 5vw, 4rem); font-weight: 700; color: #fff; line-height: 1.15; margin-bottom: 1.2rem; }
        .hero h1 span { color: #a3d43a; }
        .hero p { font-size: 1.15rem; color: rgba(255,255,255,.85); max-width: 520px; margin-bottom: 2rem; }
        .btn-hero-primary { background: #77b81e; color: #fff; border: 2px solid #77b81e; border-radius: 10px; padding: 13px 38px; font-size: 1.05rem; text-decoration: none; transition: all .2s; display: inline-block; }
        .btn-hero-primary:hover { background: transparent; color: #fff; }
        .btn-hero-outline { border: 2px solid #fff; border-radius: 10px; padding: 13px 38px; font-size: 1.05rem; color: #fff; text-decoration: none; transition: all .2s; display: inline-block; }
        .btn-hero-outline:hover { background: #fff; color: #77b81e; }
        .hero-img { width: 100%; border-radius: 20px; box-shadow: 0 20px 60px rgba(0,0,0,.45); max-height: 420px; object-fit: cover; }

        /* ── Section shared ── */
        .section-label { color: #77b81e; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; font-size: .85rem; }
        .section-title { font-size: 2.2rem; color: #3a3a3a; font-weight: 700; margin: .3rem 0 .5rem; }
        .divider { width: 56px; height: 4px; background: #77b81e; border-radius: 4px; margin: .6rem auto 2.5rem; }
        .divider-left { margin-left: 0; }

        /* ── Feature cards ── */
        .feature-card { border: none; border-radius: 16px; box-shadow: 0 4px 20px rgba(0,0,0,.07); padding: 2rem 1.5rem; height: 100%; transition: transform .2s, box-shadow .2s; background: #fff; text-align: center; }
        .feature-card:hover { transform: translateY(-6px); box-shadow: 0 12px 32px rgba(0,0,0,.13); }
        .feature-icon { width: 74px; height: 74px; background: #77b81e; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.2rem; font-size: 1.8rem; color: #fff; }
        .feature-card h5 { font-size: 1.15rem; font-weight: 700; margin-bottom: .6rem; }
        .feature-card p { color: #666; font-size: .95rem; margin: 0; }

        /* ── Stats ── */
        .stats { background: #77b81e; padding: 70px 0; }
        .stat-box { text-align: center; }
        .stat-box h2 { font-size: 3rem; font-weight: 700; color: #fff; margin: 0; line-height: 1; }
        .stat-box p { color: rgba(255,255,255,.85); font-size: 1rem; margin: .4rem 0 0; }

        /* ── Blog cards ── */
        .blog-card { border: none; border-radius: 14px; box-shadow: 0 3px 14px rgba(0,0,0,.08); overflow: hidden; height: 100%; transition: transform .2s; }
        .blog-card:hover { transform: translateY(-5px); }
        .blog-card img, .blog-card .img-ph { height: 190px; width: 100%; object-fit: cover; }
        .blog-card .img-ph { background: linear-gradient(135deg, #d1e7dd, #a3cfbb); display: flex; align-items: center; justify-content: center; font-size: 2.5rem; color: #77b81e; }
        .blog-card .card-body { padding: 1.2rem; }
        .badge-cat { background: #77b81e; color: #fff; font-size: .75rem; padding: 3px 10px; border-radius: 20px; display: inline-block; margin-bottom: .5rem; }
        .read-more { color: #77b81e; font-weight: 600; font-size: .85rem; text-decoration: none; }
        .read-more:hover { text-decoration: underline; }

        /* ── Product cards ── */
        .prod-card { border: none; border-radius: 14px; box-shadow: 0 3px 14px rgba(0,0,0,.08); overflow: hidden; height: 100%; transition: transform .2s; }
        .prod-card:hover { transform: translateY(-5px); }
        .prod-card img, .prod-card .img-ph { height: 160px; width: 100%; object-fit: cover; }
        .prod-card .img-ph { background: linear-gradient(135deg, #d1e7dd, #a3cfbb); display: flex; align-items: center; justify-content: center; font-size: 2rem; color: #77b81e; }
        .prod-price { color: #77b81e; font-weight: 700; font-size: 1.1rem; }

        /* ── CTA strip ── */
        .cta-strip {
            background: linear-gradient(135deg, #0d1f05 0%, #2d5c10 50%, #1a3a08 100%);
            padding: 100px 0; text-align: center;
            position: relative; overflow: hidden;
        }
        .cta-strip::before {
            content: '';
            position: absolute; inset: 0;
            background-image: radial-gradient(circle at 1px 1px, rgba(119,184,30,.08) 1px, transparent 0);
            background-size: 36px 36px;
        }
        .cta-strip h2 { color: #fff; font-size: 2.5rem; font-weight: 700; margin-bottom: 1rem; }
        .cta-strip p { color: rgba(255,255,255,.8); font-size: 1.1rem; max-width: 580px; margin: 0 auto 2rem; }

        /* ── Footer ── */
        .agri-footer { background: #1a2e0a; padding: 64px 0 24px; }
        .agri-footer h5 { color: #77b81e; font-weight: 700; margin-bottom: 1.1rem; font-size: 1.05rem; }
        .agri-footer p, .agri-footer li { color: #aaa; font-size: .93rem; }
        .agri-footer a { color: #aaa; text-decoration: none; transition: color .2s; display: block; margin-bottom: 5px; }
        .agri-footer a:hover { color: #77b81e; }
        .footer-bottom { border-top: 1px solid #2d4a14; margin-top: 42px; padding-top: 20px; text-align: center; color: #666; font-size: .88rem; }
        .social-btn { display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; border: 2px solid #77b81e; border-radius: 50%; color: #77b81e; font-size: 1rem; margin-right: 8px; transition: all .2s; text-decoration: none; }
        .social-btn:hover { background: #77b81e; color: #fff; }
    </style>
</head>
<body>

{# ── Navbar ── #}
<nav class="agri-nav">
    <a href="{{ path('home') }}" class="brand">
        <i class="bi bi-tree-fill"></i> AgriCloud
    </a>
    <div class="nav-links d-none d-md-flex">
        <a href="#features">Features</a>
        <a href="#blog">Blog</a>
        <a href="#market">Market</a>
        <a href="#about">About</a>
    </div>
    <div class="nav-actions">
        {% if app.user %}
            <a href="{{ path('dashboard') }}" class="btn-start"><i class="bi bi-speedometer2 me-1"></i>Dashboard</a>
        {% else %}
            <a href="{{ path('app_login') }}" class="btn-login">Login</a>
            <a href="{{ path('app_register') }}" class="btn-start">Get Started</a>
        {% endif %}
    </div>
</nav>

{# ── Hero ── #}
<section class="hero">
    <div class="container-fluid px-4 px-lg-5">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <p class="section-label mb-2">Smart Farming Platform</p>
                <h1>Grow Smarter.<br>Sell Better.<br><span>Farm Greener.</span></h1>
                <p>AgriCloud connects farmers, manages crops, and powers a thriving agricultural marketplace — all in one platform.</p>
                <div class="d-flex flex-wrap gap-3">
                    {% if app.user %}
                        <a href="{{ path('dashboard') }}" class="btn-hero-primary">Go to Dashboard</a>
                    {% else %}
                        <a href="{{ path('app_register') }}" class="btn-hero-primary">Start for Free</a>
                        <a href="{{ path('app_login') }}" class="btn-hero-outline">Login</a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</section>

{# ── Features ── #}
<section id="features" style="padding: 90px 0; background: #f8faf4;">
    <div class="container text-center">
        <p class="section-label">What We Offer</p>
        <h2 class="section-title">Everything Your Farm Needs</h2>
        <div class="divider mx-auto"></div>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon"><i class="bi bi-house-heart-fill"></i></div>
                    <h5>Farm Management</h5>
                    <p>Manage your farms and fields, track crops, and monitor every aspect of your agricultural operation.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon"><i class="bi bi-shop-window"></i></div>
                    <h5>Marketplace</h5>
                    <p>List your produce, reach buyers directly, and manage orders — from harvest to delivery.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="feature-card">
                    <div class="feature-icon"><i class="bi bi-journal-richtext"></i></div>
                    <h5>Community Blog</h5>
                    <p>Share farming tips, read expert guides, and stay connected with the agricultural community.</p>
                </div>
            </div>
        </div>
    </div>
</section>

{# ── Stats ── #}
<section class="stats">
    <div class="container">
        <div class="row g-4 text-center">
            <div class="col-6 col-md-3 stat-box">
                <h2>500+</h2><p>Registered Farmers</p>
            </div>
            <div class="col-6 col-md-3 stat-box">
                <h2>1 200+</h2><p>Products Listed</p>
            </div>
            <div class="col-6 col-md-3 stat-box">
                <h2>350+</h2><p>Farms Registered</p>
            </div>
            <div class="col-6 col-md-3 stat-box">
                <h2>24/7</h2><p>Platform Support</p>
            </div>
        </div>
    </div>
</section>

{# ── Latest Blog Posts ── #}
{% if latestPosts|length > 0 %}
<section id="blog" style="padding: 90px 0; background: #fff;">
    <div class="container">
        <div class="text-center mb-5">
            <p class="section-label">Latest Articles</p>
            <h2 class="section-title">From the Blog</h2>
            <div class="divider mx-auto"></div>
        </div>
        <div class="row g-4">
            {% for post in latestPosts %}
            <div class="col-md-4">
                <div class="blog-card">
                    {% if post.image %}
                        <img src="{{ asset('uploads/posts/' ~ post.image) }}" alt="{{ post.title }}">
                    {% else %}
                        <div class="img-ph"><i class="bi bi-journal-text"></i></div>
                    {% endif %}
                    <div class="card-body">
                        {% if post.category %}<span class="badge-cat">{{ post.category }}</span>{% endif %}
                        <h6 class="fw-bold mb-1">{{ post.title }}</h6>
                        <p class="text-muted small mb-2">{{ (post.excerpt ?? post.content)|slice(0,90) }}…</p>
                        <div class="d-flex justify-content-between align-items-center">
                            <small class="text-muted"><i class="bi bi-person me-1"></i>{{ post.user.name }}</small>
                            <a href="{{ app.user ? path('blog_show', {slug: post.slug}) : path('app_login') }}" class="read-more">Read more →</a>
                        </div>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
        <div class="text-center mt-5">
            <a href="{{ path('blog_index') }}" class="btn-hero-primary">View All Posts</a>
        </div>
    </div>
</section>
{% endif %}

{# ── Marketplace Preview ── #}
{% if latestProducts|length > 0 %}
<section id="market" style="padding: 90px 0; background: #f8faf4;">
    <div class="container">
        <div class="text-center mb-5">
            <p class="section-label">Fresh From Farms</p>
            <h2 class="section-title">Marketplace</h2>
            <div class="divider mx-auto"></div>
        </div>
        <div class="row g-4">
            {% for product in latestProducts %}
            <div class="col-6 col-md-3">
                <div class="prod-card">
                    {% if product.image %}
                        <img src="{{ asset('uploads/products/' ~ product.image) }}" alt="{{ product.name }}">
                    {% else %}
                        <div class="img-ph"><i class="bi bi-bag-heart"></i></div>
                    {% endif %}
                    <div class="p-3">
                        <h6 class="fw-bold mb-1 small">{{ product.name }}</h6>
                        <div class="prod-price">{{ product.price }} TND <small class="text-muted fw-normal" style="font-size:.75rem">/{{ product.unit }}</small></div>
                        <small class="text-muted">{{ product.quantity }} left</small>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
        <div class="text-center mt-5">
            <a href="{{ path('market_index') }}" class="btn-hero-primary">Browse Marketplace</a>
        </div>
    </div>
</section>
{% endif %}

{# ── CTA ── #}
<section id="about" class="cta-strip">
    <div class="container">
        <h2>Ready to Transform Your Farm?</h2>
        <p>Join hundreds of farmers already using AgriCloud to manage their operations, sell their produce, and grow their business.</p>
        {% if app.user %}
            <a href="{{ path('dashboard') }}" class="btn-hero-primary">Go to Dashboard</a>
        {% else %}
            <a href="{{ path('app_register') }}" class="btn-hero-primary">Create Free Account</a>
        {% endif %}
    </div>
</section>

{# ── Footer ── #}
<footer class="agri-footer">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-4 col-md-6">
                <h5><i class="bi bi-tree-fill me-2"></i>AgriCloud</h5>
                <p>Smart farming platform connecting farmers, buyers, and agricultural communities across Tunisia.</p>
                <div class="mt-3">
                    <a href="#" class="social-btn"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="social-btn"><i class="bi bi-twitter-x"></i></a>
                    <a href="#" class="social-btn"><i class="bi bi-instagram"></i></a>
                </div>
            </div>
            <div class="col-lg-2 col-md-3 col-6">
                <h5>Platform</h5>
                <a href="#features">Features</a>
                <a href="#market">Marketplace</a>
                <a href="#blog">Blog</a>
            </div>
            <div class="col-lg-4 col-md-6">
                <h5>Contact</h5>
                <p><i class="bi bi-geo-alt-fill me-2" style="color:#77b81e"></i>Esprit University, Tunis, Tunisia</p>
                <p><i class="bi bi-envelope-fill me-2" style="color:#77b81e"></i>contact@agricloud.tn</p>
                <p><i class="bi bi-telephone-fill me-2" style="color:#77b81e"></i>+216 XX XXX XXX</p>
            </div>
        </div>
        <div class="footer-bottom">
            © {{ "now"|date("Y") }} AgriCloud — Esprit University PIDEV Project
        </div>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

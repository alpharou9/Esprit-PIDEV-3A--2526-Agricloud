<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>AgriCloud — Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        body { background: #f0f7f0; }
        .login-card { max-width: 420px; }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center min-vh-100">
    <div class="login-card w-100 px-3">
        <div class="card shadow-sm border-0">
            <div class="card-body p-4">
                <div class="text-center mb-4">
                    <i class="bi bi-tree-fill text-success" style="font-size:2.5rem"></i>
                    <h4 class="fw-bold mt-2">AgriCloud</h4>
                    <p class="text-muted small">Sign in to continue</p>
                </div>

                {% if error %}
                    <div class="alert alert-danger small">
                        <i class="bi bi-exclamation-triangle me-1"></i>
                        {{ error.messageKey|trans(error.messageData, 'security') }}
                    </div>
                {% endif %}

                {{ form_start(loginForm, {
                    action: path('app_login'),
                    method: 'POST'
                }) }}
                    <div class="mb-3">
                        {{ form_label(loginForm._username, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                        {{ form_widget(loginForm._username) }}
                        {{ form_errors(loginForm._username) }}
                    </div>
                    <div class="mb-4">
                        {{ form_label(loginForm._password, null, {'label_attr': {'class': 'form-label fw-semibold'}}) }}
                        {{ form_widget(loginForm._password) }}
                        {{ form_errors(loginForm._password) }}
                    </div>
                    {{ form_widget(loginForm._csrf_token) }}
                    <button type="submit" class="btn btn-success w-100 fw-semibold">
                        <i class="bi bi-box-arrow-in-right me-1"></i> Sign In
                    </button>
                {{ form_end(loginForm) }}
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

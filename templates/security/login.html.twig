<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>AgriCloud — Sign In</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Philosopher:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        * { box-sizing: border-box; }
        body { font-family: 'Philosopher', sans-serif; margin: 0; padding: 0; height: 100vh; display: flex; }

        /* ── Left panel ── */
        .auth-left {
            width: 55%;
            background:
                radial-gradient(ellipse at 80% 20%, rgba(119,184,30,.2) 0%, transparent 50%),
                radial-gradient(ellipse at 10% 90%, rgba(30,80,5,.4) 0%, transparent 50%),
                linear-gradient(145deg, #0d1f05 0%, #1a3a08 40%, #2d5c10 100%);
            display: flex; flex-direction: column;
            justify-content: space-between;
            padding: 40px 56px;
            position: relative;
            overflow: hidden;
        }
        .auth-left::before {
            content: '';
            position: absolute; inset: 0;
            background-image: radial-gradient(circle at 1px 1px, rgba(119,184,30,.06) 1px, transparent 0);
            background-size: 36px 36px;
            pointer-events: none;
        }
        .auth-left::after {
            content: '';
            position: absolute; bottom: -60px; right: -60px;
            width: 300px; height: 300px;
            border-radius: 50%;
            background: rgba(119,184,30,.15);
        }

        .auth-brand { display: flex; align-items: center; gap: 10px; text-decoration: none; }
        .auth-brand span { font-size: 1.6rem; font-weight: 700; color: #fff; }
        .auth-brand i { color: #77b81e; font-size: 1.8rem; }

        .auth-hero-text { z-index: 1; }
        .auth-hero-text h2 { color: #fff; font-size: 2.4rem; font-weight: 700; line-height: 1.2; margin-bottom: 16px; }
        .auth-hero-text h2 span { color: #a3d43a; }
        .auth-hero-text p { color: rgba(255,255,255,.72); font-size: 1rem; max-width: 420px; }

        .auth-features { display: flex; flex-direction: column; gap: 14px; z-index: 1; }
        .auth-feature { display: flex; align-items: center; gap: 12px; }
        .auth-feature-icon {
            width: 40px; height: 40px; border-radius: 10px;
            background: rgba(119,184,30,.25);
            display: flex; align-items: center; justify-content: center;
            color: #a3d43a; font-size: 1.1rem; flex-shrink: 0;
        }
        .auth-feature span { color: rgba(255,255,255,.8); font-size: .92rem; }

        /* ── Right panel ── */
        .auth-right {
            width: 45%;
            background: #f8faf4;
            display: flex; align-items: center; justify-content: center;
            padding: 40px 48px;
        }
        .auth-form-wrap { width: 100%; max-width: 380px; }

        .auth-form-wrap h3 { font-size: 1.7rem; font-weight: 700; color: #1a2e0a; margin-bottom: 6px; }
        .auth-form-wrap .subtitle { color: #888; font-size: .9rem; margin-bottom: 32px; }

        .form-label { font-weight: 600; font-size: .85rem; color: #444; margin-bottom: 6px; }
        .form-control {
            border-radius: 10px; border: 1.5px solid #dde8cc;
            padding: 11px 14px; font-size: .93rem; background: #fff;
            transition: border-color .2s, box-shadow .2s;
        }
        .form-control:focus {
            border-color: #77b81e;
            box-shadow: 0 0 0 3px rgba(119,184,30,.15);
            outline: none;
        }
        .input-icon { position: relative; }
        .input-icon i {
            position: absolute; left: 13px; top: 50%; transform: translateY(-50%);
            color: #aaa; font-size: .95rem; pointer-events: none;
        }
        .input-icon .form-control { padding-left: 38px; }

        .btn-auth {
            background: #77b81e; color: #fff; border: none;
            border-radius: 10px; padding: 12px; font-size: 1rem; font-weight: 600;
            width: 100%; transition: background .2s;
            display: flex; align-items: center; justify-content: center; gap: 8px;
        }
        .btn-auth:hover { background: #5a9014; color: #fff; }

        .auth-divider { display: flex; align-items: center; gap: 12px; margin: 24px 0; }
        .auth-divider::before, .auth-divider::after { content: ''; flex: 1; height: 1px; background: #dde8cc; }
        .auth-divider span { color: #aaa; font-size: .82rem; white-space: nowrap; }

        .btn-guest {
            display: flex; align-items: center; justify-content: center; gap: 8px;
            width: 100%; padding: 11px;
            border: 1.5px solid #dde8cc; border-radius: 10px;
            background: #fff; color: #555; font-size: .95rem; font-weight: 600;
            text-decoration: none; transition: all .2s;
        }
        .btn-guest:hover { border-color: #77b81e; color: #77b81e; background: #f0f7e0; }

        .auth-switch { text-align: center; font-size: .88rem; color: #888; }
        .auth-switch a { color: #77b81e; font-weight: 700; text-decoration: none; }
        .auth-switch a:hover { text-decoration: underline; }

        @media (max-width: 768px) {
            .auth-left { display: none; }
            .auth-right { width: 100%; padding: 32px 24px; }
        }
    </style>
</head>
<body>

{# ── Left panel ── #}
<div class="auth-left">
    <a href="{{ path('home') }}" class="auth-brand">
        <i class="bi bi-tree-fill"></i>
        <span>AgriCloud</span>
    </a>

    <div class="auth-hero-text">
        <h2>Welcome<br>Back to<br><span>AgriCloud.</span></h2>
        <p>Sign in to manage your farms, browse the marketplace, and connect with the agricultural community.</p>
    </div>

    <div class="auth-features">
        <div class="auth-feature">
            <div class="auth-feature-icon"><i class="bi bi-house-heart-fill"></i></div>
            <span>Manage your farms and fields</span>
        </div>
        <div class="auth-feature">
            <div class="auth-feature-icon"><i class="bi bi-shop"></i></div>
            <span>Buy and sell agricultural products</span>
        </div>
        <div class="auth-feature">
            <div class="auth-feature-icon"><i class="bi bi-calendar-event"></i></div>
            <span>Discover and join farming events</span>
        </div>
    </div>
</div>

{# ── Right panel ── #}
<div class="auth-right">
    <div class="auth-form-wrap">
        <h3>Sign In</h3>
        <p class="subtitle">Enter your credentials to access your account</p>

        {% if error %}
            <div class="alert alert-danger d-flex align-items-center gap-2 mb-4" style="border-radius:10px;border:none;background:#fde8e8;color:#b91c1c;font-size:.88rem">
                <i class="bi bi-exclamation-triangle-fill"></i>
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <form method="post" action="{{ path('app_login') }}">
            <div class="mb-3">
                <label for="email" class="form-label">Email Address</label>
                <div class="input-icon">
                    <i class="bi bi-envelope"></i>
                    <input type="email" id="email" name="_username" class="form-control"
                           value="{{ last_username }}" autofocus autocomplete="email"
                           placeholder="your@email.com" required>
                </div>
            </div>

            <div class="mb-4">
                <label for="password" class="form-label">Password</label>
                <div class="input-icon">
                    <i class="bi bi-lock"></i>
                    <input type="password" id="password" name="_password" class="form-control"
                           autocomplete="current-password" placeholder="••••••••" required>
                </div>
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="btn-auth">
                <i class="bi bi-box-arrow-in-right"></i> Sign In
            </button>
        </form>

        <div class="auth-divider"><span>or</span></div>

        <a href="{{ path('guest_login') }}" class="btn-guest">
            <i class="bi bi-person-dash"></i> Continue as Guest
        </a>

        <div class="auth-switch mt-3">
            No account? <a href="{{ path('app_register') }}">Create one for free →</a>
        </div>

        <div class="text-center mt-4">
            <a href="{{ path('home') }}" class="text-muted text-decoration-none" style="font-size:.82rem">
                <i class="bi bi-arrow-left me-1"></i>Back to homepage
            </a>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

{% extends 'base.html.twig' %}
{% block title %}{{ product ? 'Edit ' ~ product.name : 'New Product' }} - AgriCloud{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    .product-form-shell {
        width: 100%;
        max-width: 1120px;
    }

    .product-form-card {
        border: 1px solid rgba(119, 184, 30, 0.12);
        border-radius: 28px;
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(252, 253, 249, 0.98));
        box-shadow: 0 20px 48px rgba(35, 58, 12, 0.08);
        overflow: hidden;
    }

    .product-form-card .card-body {
        padding: 2rem 2rem 1.75rem;
    }

    .product-form-heading {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1.75rem;
    }

    .product-form-title {
        display: flex;
        align-items: center;
        gap: 0.85rem;
    }

    .product-form-title h5 {
        margin: 0;
        font-size: 2rem;
        font-weight: 700;
        color: #22340f;
    }

    .product-form-back {
        width: 46px;
        height: 46px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(34, 52, 15, 0.15);
        background: rgba(255, 255, 255, 0.95);
    }

    .product-form-card label {
        font-size: 1.1rem;
        font-weight: 700;
        color: #22340f;
        margin-bottom: 0.55rem;
    }

    .product-form-card .form-control,
    .product-form-card .form-select,
    .product-form-card .input-group-text {
        min-height: 52px;
        border-radius: 16px;
        border: 1px solid #d8e1cb;
        background: #fbfcf8;
        box-shadow: none;
        transition: border-color .2s ease, box-shadow .2s ease, background-color .2s ease, transform .2s ease;
    }

    .product-form-card textarea.form-control {
        min-height: 132px;
        padding-top: 0.95rem;
    }

    .product-form-card .form-control,
    .product-form-card .form-select {
        padding: 0.8rem 1rem;
        font-size: 1.05rem;
    }

    .product-form-card .form-select {
        appearance: none;
        -webkit-appearance: none;
        -moz-appearance: none;
        padding-right: 3rem;
        background-image:
            linear-gradient(45deg, transparent 50%, #577a22 50%),
            linear-gradient(135deg, #577a22 50%, transparent 50%);
        background-position:
            calc(100% - 22px) calc(50% - 2px),
            calc(100% - 15px) calc(50% - 2px);
        background-size: 7px 7px, 7px 7px;
        background-repeat: no-repeat;
    }

    .product-form-card .form-control:focus,
    .product-form-card .form-select:focus {
        border-color: rgba(119, 184, 30, 0.7);
        background: #fff;
        box-shadow: 0 0 0 0.22rem rgba(119, 184, 30, 0.14);
        transform: translateY(-1px);
    }

    .product-form-card .input-group-text {
        padding-inline: 1rem;
        font-weight: 700;
        color: #537a20;
        background: #f2f8e7;
    }

    .product-form-card .form-text {
        margin-top: 0.45rem;
        color: #6e7b5f;
        font-size: 0.95rem;
    }

    .product-form-card .btn-success {
        min-height: 50px;
        padding-inline: 1.35rem;
        border-radius: 14px;
        font-size: 1rem;
        font-weight: 700;
        box-shadow: 0 10px 24px rgba(119, 184, 30, 0.2);
    }

    .product-form-card .btn-outline-secondary {
        min-height: 50px;
        padding-inline: 1.15rem;
        border-radius: 14px;
    }

    .product-form-card #ai-generate-description {
        min-height: 46px;
        padding-inline: 1rem;
        border-radius: 14px;
        border-color: rgba(119, 184, 30, 0.55);
        background: linear-gradient(180deg, #ffffff, #f4faea);
        font-weight: 700;
    }

    .product-form-card #ai-generate-description:hover {
        background: linear-gradient(180deg, #f9fff1, #edf8dc);
        border-color: rgba(119, 184, 30, 0.8);
        color: #3f6812;
    }

    @media (max-width: 991.98px) {
        .product-form-shell {
            max-width: 100%;
        }

        .product-form-card .card-body {
            padding: 1.5rem 1.1rem;
        }

        .product-form-heading {
            align-items: flex-start;
            margin-bottom: 1.25rem;
        }

        .product-form-title h5 {
            font-size: 1.6rem;
        }

    }
</style>
{% endblock %}

{% block body %}
<div class="product-form-shell">
<div class="card product-form-card">
    <div class="card-body p-4">
        <div class="product-form-heading">
            <div class="product-form-title">
                <a href="{{ path('my_products') }}" class="btn btn-outline-secondary product-form-back"><i class="bi bi-arrow-left"></i></a>
                <h5>{{ product ? 'Edit Product - ' ~ product.name : 'List a New Product' }}</h5>
            </div>
        </div>

        {{ form_start(form, {attr: {enctype: 'multipart/form-data', novalidate: 'novalidate'}}) }}

        <div class="row g-3">
            <div class="col-md-8">
                <div class="mb-3">
                    {{ form_label(form.name) }}
                    {{ form_widget(form.name) }}
                    {{ form_errors(form.name) }}
                    <div class="form-text">Required - 2 to 150 characters</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="mb-3">
                    {{ form_label(form.category) }}
                    {{ form_widget(form.category) }}
                    {{ form_errors(form.category) }}
                    <div class="form-text">Optional</div>
                </div>
            </div>
        </div>

        <div class="row g-3">
            <div class="col-md-4">
                <div class="mb-3">
                    {{ form_label(form.price) }}
                    <div class="input-group">
                        {{ form_widget(form.price) }}
                        <span class="input-group-text">TND</span>
                    </div>
                    {{ form_errors(form.price) }}
                    <div class="form-text">Required - Positive number - Max 999,999</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="mb-3">
                    {{ form_label(form.quantity) }}
                    {{ form_widget(form.quantity) }}
                    {{ form_errors(form.quantity) }}
                    <div class="form-text">Required - 0 or more - Max 999,999</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="mb-3">
                    {{ form_label(form.unit) }}
                    {{ form_widget(form.unit) }}
                    {{ form_errors(form.unit) }}
                    <div class="form-text">Required - Unit of measurement</div>
                </div>
            </div>
        </div>

        <div class="mb-3">
            {{ form_label(form.farm) }}
            {{ form_widget(form.farm) }}
            {{ form_errors(form.farm) }}
            <div class="form-text">Optional - Link this product to one of your farms</div>
        </div>

        <div class="mb-3">
            <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                {{ form_label(form.description) }}
                <button
                    type="button"
                    class="btn btn-outline-success btn-sm"
                    id="ai-generate-description"
                    data-endpoint="{{ path('ai_product_description') }}"
                    data-name-id="{{ form.name.vars.id }}"
                    data-category-id="{{ form.category.vars.id }}"
                    data-unit-id="{{ form.unit.vars.id }}"
                    data-price-id="{{ form.price.vars.id }}"
                    data-origin-id="{{ form.farm.vars.id }}"
                    data-stock-id="{{ form.quantity.vars.id }}"
                    data-description-id="{{ form.description.vars.id }}"
                >
                    <i class="bi bi-stars me-1"></i>Generate with AI
                </button>
            </div>
            {{ form_widget(form.description) }}
            {{ form_errors(form.description) }}
            <div class="form-text" id="ai-description-status">Optional - Max 2,000 characters</div>
        </div>

        <div class="mb-4">
            {{ form_label(form.imageFile) }}
            {% if product and product.imageUrl %}
                <div class="mb-2">
                    <img src="{{ product.imageExternal ? product.imageUrl : asset(product.imageUrl) }}" class="rounded-3" style="height:80px;object-fit:cover" alt="">
                    <div class="form-text">Upload a new image to replace the current one. Cloudinary is used when configured, with local storage as a fallback.</div>
                </div>
            {% endif %}
            {{ form_widget(form.imageFile) }}
            {{ form_errors(form.imageFile) }}
            <div class="form-text">Max 2MB - JPG, PNG or WEBP. Images are uploaded to Cloudinary when configured, with local storage as a fallback.</div>
        </div>

        <button type="submit" class="btn btn-success">
            <i class="bi bi-check-lg me-1"></i>{{ product ? 'Save Changes' : 'Submit Product' }}
        </button>
        <a href="{{ path('my_products') }}" class="btn btn-outline-secondary ms-2">Cancel</a>

        {{ form_end(form) }}
    </div>
</div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.addEventListener('DOMContentLoaded', () => {
    const button = document.getElementById('ai-generate-description');

    if (!button) {
        return;
    }

    const status = document.getElementById('ai-description-status');
    const nameInput = document.getElementById(button.dataset.nameId);
    const categoryInput = document.getElementById(button.dataset.categoryId);
    const unitInput = document.getElementById(button.dataset.unitId);
    const priceInput = document.getElementById(button.dataset.priceId);
    const originInput = document.getElementById(button.dataset.originId);
    const stockInput = document.getElementById(button.dataset.stockId);
    const descriptionInput = document.getElementById(button.dataset.descriptionId);

    const setSelectValue = (select, value) => {
        if (!select || typeof value !== 'string' || value.trim() === '') {
            return false;
        }

        const normalizedValue = value.trim().toLowerCase();
        const option = Array.from(select.options).find((item) => {
            return item.value.toLowerCase() === normalizedValue
                || item.text.trim().toLowerCase() === normalizedValue;
        });

        if (!option) {
            return false;
        }

        select.value = option.value;
        select.dispatchEvent(new Event('change', { bubbles: true }));

        return true;
    };

    button.addEventListener('click', async () => {
        const name = nameInput?.value.trim() ?? '';
        const existingDescription = descriptionInput?.value.trim() ?? '';
        const existingCategory = categoryInput?.value ?? '';

        if (!name && !existingCategory && !existingDescription) {
            status.textContent = 'Enter a name, choose a category, or add a short description hint first.';
            status.classList.remove('text-success');
            status.classList.add('text-danger');
            return;
        }

        const origin = originInput && originInput.selectedIndex >= 0
            ? originInput.options[originInput.selectedIndex].text.trim()
            : '';

        const payload = {
            name,
            category: existingCategory,
            unit: unitInput?.value ?? '',
            price: priceInput?.value ?? '',
            origin: origin === '- Not linked to a farm -' ? '' : origin,
            stock: stockInput?.value ?? '',
            description: existingDescription,
        };

        button.disabled = true;
        status.textContent = 'Generating AI draft...';
        status.classList.remove('text-danger', 'text-success');

        try {
            const response = await fetch(button.dataset.endpoint, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest',
                },
                body: JSON.stringify(payload),
            });

            const contentType = response.headers.get('content-type') || '';
            let data = {};

            if (contentType.includes('application/json')) {
                data = await response.json();
            } else {
                const text = await response.text();
                throw new Error(text && !text.startsWith('<') ? text : 'Unable to generate a description right now.');
            }

            if (!response.ok) {
                throw new Error(data.error || 'Unable to generate a description right now.');
            }

            if (typeof data.name === 'string' && data.name.trim() !== '' && nameInput) {
                nameInput.value = data.name.trim();
                nameInput.dispatchEvent(new Event('input', { bubbles: true }));
            }

            setSelectValue(categoryInput, data.category);
            setSelectValue(unitInput, data.unit);

            if (typeof data.description === 'string' && data.description.trim() !== '' && descriptionInput) {
                descriptionInput.value = data.description.trim();
                descriptionInput.dispatchEvent(new Event('input', { bubbles: true }));
            }

            status.textContent = 'AI draft generated successfully.';
            status.classList.add('text-success');
        } catch (error) {
            status.textContent = error.message || 'Unable to generate a description right now.';
            status.classList.add('text-danger');
        } finally {
            button.disabled = false;
        }
    });
});
</script>
{% endblock %}

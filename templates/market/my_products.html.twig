{% extends 'base.html.twig' %}
{% block title %}My Products — AgriCloud{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0"><i class="bi bi-box-seam me-2"></i>{{ is_granted('ROLE_ADMIN') ? 'All Products' : 'My Products' }}</h5>
    <div class="d-flex gap-2">
        <a href="{{ path('market_index') }}" class="btn btn-outline-secondary btn-sm"><i class="bi bi-shop me-1"></i>Marketplace</a>
        <a href="{{ path('product_new') }}" class="btn btn-success btn-sm"><i class="bi bi-plus-lg me-1"></i>New Product</a>
    </div>
</div>

<form method="get" class="mb-3 d-flex gap-2" style="max-width:500px">
    <input type="text" name="q" value="{{ q }}" class="form-control form-control-sm" placeholder="Search…">
    {% if is_granted('ROLE_ADMIN') %}
    <select name="status" class="form-select form-select-sm" style="width:140px">
        <option value="">All statuses</option>
        {% for s in ['pending','approved','rejected','sold_out'] %}
            <option value="{{ s }}" {{ status == s ? 'selected' : '' }}>{{ s|capitalize }}</option>
        {% endfor %}
    </select>
    {% endif %}
    <button class="btn btn-outline-secondary btn-sm"><i class="bi bi-search"></i></button>
    {% if q or status %}<a href="{{ path('my_products') }}" class="btn btn-outline-danger btn-sm"><i class="bi bi-x"></i></a>{% endif %}
</form>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Product</th>
                    {% if is_granted('ROLE_ADMIN') %}<th>Seller</th>{% endif %}
                    <th>Price</th>
                    <th>Stock</th>
                    <th>Status</th>
                    <th>Views</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for product in pagination %}
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            {% if product.image %}
                                <img src="{{ asset('uploads/products/' ~ product.image) }}" class="rounded-2" style="width:40px;height:40px;object-fit:cover" alt="">
                            {% else %}
                                <div class="rounded-2 d-flex align-items-center justify-content-center bg-light" style="width:40px;height:40px;font-size:1.2rem;color:#198754"><i class="bi bi-bag-heart"></i></div>
                            {% endif %}
                            <div>
                                <div class="fw-semibold">{{ product.name }}</div>
                                {% if product.category %}<div class="text-muted small">{{ product.category|capitalize }}</div>{% endif %}
                            </div>
                        </div>
                    </td>
                    {% if is_granted('ROLE_ADMIN') %}<td class="small">{{ product.user.name }}</td>{% endif %}
                    <td class="fw-semibold text-success">{{ product.price }} TND</td>
                    <td>{{ product.quantity }} {{ product.unit }}</td>
                    <td>
                        <span class="badge {% if product.status == 'approved' %}bg-success{% elseif product.status == 'pending' %}bg-warning text-dark{% elseif product.status == 'rejected' %}bg-danger{% else %}bg-secondary{% endif %}">
                            {{ product.status|capitalize }}
                        </span>
                    </td>
                    <td class="text-muted small">{{ product.views ?? 0 }}</td>
                    <td class="text-end">
                        <a href="{{ path('product_show', {id: product.id}) }}" class="btn btn-sm btn-outline-secondary" title="View"><i class="bi bi-eye"></i></a>
                        <a href="{{ path('product_edit', {id: product.id}) }}" class="btn btn-sm btn-outline-primary" title="Edit"><i class="bi bi-pencil"></i></a>
                        {% if is_granted('ROLE_ADMIN') and product.status == 'pending' %}
                        <form method="post" action="{{ path('product_approve', {id: product.id}) }}" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('approve_product_' ~ product.id) }}">
                            <button class="btn btn-sm btn-outline-success" title="Approve"><i class="bi bi-check-lg"></i></button>
                        </form>
                        <form method="post" action="{{ path('product_reject', {id: product.id}) }}" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('reject_product_' ~ product.id) }}">
                            <button class="btn btn-sm btn-outline-danger" title="Reject"><i class="bi bi-x-lg"></i></button>
                        </form>
                        {% endif %}
                        <form method="post" action="{{ path('product_delete', {id: product.id}) }}" class="d-inline" onsubmit="return confirm('Delete this product?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_product_' ~ product.id) }}">
                            <button class="btn btn-sm btn-outline-danger" title="Delete"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
                {% else %}
                <tr><td colspan="7" class="text-center text-muted py-4">No products found.</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    {% if pagination.pageCount > 1 %}
    <div class="card-footer bg-white d-flex justify-content-end py-2">
        {{ knp_pagination_render(pagination) }}
    </div>
    {% endif %}
</div>
{% endblock %}

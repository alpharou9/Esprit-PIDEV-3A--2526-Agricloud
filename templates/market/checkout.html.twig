{% extends 'base.html.twig' %}
{% block title %}Checkout - AgriCloud{% endblock %}

{% block stylesheets %}
<style>
.payment-choice-group{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:1rem}
.payment-choice-card{position:relative}
.payment-choice-card input{position:absolute;opacity:0;pointer-events:none}
.payment-choice-label{display:block;height:100%;border:1px solid #dbe6cf;border-radius:20px;padding:1rem 1rem .9rem;background:#fbfcf8;cursor:pointer;transition:all .18s ease}
.payment-choice-label strong{display:block;margin-bottom:.2rem;color:#203015}
.payment-choice-label span{display:block;font-size:.9rem;line-height:1.6;color:#6b7c59}
.payment-choice-card input:checked + .payment-choice-label{border-color:#77b81e;background:#f1f8e3;box-shadow:0 0 0 .22rem rgba(119,184,30,.12)}
@media (max-width: 767.98px){.payment-choice-group{grid-template-columns:1fr}}
</style>
{% endblock %}

{% block body %}
<div class="d-flex align-items-center gap-2 mb-4">
    <a href="{{ path('cart_index') }}" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h5 class="fw-bold mb-0"><i class="bi bi-credit-card me-2"></i>Checkout</h5>
</div>

<div class="row g-4">
    <div class="col-md-7">
        <div class="card border-0 shadow-sm rounded-4 p-4">
            <h6 class="fw-bold mb-3">Shipping Information</h6>
            {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

            <div class="mb-4">
                {{ form_label(form.paymentMethod) }}
                <div class="payment-choice-group">
                    {% for choice in form.paymentMethod %}
                        <div class="payment-choice-card">
                            {{ form_widget(choice) }}
                            <label class="payment-choice-label" for="{{ choice.vars.id }}">
                                <strong>{{ choice.vars.label }}</strong>
                                <span>
                                    {% if choice.vars.value == 'stripe' %}
                                        Pay securely with Stripe checkout.
                                    {% else %}
                                        Confirm now and pay when the order is delivered.
                                    {% endif %}
                                </span>
                            </label>
                        </div>
                    {% endfor %}
                </div>
                {{ form_errors(form.paymentMethod) }}
            </div>

            <div class="mb-3">
                {{ form_label(form.shippingAddress) }}
                {{ form_widget(form.shippingAddress) }}
                {{ form_errors(form.shippingAddress) }}
                <div class="form-text">Required - 5-500 characters</div>
            </div>
            <div class="row g-3">
                <div class="col-md-7">
                    <div class="mb-3">
                        {{ form_label(form.shippingCity) }}
                        {{ form_widget(form.shippingCity) }}
                        {{ form_errors(form.shippingCity) }}
                        <div class="form-text">Required - Max 100 characters</div>
                    </div>
                </div>
                <div class="col-md-5">
                    <div class="mb-3">
                        {{ form_label(form.shippingPostal) }}
                        {{ form_widget(form.shippingPostal) }}
                        {{ form_errors(form.shippingPostal) }}
                        <div class="form-text">Optional - Digits only - 4-10 numbers</div>
                    </div>
                </div>
            </div>
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="mb-3">
                        {{ form_label(form.shippingEmail) }}
                        {{ form_widget(form.shippingEmail) }}
                        {{ form_errors(form.shippingEmail) }}
                        <div class="form-text">Required - Valid email address</div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        {{ form_label(form.shippingPhone) }}
                        {{ form_widget(form.shippingPhone) }}
                        {{ form_errors(form.shippingPhone) }}
                        <div class="form-text">Optional - 8-20 digits, may start with +</div>
                    </div>
                </div>
            </div>
            <div class="mb-4">
                {{ form_label(form.notes) }}
                {{ form_widget(form.notes) }}
                {{ form_errors(form.notes) }}
                <div class="form-text">Optional - Max 1,000 characters</div>
            </div>

            <button type="submit" class="btn btn-success w-100 py-2 fw-semibold">
                <i class="bi bi-bag-check me-1"></i>Continue - {{ total|number_format(2) }} TND
            </button>
            {{ form_end(form) }}
        </div>
    </div>

    <div class="col-md-5">
        <div class="card border-0 shadow-sm rounded-4 p-4">
            <h6 class="fw-bold mb-3">Order Summary</h6>
            {% for item in items %}
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="small">
                    <span class="fw-semibold">{{ item.product.name }}</span>
                    <span class="text-muted"> x {{ item.quantity }}</span>
                </div>
                <span class="small fw-semibold">{{ item.subtotal|number_format(2) }} TND</span>
            </div>
            {% endfor %}
            <hr>
            <div class="d-flex justify-content-between fw-bold">
                <span>Total</span>
                <span class="text-success">{{ total|number_format(2) }} TND</span>
            </div>
            {% if stripeConvertedTotal is not null %}
            <div class="d-flex justify-content-between small text-muted mt-2">
                <span>Stripe charge</span>
                <span>{{ stripeConvertedTotal|number_format(2) }} {{ stripeCurrency }}</span>
            </div>
            {% endif %}
            <div class="text-muted small mt-3">
                Stripe checkout charges in {{ stripeCurrency }} using the current TND conversion rate, while cash on delivery keeps the current flow.
            </div>
        </div>
    </div>
</div>
{% endblock %}

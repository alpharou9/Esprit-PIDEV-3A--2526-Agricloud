{% extends 'base.html.twig' %}
{% block title %}Orders - AgriCloud{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0"><i class="bi bi-receipt me-2"></i>Orders</h5>
    <a href="{{ path('market_index') }}" class="btn btn-outline-secondary btn-sm"><i class="bi bi-shop me-1"></i>Marketplace</a>
</div>

{% macro order_table(orders, title, icon) %}
<h6 class="fw-semibold text-muted mb-2"><i class="bi bi-{{ icon }} me-1"></i>{{ title }}</h6>
{% if orders is empty %}
<div class="text-muted small mb-4 p-3 bg-light rounded-3">No orders here.</div>
{% else %}
<div class="card border-0 shadow-sm mb-4">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Product</th>
                    <th>Qty</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th>Date</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for order in orders %}
                <tr>
                    <td class="text-muted small">{{ order.id }}</td>
                    <td class="fw-semibold">{{ order.product.name }}</td>
                    <td>{{ order.quantity }}</td>
                    <td class="text-success fw-bold">{{ order.totalPrice }} TND</td>
                    <td>
                        <div class="d-flex flex-column gap-2" style="min-width: 170px;">
                            <span class="badge bg-{{ order.statusColor }} {{ order.status == 'pending' ? 'text-dark' : '' }} align-self-start">{{ order.statusLabel }}</span>
                            <div class="progress" style="height: 7px;">
                                <div class="progress-bar bg-{{ order.status == 'cancelled' ? 'danger' : 'success' }}" role="progressbar" style="width: {{ order.statusProgressPercent }}%;"></div>
                            </div>
                            <small class="text-muted">
                                {% if order.status == 'cancelled' %}
                                    Order cancelled
                                {% else %}
                                    Step {{ order.statusStepNumber }} of 5
                                {% endif %}
                            </small>
                        </div>
                    </td>
                    <td class="text-muted small">{{ order.orderDate ? order.orderDate|date('d M Y') : '-' }}</td>
                    <td class="text-end">
                        <div class="d-inline-flex gap-2">
                            <a href="{{ path('order_show', {id: order.id}) }}" class="btn btn-sm btn-outline-secondary"><i class="bi bi-eye"></i></a>
                            <a href="{{ path('order_export_pdf', {id: order.id}) }}" class="btn btn-sm btn-outline-danger"><i class="bi bi-file-earmark-pdf"></i></a>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}
{% endmacro %}

{{ _self.order_table(myOrders, 'My Purchases', 'bag-check') }}
{{ _self.order_table(mySales, is_granted('ROLE_ADMIN') ? 'All Orders' : 'My Sales', 'shop') }}
{% endblock %}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Order #{{ order.id }}</title>
    <style>
        body { font-family: DejaVu Sans, sans-serif; color: #22340f; font-size: 13px; margin: 28px; }
        .header { border-bottom: 2px solid #77b81e; padding-bottom: 14px; margin-bottom: 24px; }
        .brand { font-size: 28px; font-weight: 700; color: #5a9014; margin: 0 0 4px; }
        .subtitle { color: #6e7b5f; margin: 0; }
        .meta-table, .summary-table { width: 100%; border-collapse: collapse; margin-bottom: 22px; }
        .meta-table td { vertical-align: top; width: 50%; padding-right: 18px; }
        .panel { border: 1px solid #dde7cf; border-radius: 14px; padding: 14px 16px; background: #fbfcf8; }
        .panel-title { font-size: 14px; font-weight: 700; margin: 0 0 10px; color: #314a13; }
        .detail-row { margin-bottom: 7px; }
        .detail-label { display: inline-block; min-width: 110px; color: #6e7b5f; font-weight: 700; }
        .summary-table th, .summary-table td { border: 1px solid #dde7cf; padding: 10px 12px; text-align: left; }
        .summary-table thead th { background: #edf6df; color: #314a13; font-weight: 700; }
        .total-row td { font-weight: 700; background: #f6faee; }
        .status { display: inline-block; padding: 4px 10px; border-radius: 999px; background: #edf6df; color: #43691a; font-weight: 700; font-size: 12px; }
        .footer { margin-top: 28px; color: #7c8970; font-size: 11px; text-align: center; }
    </style>
</head>
<body>
    <div class="header">
        <h1 class="brand">AgriCloud</h1>
        <p class="subtitle">Order summary export</p>
    </div>

    <table class="meta-table">
        <tr>
            <td>
                <div class="panel">
                    <h2 class="panel-title">Order Information</h2>
                    <div class="detail-row"><span class="detail-label">Order ID</span> #{{ order.id }}</div>
                    <div class="detail-row"><span class="detail-label">Status</span> <span class="status">{{ order.status|capitalize }}</span></div>
                    <div class="detail-row"><span class="detail-label">Order Date</span> {{ order.orderDate ? order.orderDate|date('d M Y H:i') : '-' }}</div>
                    <div class="detail-row"><span class="detail-label">Customer</span> {{ order.customer.name }}</div>
                    <div class="detail-row"><span class="detail-label">Seller</span> {{ order.seller.name }}</div>
                    {% if order.cancelledAt %}
                        <div class="detail-row"><span class="detail-label">Cancelled</span> {{ order.cancelledAt|date('d M Y H:i') }}</div>
                    {% endif %}
                </div>
            </td>
            <td>
                <div class="panel">
                    <h2 class="panel-title">Shipping Details</h2>
                    <div class="detail-row"><span class="detail-label">Address</span> {{ order.shippingAddress }}</div>
                    <div class="detail-row"><span class="detail-label">City</span> {{ order.shippingCity ?: '-' }}</div>
                    <div class="detail-row"><span class="detail-label">Postal</span> {{ order.shippingPostal ?: '-' }}</div>
                    <div class="detail-row"><span class="detail-label">Email</span> {{ order.shippingEmail ?: '-' }}</div>
                    <div class="detail-row"><span class="detail-label">Phone</span> {{ order.shippingPhone ?: '-' }}</div>
                </div>
            </td>
        </tr>
    </table>

    <table class="summary-table">
        <thead>
            <tr>
                <th>Product</th>
                <th>Unit Price</th>
                <th>Quantity</th>
                <th>Total</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>{{ order.product.name }}</td>
                <td>{{ order.unitPrice }} TND</td>
                <td>{{ order.quantity }} {{ order.product.unit }}</td>
                <td>{{ order.totalPrice }} TND</td>
            </tr>
            <tr class="total-row">
                <td colspan="3">Grand Total</td>
                <td>{{ order.totalPrice }} TND</td>
            </tr>
        </tbody>
    </table>

    {% if order.notes %}
        <div class="panel">
            <h2 class="panel-title">Notes</h2>
            <div>{{ order.notes }}</div>
        </div>
    {% endif %}

    <div class="footer">
        Generated on {{ "now"|date('d M Y H:i') }} by AgriCloud
    </div>
</body>
</html>

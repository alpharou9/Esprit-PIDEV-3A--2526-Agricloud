{% extends 'base.html.twig' %}
{% block title %}Marketplace - AgriCloud{% endblock %}

{% block stylesheets %}
<style>
.product-card{border-radius:14px;border:none;box-shadow:0 2px 10px rgba(0,0,0,.07);transition:transform .15s,box-shadow .15s;overflow:hidden}
.product-card:hover{transform:translateY(-3px);box-shadow:0 6px 20px rgba(0,0,0,.12)}
.product-img{height:180px;object-fit:cover;width:100%}
.product-img-placeholder{height:180px;background:linear-gradient(135deg,#d1e7dd,#a3cfbb);display:flex;align-items:center;justify-content:center;font-size:3rem;color:#198754}
.favorite-toggle-form{position:absolute;top:12px;right:12px;z-index:3}
.favorite-toggle-btn{width:42px;height:42px;border:none;border-radius:999px;display:inline-flex;align-items:center;justify-content:center;background:rgba(255,255,255,.96);box-shadow:0 10px 24px rgba(18,38,12,.16);color:#7a8b66;transition:transform .16s ease,box-shadow .16s ease,color .16s ease}
.favorite-toggle-btn:hover{transform:translateY(-1px) scale(1.03);box-shadow:0 12px 28px rgba(18,38,12,.2);color:#198754}
.favorite-toggle-btn.is-active{color:#dc3545}
.product-rating-badge{position:absolute;top:12px;left:12px;z-index:2;display:inline-flex;flex-direction:column;gap:.1rem;min-width:104px;padding:.45rem .65rem;border-radius:14px;background:rgba(255,255,255,.94);backdrop-filter:blur(8px);box-shadow:0 10px 24px rgba(18,38,12,.14)}
.product-rating-stars{font-size:.72rem;letter-spacing:.06em;color:#f4b400;line-height:1}
.product-rating-meta{font-size:.72rem;font-weight:700;color:#355c19;line-height:1.1}
.product-rating-empty{font-size:.72rem;font-weight:600;color:#6c757d;line-height:1.1}
.product-stock-chip{display:inline-flex;align-items:center;gap:.35rem;padding:.35rem .65rem;border-radius:999px;font-size:.74rem;font-weight:700}
.product-stock-chip-out{background:#fef3f2;color:#b42318}
.product-stock-chip-low{background:#fff7ed;color:#b54708}
.product-stock-chip-ok{background:#ecfdf3;color:#166534}
.market-filter-card{max-width:980px;border:1px solid rgba(119,184,30,.12);background:linear-gradient(180deg,rgba(255,255,255,.96),rgba(249,251,244,.98));border-radius:24px;box-shadow:0 14px 34px rgba(35,58,12,.07);padding:1rem 1rem .9rem}
.market-filter-grid{display:grid;grid-template-columns:minmax(0,1.8fr) minmax(200px,.8fr) minmax(200px,.8fr) auto auto;gap:.9rem;align-items:center}
.market-search-wrap,.market-select-wrap{position:relative}
.market-search-wrap .form-control,.market-select-wrap .form-select{min-height:52px;border-radius:16px;border:1px solid #d8e1cb;background:#fcfdf9;box-shadow:none;font-size:1rem;padding:.85rem 1rem;transition:border-color .18s ease,box-shadow .18s ease,transform .18s ease}
.market-search-wrap .form-control{padding-left:2.85rem}
.market-select-wrap .form-select{appearance:none;-webkit-appearance:none;-moz-appearance:none;padding-right:3rem;background-image:linear-gradient(45deg,transparent 50%,#577a22 50%),linear-gradient(135deg,#577a22 50%,transparent 50%);background-position:calc(100% - 22px) calc(50% - 2px),calc(100% - 15px) calc(50% - 2px);background-size:7px 7px,7px 7px;background-repeat:no-repeat}
.market-search-wrap .form-control:focus,.market-select-wrap .form-select:focus{border-color:rgba(119,184,30,.72);background:#fff;box-shadow:0 0 0 .22rem rgba(119,184,30,.14);transform:translateY(-1px)}
.market-search-icon{position:absolute;left:1rem;top:50%;transform:translateY(-50%);font-size:1rem;color:#6d7e58;pointer-events:none}
.market-filter-action{min-height:52px;border-radius:16px;padding-inline:1rem;font-weight:700}
.market-filter-reset{min-height:52px;border-radius:16px;padding-inline:1rem}
.category-pills{display:flex;gap:.65rem;flex-wrap:wrap;margin-top:1rem}
.category-pill{cursor:pointer;border-radius:999px;padding:.55rem 1rem;font-size:.9rem;font-weight:700;border:1px solid #d9e1d0;background:rgba(255,255,255,.96);color:#42641b;text-decoration:none;transition:all .16s ease}
.category-pill:hover,.category-pill.active{background:#198754;color:#fff;border-color:#198754;box-shadow:0 10px 22px rgba(25,135,84,.18);transform:translateY(-1px)}
.pagination{gap:4px}.pagination .page-item .page-link{border:none;border-radius:8px;width:34px;height:34px;display:flex;align-items:center;justify-content:center;font-size:.85rem;font-weight:500;color:#495057;background:#f1f3f5;transition:all .15s;padding:0}
.pagination .page-item .page-link:hover{background:#d1e7dd;color:#198754;transform:translateY(-1px)}
.pagination .page-item.active .page-link{background:#198754;color:#fff;box-shadow:0 3px 8px rgba(25,135,84,.4)}
.pagination .page-item.disabled .page-link{background:transparent;color:#ced4da}
@media (max-width: 991.98px){.market-filter-grid{grid-template-columns:1fr 1fr}.market-filter-action,.market-filter-reset{width:100%}}
@media (max-width: 767.98px){.market-filter-card{padding:.9rem}.market-filter-grid{grid-template-columns:1fr}.category-pill{font-size:.85rem}}
</style>
{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0"><i class="bi bi-shop me-2"></i>Marketplace</h5>
    <div class="d-flex gap-2">
        <a href="{{ path('my_products') }}" class="btn btn-outline-success btn-sm"><i class="bi bi-box-seam me-1"></i>My Products</a>
        <a href="{{ path('favorite_index') }}" class="btn btn-outline-danger btn-sm"><i class="bi bi-heart me-1"></i>My Favorites</a>
        <a href="{{ path('product_new') }}" class="btn btn-success btn-sm"><i class="bi bi-plus-lg me-1"></i>Sell Product</a>
        <a href="{{ path('cart_index') }}" class="btn btn-outline-primary btn-sm"><i class="bi bi-cart me-1"></i>Cart</a>
        <a href="{{ path('order_index') }}" class="btn btn-outline-secondary btn-sm"><i class="bi bi-receipt me-1"></i>Orders</a>
    </div>
</div>

<form method="get" class="market-filter-card mb-4">
    <div class="market-filter-grid">
        <div class="market-search-wrap">
            <i class="bi bi-search market-search-icon"></i>
            <input type="text" name="q" value="{{ q }}" class="form-control" placeholder="Search products...">
        </div>
        <div class="market-select-wrap">
            <select name="category" class="form-select">
                <option value="" {{ category == '' ? 'selected' : '' }}>Select category</option>
                {% for label, val in {'Vegetables':'vegetables','Fruits':'fruits','Grains':'grains','Dairy':'dairy','Meat':'meat','Herbs':'herbs','Other':'other'} %}
                    <option value="{{ val }}" {{ category == val ? 'selected' : '' }}>{{ label }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="market-select-wrap">
            <select name="sort" class="form-select">
                <option value="" {{ sort == '' ? 'selected' : '' }}>Sort by</option>
                <option value="name_asc" {{ sort == 'name_asc' ? 'selected' : '' }}>Name A to Z</option>
                <option value="name_desc" {{ sort == 'name_desc' ? 'selected' : '' }}>Name Z to A</option>
                <option value="price_asc" {{ sort == 'price_asc' ? 'selected' : '' }}>Price low to high</option>
                <option value="price_desc" {{ sort == 'price_desc' ? 'selected' : '' }}>Price high to low</option>
                <option value="newest" {{ sort == 'newest' ? 'selected' : '' }}>Newest first</option>
            </select>
        </div>
        <button class="btn btn-success market-filter-action" type="submit">
            <i class="bi bi-sliders me-1"></i>Filter
        </button>
        {% if q or category or sort %}
            <a href="{{ path('market_index') }}" class="btn btn-outline-danger market-filter-reset d-inline-flex align-items-center justify-content-center">
                <i class="bi bi-x-lg me-1"></i>Reset
            </a>
        {% endif %}
    </div>

    <div class="category-pills">
        <a href="{{ path('market_index', {q: q, sort: sort}) }}" class="category-pill {{ category == '' ? 'active' : '' }}">All</a>
        {% for label, val in {'Vegetables':'vegetables','Fruits':'fruits','Grains':'grains','Dairy':'dairy','Meat':'meat','Herbs':'herbs','Other':'other'} %}
            <a href="{{ path('market_index', {q: q, category: val, sort: sort}) }}" class="category-pill {{ category == val ? 'active' : '' }}">{{ label }}</a>
        {% endfor %}
    </div>
</form>

{% if pagination.totalItemCount == 0 %}
<div class="text-center text-muted py-5">
    <i class="bi bi-shop" style="font-size:3rem;opacity:.3"></i>
    <p class="mt-2">No products found.</p>
</div>
{% else %}
<div class="row g-3">
    {% for product in pagination %}
    {% set review = productReviewStats[product.id] ?? {averageRating: null, reviewCount: 0} %}
    {% set reviewRounded = review.averageRating is not null ? review.averageRating|round(0, 'common') : 0 %}
    <div class="col-md-3">
        <div class="card product-card h-100">
            <div class="position-relative">
                {% if app.user and product.user != app.user %}
                    {% include 'market/_favorite_button.html.twig' with {
                        product: product,
                        isFavorited: product.id in favoriteProductIds,
                        redirectRoute: 'market_index',
                        buttonClass: 'favorite-toggle-btn'
                    } only %}
                {% endif %}
                <div class="product-rating-badge">
                    <div class="product-rating-stars">
                        {% for i in 1..5 %}
                            <i class="bi {% if i <= reviewRounded %}bi-star-fill{% else %}bi-star{% endif %}"></i>
                        {% endfor %}
                    </div>
                    {% if review.averageRating is not null %}
                        <div class="product-rating-meta">{{ review.averageRating|number_format(1) }}/5 • {{ review.reviewCount }} review{{ review.reviewCount == 1 ? '' : 's' }}</div>
                    {% else %}
                        <div class="product-rating-empty">No reviews yet</div>
                    {% endif %}
                </div>

                {% if product.imageUrl %}
                    <img src="{{ product.imageExternal ? product.imageUrl : asset(product.imageUrl) }}" class="product-img" alt="{{ product.name }}">
                {% else %}
                    <div class="product-img-placeholder">
                        <i class="bi bi-bag-heart"></i>
                    </div>
                {% endif %}
                {% if product.quantity == 0 %}
                <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center" style="background:rgba(0,0,0,.45);border-radius:0">
                    <span class="badge bg-danger fs-6 px-3 py-2"><i class="bi bi-x-circle me-1"></i>Out of Stock</span>
                </div>
                {% endif %}
            </div>
            <div class="card-body d-flex flex-column">
                <div class="d-flex justify-content-between align-items-start mb-1">
                    <h6 class="fw-bold mb-0">{{ product.name }}</h6>
                    {% if product.category %}
                        <span class="badge bg-light text-dark border small">{{ product.category|capitalize }}</span>
                    {% endif %}
                </div>
                <p class="text-muted small mb-2 flex-grow-1">{{ product.description|slice(0,80) }}{% if product.description|length > 80 %}...{% endif %}</p>
                <div class="mb-2">
                    {% if product.quantity == 0 %}
                        <span class="product-stock-chip product-stock-chip-out">
                            <i class="bi bi-x-octagon-fill"></i>Out of stock
                        </span>
                    {% elseif product.quantity <= 5 %}
                        <span class="product-stock-chip product-stock-chip-low">
                            <i class="bi bi-fire"></i>Only {{ product.quantity }} left in stock
                        </span>
                    {% else %}
                        <span class="product-stock-chip product-stock-chip-ok">
                            <i class="bi bi-check-circle-fill"></i>In stock
                        </span>
                    {% endif %}
                </div>
                <div class="d-flex justify-content-between align-items-center mt-auto">
                    <span class="fw-bold text-success fs-5">{{ product.price }} TND<span class="text-muted small fw-normal">/{{ product.unit }}</span></span>
                    {% if product.quantity == 0 %}
                        <span class="text-danger small fw-semibold"><i class="bi bi-x-circle me-1"></i>Out of stock</span>
                    {% else %}
                        <span class="text-muted small"><i class="bi bi-layers me-1"></i>{{ product.quantity }} left</span>
                    {% endif %}
                </div>
                <div class="text-muted small mt-1"><i class="bi bi-person me-1"></i>{{ product.user.name }}</div>
            </div>
            <div class="card-footer bg-white border-0 pb-3">
                {% if product.quantity == 0 %}
                <button class="btn btn-secondary btn-sm w-100" disabled>
                    <i class="bi bi-x-circle me-1"></i>Out of Stock
                </button>
                {% else %}
                <a href="{{ path('product_show', {id: product.id}) }}" class="btn btn-success btn-sm w-100">
                    <i class="bi bi-eye me-1"></i>View & Buy
                </a>
                {% endif %}
            </div>
        </div>
    </div>
    {% endfor %}
</div>

{% if pagination.pageCount > 1 %}
<div class="d-flex justify-content-center mt-4">
    {{ knp_pagination_render(pagination) }}
</div>
{% endif %}
{% endif %}
{% endblock %}

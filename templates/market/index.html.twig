{% extends 'front_base.html.twig' %}

{% block title %}Market - AgriCloud{% endblock %}

{% block tophead %}
    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
        <div>
            <a href="{{ path('market_index') }}" class="fs-4 fw-bold">
                <i class="bi bi-tree-fill me-2"></i>AgriCloud Market
            </a>
            <div class="small opacity-75 mt-1">Approved products only, ready for customer purchase.</div>
        </div>
        <div class="d-flex align-items-center gap-3">
            {% if is_granted('ROLE_CUSTOMER') %}
                <a href="{{ path('cart_index') }}" class="btn btn-light btn-sm">
                    <i class="bi bi-cart3 me-1"></i>Cart <span class="badge text-bg-success ms-1">{{ cartCount }}</span>
                </a>
                <a href="{{ path('customer_order_index') }}" class="btn btn-outline-light btn-sm">My orders</a>
            {% elseif not app.user %}
                <a href="{{ path('app_login') }}" class="btn btn-light btn-sm">Login to buy</a>
            {% endif %}
            {% if is_granted('ROLE_FARMER') %}
                <a href="{{ path('dashboard') }}" class="btn btn-outline-light btn-sm">Backoffice</a>
            {% endif %}
        </div>
    </div>
{% endblock %}

{% block maincontainer %}
<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h2 class="fw-bold mb-1">Product Catalog</h2>
        <p class="text-muted mb-0">Front-office market view based on your `products` and `shopping_cart` tables.</p>
    </div>
</div>

<form method="get" class="mb-4">
    <div class="p-3 p-lg-4 rounded-4" style="background: linear-gradient(135deg, rgba(47,125,50,.07), rgba(134,184,93,.14)); border: 1px solid rgba(47,125,50,.12);">
        <div class="row g-3 align-items-end">
            <div class="col-lg-5">
                <label for="q" class="form-label fw-semibold">Search</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
                    <input id="q" type="text" name="q" value="{{ q }}" class="form-control border-start-0" placeholder="Name, category, farmer">
                </div>
            </div>
            <div class="col-md-4 col-lg-3">
                <label for="category" class="form-label fw-semibold">Category</label>
                <select id="category" name="category" class="form-select">
                    <option value="">All categories</option>
                    {% for category in categories %}
                        <option value="{{ category }}" {{ selectedCategory == category ? 'selected' : '' }}>{{ category }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-4 col-lg-2">
                <label for="sort" class="form-label fw-semibold">Sort by</label>
                <select id="sort" name="sort" class="form-select">
                    {% for value, label in sortOptions %}
                        <option value="{{ value }}" {{ selectedSort == value ? 'selected' : '' }}>{{ label }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-4 col-lg-2 d-grid">
                <button class="btn btn-success"><i class="bi bi-funnel-fill me-1"></i>Apply</button>
            </div>
        </div>
    </div>
</form>

<div class="row g-4">
    {% for product in products %}
        <div class="col-md-6 col-xl-4">
            <div class="card border-0 shadow-sm h-100 rounded-4 overflow-hidden">
                {% if product.image %}
                    <img src="/{{ product.image }}" alt="{{ product.name }}" class="card-img-top" style="height: 220px; object-fit: cover;">
                {% else %}
                    <div class="d-flex align-items-center justify-content-center bg-light" style="height: 220px;">
                        <i class="bi bi-image text-muted fs-1"></i>
                    </div>
                {% endif %}
                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                        <div>
                            <h5 class="card-title mb-1">
                                <a href="{{ path('market_show', {id: product.id}) }}" class="text-decoration-none text-dark">
                                    {{ product.name }}
                                </a>
                            </h5>
                            <div class="text-muted small">{{ product.category ?: 'Other' }}</div>
                        </div>
                        <span class="badge text-bg-success">{{ product.price|number_format(2, '.', ' ') }}</span>
                    </div>
                    <p class="text-muted small flex-grow-1">{{ product.description ?: 'No description provided.' }}</p>
                    <div class="small text-muted mb-1">Farmer: {{ product.user ? product.user.name : 'N/A' }}</div>
                    <div class="small text-muted mb-3">Farm: {{ product.farm ? product.farm.name : 'No farm' }}</div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="fw-semibold">{{ product.quantity }} {{ product.unit }} available</span>
                        <span class="badge text-bg-light">Views {{ product.views ?? 0 }}</span>
                    </div>
                    <div class="mt-auto d-grid gap-2">
                        <a href="{{ path('market_show', {id: product.id}) }}" class="btn btn-outline-success">
                            <i class="bi bi-eye me-1"></i>View details
                        </a>
                        {% if is_granted('ROLE_CUSTOMER') %}
                            <form method="post" action="{{ path('cart_add', {id: product.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('cart_add_' ~ product.id) }}">
                                <div class="input-group">
                                    <input type="number" min="1" max="{{ product.quantity }}" name="quantity" value="1" class="form-control">
                                    <button class="btn btn-success">
                                        <i class="bi bi-cart-plus me-1"></i>Add to cart
                                    </button>
                                </div>
                            </form>
                        {% else %}
                            <a href="{{ path('app_login') }}" class="btn btn-success">
                                <i class="bi bi-box-arrow-in-right me-1"></i>Login to order
                            </a>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    {% else %}
        <div class="col-12">
            <div class="text-center py-5 text-muted">
                <i class="bi bi-basket fs-1 d-block mb-3"></i>
                No approved products match your current filters.
            </div>
        </div>
    {% endfor %}
</div>
{% endblock %}

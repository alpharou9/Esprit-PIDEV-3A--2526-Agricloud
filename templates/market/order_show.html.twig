{% extends 'base.html.twig' %}
{% block title %}Order #{{ order.id }} - AgriCloud{% endblock %}

{% block body %}
{% set timeline = ['pending', 'confirmed', 'preparing', 'shipped', 'delivered'] %}
<div class="d-flex align-items-center gap-2 mb-4">
    <a href="{{ path('order_index') }}" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h5 class="fw-bold mb-0">Order #{{ order.id }}</h5>
    <span class="badge bg-{{ order.statusColor }} {% if order.status == 'pending' %}text-dark{% endif %}">{{ order.statusLabel }}</span>
    <a href="{{ path('order_export_pdf', {id: order.id}) }}" class="btn btn-outline-danger btn-sm ms-auto">
        <i class="bi bi-file-earmark-pdf me-1"></i>Export PDF
    </a>
</div>

<div class="row g-4">
    <div class="col-md-7">
        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="fw-bold mb-0">Order Progress</h6>
                <span class="small text-muted">{{ order.status == 'cancelled' ? 'Cancelled' : order.statusProgressPercent ~ '% complete' }}</span>
            </div>
            {% if order.status == 'cancelled' %}
                <div class="alert alert-danger rounded-4 mb-0">
                    This order has been cancelled{% if order.cancelledReason %}: {{ order.cancelledReason }}{% else %}.{% endif %}
                </div>
            {% else %}
                <div class="progress mb-4" style="height: 10px;">
                    <div class="progress-bar bg-success" role="progressbar" style="width: {{ order.statusProgressPercent }}%;"></div>
                </div>
                <div class="row row-cols-1 row-cols-md-5 g-3">
                    {% for step in timeline %}
                        {% set completed = loop.index <= order.statusStepNumber %}
                        <div class="col">
                            <div class="rounded-4 border h-100 p-3 text-center {{ completed ? 'border-success bg-success-subtle' : 'border-light bg-light' }}">
                                <div class="fw-semibold small {{ completed ? 'text-success' : 'text-muted' }}">{{ step == 'preparing' ? 'Preparing' : step|capitalize }}</div>
                            </div>
                        </div>
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="card border-0 shadow-sm rounded-4 p-4 mb-4">
            <h6 class="fw-bold mb-3">Product</h6>
            <div class="d-flex gap-3 align-items-center">
                {% if order.product.imageUrl %}
                    <img src="{{ order.product.imageExternal ? order.product.imageUrl : asset(order.product.imageUrl) }}" class="rounded-3" style="width:70px;height:70px;object-fit:cover">
                {% else %}
                    <div class="rounded-3 bg-light d-flex align-items-center justify-content-center" style="width:70px;height:70px;font-size:2rem;color:#198754"><i class="bi bi-bag-heart"></i></div>
                {% endif %}
                <div>
                    <div class="fw-semibold fs-6">{{ order.product.name }}</div>
                    <div class="text-muted small">Sold by {{ order.seller.name }}</div>
                    <div class="mt-1">
                        <span class="fw-bold text-success">{{ order.unitPrice }} TND</span>
                        <span class="text-muted"> x {{ order.quantity }} = </span>
                        <span class="fw-bold text-success">{{ order.totalPrice }} TND</span>
                        {% if convertedUnitPrice is not empty or convertedTotalPrice is not empty %}
                        <div class="text-muted small mt-1">
                            {% if convertedUnitPrice.EUR is defined %}<span class="me-3">Unit: € {{ convertedUnitPrice.EUR|number_format(2) }}</span>{% endif %}
                            {% if convertedUnitPrice.USD is defined %}<span class="me-3">Unit: $ {{ convertedUnitPrice.USD|number_format(2) }}</span>{% endif %}
                            {% if convertedTotalPrice.EUR is defined %}<span class="me-3">Total: € {{ convertedTotalPrice.EUR|number_format(2) }}</span>{% endif %}
                            {% if convertedTotalPrice.USD is defined %}<span>Total: $ {{ convertedTotalPrice.USD|number_format(2) }}</span>{% endif %}
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 p-4">
            <h6 class="fw-bold mb-3">Shipping Details</h6>
            {% if shippingDetails %}
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Name</dt>
                    <dd class="col-sm-8">{{ shippingDetails.name ?: '-' }}</dd>
                    <dt class="col-sm-4 text-muted">Address</dt>
                    <dd class="col-sm-8">{{ shippingDetails.formatted ?: '-' }}</dd>
                    <dt class="col-sm-4 text-muted">Email</dt>
                    <dd class="col-sm-8">{{ shippingDetails.email ?: '-' }}</dd>
                    <dt class="col-sm-4 text-muted">Phone</dt>
                    <dd class="col-sm-8">{{ shippingDetails.phone ?: '-' }}</dd>
                    {% if shippingDetails.notes %}
                    <dt class="col-sm-4 text-muted">Notes</dt>
                    <dd class="col-sm-8">{{ shippingDetails.notes }}</dd>
                    {% endif %}
                </dl>
            {% elseif order.paymentMethod == 'stripe' %}
                <div class="text-muted small">
                    Shipping details are managed by Stripe Checkout and are not stored in AgriCloud. They will appear here after Stripe completes the session and returns them.
                </div>
            {% elseif order.paymentMethod == 'cash' %}
                <div class="text-muted small">
                    Cash delivery details are stored temporarily and may have expired or already been cleared after processing.
                </div>
            {% else %}
                <div class="text-muted small">
                    This order does not store shipping details in AgriCloud.
                </div>
            {% endif %}
        </div>
    </div>

    <div class="col-md-5">
        <div class="card border-0 shadow-sm rounded-4 p-4 mb-3">
            <h6 class="fw-bold mb-3">Order Info</h6>
            <dl class="row mb-0">
                <dt class="col-sm-5 text-muted">Customer</dt>
                <dd class="col-sm-7">{{ order.customer.name }}</dd>
                <dt class="col-sm-5 text-muted">Order Date</dt>
                <dd class="col-sm-7 small">{{ order.orderDate ? order.orderDate|date('d M Y H:i') : '-' }}</dd>
                <dt class="col-sm-5 text-muted">Payment Method</dt>
                <dd class="col-sm-7">
                    {{ order.paymentMethodLabel }}
                    {% if order.paymentMethod == 'stripe' %}
                        <div class="small text-muted">Charged in EUR from the TND order total at checkout time.</div>
                    {% endif %}
                </dd>
                <dt class="col-sm-5 text-muted">Payment Status</dt>
                <dd class="col-sm-7">
                    <span class="badge bg-{{ order.paymentStatusColor }} {{ order.paymentStatus == 'pending' ? 'text-dark' : '' }}">{{ order.paymentStatusLabel }}</span>
                </dd>
                {% if order.cancelledAt %}
                <dt class="col-sm-5 text-muted">Cancelled</dt>
                <dd class="col-sm-7 small text-danger">{{ order.cancelledAt|date('d M Y') }}{% if order.cancelledReason %} - {{ order.cancelledReason }}{% endif %}</dd>
                {% endif %}
            </dl>
        </div>

        {% if order.customer == app.user and order.paymentMethod == 'stripe' and order.paymentStatus != 'paid' and order.status != 'cancelled' %}
        <form method="post" action="{{ path('order_pay', {id: order.id}) }}" class="mb-3">
            <input type="hidden" name="_token" value="{{ csrf_token('order_pay_' ~ order.id) }}">
            <button class="btn btn-primary btn-sm w-100">
                <i class="bi bi-credit-card-2-front me-1"></i>Pay with Stripe
            </button>
        </form>
        {% endif %}

        {% if order.seller == app.user or is_granted('ROLE_ADMIN') %}
        <div class="card border-0 shadow-sm rounded-4 p-4 mb-3">
            <h6 class="fw-bold mb-3">Update Status</h6>
            <form method="post" action="{{ path('order_status', {id: order.id}) }}">
                <input type="hidden" name="_token" value="{{ csrf_token('order_status_' ~ order.id) }}">
                <select name="status" class="form-select mb-2">
                    {% for s in availableStatuses %}
                        <option value="{{ s }}" {{ order.status == s ? 'selected' : '' }}>{{ s == 'preparing' ? 'Preparing' : s|capitalize }}</option>
                    {% endfor %}
                </select>
                <textarea name="reason" class="form-control mb-2" rows="2" placeholder="Cancellation reason (if cancelling)..."></textarea>
                <button class="btn btn-success btn-sm w-100">Update Status</button>
            </form>
        </div>
        {% endif %}

        {% if order.customer == app.user and order.status in ['pending','confirmed'] %}
        <form method="post" action="{{ path('order_cancel', {id: order.id}) }}"
              onsubmit="return confirm('Cancel this order?')">
            <input type="hidden" name="_token" value="{{ csrf_token('order_cancel_' ~ order.id) }}">
            <button class="btn btn-outline-danger btn-sm w-100"><i class="bi bi-x-circle me-1"></i>Cancel Order</button>
        </form>
        {% endif %}
    </div>
</div>
{% endblock %}

{% if pageCount > 1 %}
<nav aria-label="Page navigation">
    <ul class="pagination pagination-sm mb-0">

        {# Previous #}
        {% if previous is defined %}
            <li class="page-item">
                <a class="page-link" href="{{ path(route, knp_pagination_query(query, previous, options)) }}" aria-label="Previous">
                    <i class="bi bi-chevron-left"></i>
                </a>
            </li>
        {% else %}
            <li class="page-item disabled">
                <span class="page-link"><i class="bi bi-chevron-left"></i></span>
            </li>
        {% endif %}

        {# First page + ellipsis #}
        {% if startPage > 1 %}
            <li class="page-item">
                <a class="page-link" href="{{ path(route, knp_pagination_query(query, 1, options)) }}">1</a>
            </li>
            {% if startPage == 3 %}
                <li class="page-item">
                    <a class="page-link" href="{{ path(route, knp_pagination_query(query, 2, options)) }}">2</a>
                </li>
            {% elseif startPage != 2 %}
                <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
            {% endif %}
        {% endif %}

        {# Page numbers #}
        {% for page in pagesInRange %}
            {% if page != current %}
                <li class="page-item">
                    <a class="page-link" href="{{ path(route, knp_pagination_query(query, page, options)) }}">{{ page }}</a>
                </li>
            {% else %}
                <li class="page-item active">
                    <span class="page-link">{{ page }}</span>
                </li>
            {% endif %}
        {% endfor %}

        {# Last page + ellipsis #}
        {% if pageCount > endPage %}
            {% if pageCount > (endPage + 2) %}
                <li class="page-item disabled"><span class="page-link">&hellip;</span></li>
            {% elseif pageCount > (endPage + 1) %}
                <li class="page-item">
                    <a class="page-link" href="{{ path(route, knp_pagination_query(query, pageCount - 1, options)) }}">{{ pageCount - 1 }}</a>
                </li>
            {% endif %}
            <li class="page-item">
                <a class="page-link" href="{{ path(route, knp_pagination_query(query, pageCount, options)) }}">{{ pageCount }}</a>
            </li>
        {% endif %}

        {# Next #}
        {% if next is defined %}
            <li class="page-item">
                <a class="page-link" href="{{ path(route, knp_pagination_query(query, next, options)) }}" aria-label="Next">
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        {% else %}
            <li class="page-item disabled">
                <span class="page-link"><i class="bi bi-chevron-right"></i></span>
            </li>
        {% endif %}

    </ul>
</nav>
{% endif %}

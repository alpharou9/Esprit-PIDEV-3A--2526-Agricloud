{% if pageCount > 1 %}
<nav aria-label="Pagination navigation" class="knp-pagination-nav">
    <ul class="pagination justify-content-center flex-wrap gap-2 mb-0">
        {% if previous is defined %}
            <li class="page-item">
                <a class="page-link page-link-nav" href="{{ path(route, knp_pagination_query(query, previous, options)) }}" rel="prev" aria-label="Previous page">
                    <i class="bi bi-chevron-left"></i>
                    <span>Previous</span>
                </a>
            </li>
        {% else %}
            <li class="page-item disabled">
                <span class="page-link page-link-nav" aria-disabled="true">
                    <i class="bi bi-chevron-left"></i>
                    <span>Previous</span>
                </span>
            </li>
        {% endif %}

        {% if startPage > 1 %}
            <li class="page-item">
                <a class="page-link" href="{{ path(route, knp_pagination_query(query, 1, options)) }}">1</a>
            </li>
            {% if startPage == 3 %}
                <li class="page-item">
                    <a class="page-link" href="{{ path(route, knp_pagination_query(query, 2, options)) }}">2</a>
                </li>
            {% elseif startPage != 2 %}
                <li class="page-item disabled">
                    <span class="page-link page-link-dots">&hellip;</span>
                </li>
            {% endif %}
        {% endif %}

        {% for page in pagesInRange %}
            {% if page != current %}
                <li class="page-item">
                    <a class="page-link" href="{{ path(route, knp_pagination_query(query, page, options)) }}">{{ page }}</a>
                </li>
            {% else %}
                <li class="page-item active" aria-current="page">
                    <span class="page-link">{{ page }}</span>
                </li>
            {% endif %}
        {% endfor %}

        {% if pageCount > endPage %}
            {% if pageCount > (endPage + 2) %}
                <li class="page-item disabled">
                    <span class="page-link page-link-dots">&hellip;</span>
                </li>
            {% elseif pageCount > (endPage + 1) %}
                <li class="page-item">
                    <a class="page-link" href="{{ path(route, knp_pagination_query(query, pageCount - 1, options)) }}">{{ pageCount - 1 }}</a>
                </li>
            {% endif %}
            <li class="page-item">
                <a class="page-link" href="{{ path(route, knp_pagination_query(query, pageCount, options)) }}">{{ pageCount }}</a>
            </li>
        {% endif %}

        {% if next is defined %}
            <li class="page-item">
                <a class="page-link page-link-nav" href="{{ path(route, knp_pagination_query(query, next, options)) }}" rel="next" aria-label="Next page">
                    <span>Next</span>
                    <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        {% else %}
            <li class="page-item disabled">
                <span class="page-link page-link-nav" aria-disabled="true">
                    <span>Next</span>
                    <i class="bi bi-chevron-right"></i>
                </span>
            </li>
        {% endif %}
    </ul>
</nav>
{% endif %}

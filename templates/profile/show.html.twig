{% extends 'base_front.html.twig' %}

{% block title %}My Profile — AgriCloud{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="fw-bold mb-0"><i class="bi bi-person-circle me-2"></i>My Profile</h5>
            <a href="{{ path('profile_edit') }}" class="btn btn-success btn-sm">
                <i class="bi bi-pencil me-1"></i> Edit Profile
            </a>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                <dl class="row mb-0">
                    <dt class="col-sm-4 text-muted">Full Name</dt>
                    <dd class="col-sm-8 fw-semibold">{{ user.name }}</dd>

                    <dt class="col-sm-4 text-muted">Email</dt>
                    <dd class="col-sm-8">{{ user.email }}</dd>

                    <dt class="col-sm-4 text-muted">Phone</dt>
                    <dd class="col-sm-8">{{ user.phone ?? '—' }}</dd>

                    <dt class="col-sm-4 text-muted">Role</dt>
                    <dd class="col-sm-8">
                        {% if user.role %}
                            <span class="badge bg-secondary">{{ user.role.name }}</span>
                        {% else %}
                            <span class="text-muted">—</span>
                        {% endif %}
                    </dd>

                    <dt class="col-sm-4 text-muted">Status</dt>
                    <dd class="col-sm-8">
                        {% if user.status == 'active' %}
                            <span class="badge bg-success">Active</span>
                        {% elseif user.status == 'blocked' %}
                            <span class="badge bg-danger">Blocked</span>
                        {% else %}
                            <span class="badge bg-secondary">Inactive</span>
                        {% endif %}
                    </dd>

                    <dt class="col-sm-4 text-muted">Member since</dt>
                    <dd class="col-sm-8 text-muted small">
                        {{ user.createdAt ? user.createdAt|date('d M Y') : '—' }}
                    </dd>
                </dl>
            </div>
        </div>
    </div>
</div>
{% endblock %}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>AgriCloud — Profile Card — {{ user.name }}</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background: #f0f4e8;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            padding: 24px;
        }

        .no-print {
            position: fixed;
            top: 20px;
            right: 20px;
            display: flex;
            gap: 10px;
            z-index: 100;
        }
        .btn-print {
            background: #77b81e;
            color: #fff;
            border: none;
            border-radius: 10px;
            padding: 10px 22px;
            font-size: .95rem;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }
        .btn-back {
            background: #fff;
            color: #555;
            border: 1.5px solid #dde8cc;
            border-radius: 10px;
            padding: 10px 22px;
            font-size: .95rem;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 8px;
            text-decoration: none;
        }

        /* ── Card ── */
        .card {
            background: #fff;
            border-radius: 20px;
            width: 680px;
            max-width: 100%;
            box-shadow: 0 8px 40px rgba(0,0,0,.12);
            overflow: hidden;
        }

        .card-header {
            background: linear-gradient(135deg, #1a2e0a 0%, #3a6010 100%);
            padding: 36px 40px 28px;
            position: relative;
        }
        .card-header::after {
            content: '';
            position: absolute;
            bottom: -1px;
            left: 0;
            right: 0;
            height: 24px;
            background: #fff;
            border-radius: 24px 24px 0 0;
        }
        .brand {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 24px;
        }
        .brand-icon {
            width: 32px;
            height: 32px;
            background: #77b81e;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-weight: 700;
            font-size: .9rem;
        }
        .brand span {
            color: #fff;
            font-weight: 700;
            font-size: 1.1rem;
            letter-spacing: .5px;
        }
        .header-main {
            display: flex;
            align-items: center;
            gap: 20px;
        }
        .avatar {
            width: 80px;
            height: 80px;
            border-radius: 50%;
            background: #77b81e;
            border: 3px solid rgba(255,255,255,.3);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            font-weight: 700;
            color: #fff;
            flex-shrink: 0;
            overflow: hidden;
        }
        .avatar img { width: 100%; height: 100%; object-fit: cover; }
        .header-info h1 {
            color: #fff;
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 4px;
        }
        .header-info p {
            color: rgba(255,255,255,.7);
            font-size: .9rem;
        }
        .role-badge {
            display: inline-block;
            margin-top: 8px;
            background: rgba(119,184,30,.3);
            color: #a3d43a;
            border: 1px solid rgba(163,212,58,.4);
            border-radius: 20px;
            padding: 3px 14px;
            font-size: .78rem;
            font-weight: 600;
        }

        /* ── Body ── */
        .card-body {
            padding: 28px 40px 32px;
        }

        .section-title {
            font-size: .7rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: #77b81e;
            font-weight: 700;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .section-title::after {
            content: '';
            flex: 1;
            height: 1px;
            background: #e8f0d8;
        }

        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-bottom: 28px;
        }
        .info-item {
            background: #f8faf4;
            border-radius: 12px;
            padding: 14px 16px;
            border: 1px solid #edf3e0;
        }
        .info-item .label {
            font-size: .72rem;
            color: #aaa;
            text-transform: uppercase;
            letter-spacing: .8px;
            font-weight: 600;
            margin-bottom: 4px;
        }
        .info-item .value {
            font-size: .95rem;
            font-weight: 600;
            color: #222;
        }

        /* ── QR section ── */
        .qr-section {
            display: flex;
            align-items: center;
            gap: 24px;
            background: #f8faf4;
            border-radius: 14px;
            padding: 20px 24px;
            border: 1px solid #edf3e0;
            margin-bottom: 24px;
        }
        .qr-section img {
            width: 100px;
            height: 100px;
            border-radius: 8px;
            border: 2px solid #dde8cc;
        }
        .qr-info h4 {
            font-size: .9rem;
            font-weight: 700;
            color: #1a2e0a;
            margin-bottom: 4px;
        }
        .qr-info p {
            font-size: .78rem;
            color: #888;
            line-height: 1.5;
        }

        /* ── Footer ── */
        .card-footer {
            background: #f8faf4;
            border-top: 1px solid #edf3e0;
            padding: 16px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        .card-footer span {
            font-size: .75rem;
            color: #bbb;
        }
        .card-footer strong {
            color: #77b81e;
        }

        /* ── Status badges ── */
        .status-active { color: #22c55e; font-weight: 700; }
        .status-blocked { color: #ef4444; font-weight: 700; }

        /* ── Print media ── */
        @media print {
            * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; }
            body { background: #fff; padding: 0; }
            .no-print { display: none !important; }
            .card {
                box-shadow: none;
                border-radius: 0;
                width: 100%;
                max-width: 100%;
            }
        }
    </style>
</head>
<body>

<div class="no-print">
    <a href="{{ path('profile_show') }}" class="btn-back">← Back</a>
    <button onclick="window.print()" class="btn-print">⬇ Save as PDF</button>
</div>

<div class="card">

    {# ── Header ── #}
    <div class="card-header">
        <div class="brand">
            <div class="brand-icon">A</div>
            <span>AgriCloud</span>
        </div>
        <div class="header-main">
            <div class="avatar">
                {% if user.profilePicture %}
                    <img src="{{ absolute_url(asset('uploads/avatars/' ~ user.profilePicture)) }}" alt="{{ user.name }}">
                {% else %}
                    {{ user.name|slice(0,1)|upper }}
                {% endif %}
            </div>
            <div class="header-info">
                <h1>{{ user.name }}</h1>
                <p>{{ user.email }}</p>
                {% if user.role %}
                    <span class="role-badge">{{ user.role.name }}</span>
                {% endif %}
            </div>
        </div>
    </div>

    {# ── Body ── #}
    <div class="card-body">

        <div class="section-title">Personal Information</div>
        <div class="info-grid">
            <div class="info-item">
                <div class="label">Full Name</div>
                <div class="value">{{ user.name }}</div>
            </div>
            <div class="info-item">
                <div class="label">Email Address</div>
                <div class="value">{{ user.email }}</div>
            </div>
            <div class="info-item">
                <div class="label">Phone</div>
                <div class="value">{{ user.phone ?? '—' }}</div>
            </div>
            <div class="info-item">
                <div class="label">Account Status</div>
                <div class="value {% if user.status == 'active' %}status-active{% else %}status-blocked{% endif %}">
                    {{ user.status|capitalize }}
                </div>
            </div>
            <div class="info-item">
                <div class="label">Role</div>
                <div class="value">{{ user.role ? user.role.name : 'No role' }}</div>
            </div>
            <div class="info-item">
                <div class="label">Member Since</div>
                <div class="value">{{ user.createdAt ? user.createdAt|date('d M Y') : '—' }}</div>
            </div>
            {% if user.faceEnrolledAt %}
            <div class="info-item">
                <div class="label">Face Login</div>
                <div class="value status-active">Enrolled {{ user.faceEnrolledAt|date('d M Y') }}</div>
            </div>
            {% endif %}
            {% if user.oauthProvider %}
            <div class="info-item">
                <div class="label">Login Method</div>
                <div class="value">{{ user.oauthProvider|capitalize }} OAuth</div>
            </div>
            {% endif %}
        </div>

        <div class="section-title">Profile QR Code</div>
        <div class="qr-section">
            <img src="https://api.qrserver.com/v1/create-qr-code/?size=100x100&data={{ profileUrl|url_encode }}&color=1a2e0a&bgcolor=f8faf4"
                 alt="Profile QR Code">
            <div class="qr-info">
                <h4>Scan to visit profile</h4>
                <p>This QR code links directly to this AgriCloud account profile.<br>
                Valid for user <strong>{{ user.name }}</strong>.</p>
                <p style="margin-top:6px;font-size:.72rem;color:#aaa">{{ profileUrl }}</p>
            </div>
        </div>

    </div>

    {# ── Footer ── #}
    <div class="card-footer">
        <span>Generated on {{ exportedAt|date('d F Y, H:i') }}</span>
        <span><strong>AgriCloud</strong> — Agricultural Platform</span>
    </div>

</div>

<script>
// Auto-print after a short delay if ?autoprint=1 is in the URL
if (new URLSearchParams(window.location.search).get('autoprint') === '1') {
    setTimeout(() => window.print(), 500);
}
</script>

</body>
</html>

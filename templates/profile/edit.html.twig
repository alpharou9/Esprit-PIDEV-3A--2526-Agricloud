{% extends 'base.html.twig' %}

{% block title %}Edit Profile - AgriCloud{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="d-flex align-items-center mb-3 gap-2">
            <a href="{{ path('profile_show') }}" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h5 class="fw-bold mb-0">Edit My Profile</h5>
        </div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">
                {{ form_start(form) }}

                <div class="mb-3">
                    {{ form_label(form.name) }}
                    {{ form_widget(form.name) }}
                    {{ form_errors(form.name) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.email) }}
                    {{ form_widget(form.email) }}
                    {{ form_errors(form.email) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.phone) }}
                    {{ form_widget(form.phone) }}
                    {{ form_errors(form.phone) }}
                </div>

                <div class="mb-4">
                    {{ form_label(form.plainPassword) }}
                    {{ form_widget(form.plainPassword) }}
                    {{ form_errors(form.plainPassword) }}
                    <div class="form-text">Leave blank to keep your current password.</div>
                </div>

                <button type="submit" class="btn btn-success">
                    <i class="bi bi-check-lg me-1"></i> Save Changes
                </button>
                <a href="{{ path('profile_show') }}" class="btn btn-outline-secondary ms-2">Cancel</a>

                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}AgriCloud{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        :root {
            --agri-green: #2f7d32;
            --agri-green-dark: #1f5c24;
            --agri-cream: #f7f3e8;
            --agri-ink: #233127;
        }
        body {
            background:
                radial-gradient(circle at top right, rgba(168, 213, 186, 0.28), transparent 28%),
                linear-gradient(180deg, #f9fbf7 0%, var(--agri-cream) 100%);
            color: var(--agri-ink);
        }
        .sidebar {
            min-height: calc(100vh - 72px);
            background: rgba(255, 255, 255, 0.86);
            border-right: 1px solid rgba(47, 125, 50, 0.14);
            backdrop-filter: blur(14px);
        }
        .sidebar a {
            color: #47604d;
            text-decoration: none;
            padding: 10px 12px;
            border-radius: 12px;
            display: block;
            transition: all .2s ease;
        }
        .sidebar a:hover, .sidebar a.active {
            background: linear-gradient(135deg, var(--agri-green) 0%, #5ba05f 100%);
            color: #fff;
            box-shadow: 0 10px 24px rgba(47, 125, 50, 0.18);
        }
        .sidebar .nav-section {
            font-size: .72rem;
            font-weight: 700;
            letter-spacing: .08em;
            text-transform: uppercase;
            color: #809080;
            padding: 10px 12px 6px;
        }
        .topbar {
            height: 72px;
            background: linear-gradient(135deg, var(--agri-green-dark) 0%, var(--agri-green) 55%, #77b255 100%);
            box-shadow: 0 18px 40px rgba(31, 92, 36, 0.2);
        }
        .brand-pill {
            padding: .55rem .9rem;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.12);
            border: 1px solid rgba(255, 255, 255, 0.16);
        }
        .content-shell {
            background: rgba(255, 255, 255, 0.72);
            border: 1px solid rgba(47, 125, 50, 0.08);
            border-radius: 24px;
            box-shadow: 0 16px 36px rgba(35, 49, 39, 0.08);
            padding: 1.5rem;
        }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>

<nav class="navbar navbar-dark topbar px-3 px-lg-4">
    <a class="navbar-brand fw-bold d-flex align-items-center gap-2" href="{{ path('dashboard') }}">
        <span class="brand-pill">
            <i class="bi bi-tree-fill me-1"></i> AgriCloud
        </span>
    </a>
    <div class="d-flex align-items-center gap-3">
        <span class="text-white small">{{ app.user.name ?? 'Guest' }}</span>
        <a href="{{ path('app_logout') }}" class="btn btn-outline-light btn-sm">
            <i class="bi bi-box-arrow-right me-1"></i>Logout
        </a>
    </div>
</nav>

<div class="container-fluid py-4">
    <div class="row">
        <nav class="col-lg-2 sidebar py-3 rounded-4">
            <a href="{{ path('dashboard') }}" class="{{ app.request.attributes.get('_route') == 'dashboard' ? 'active' : '' }}">
                <i class="bi bi-speedometer2 me-1"></i> Dashboard
            </a>

            <div class="nav-section mt-3">Commerce</div>
            <a href="{{ path('product_index') }}" class="{{ app.request.attributes.get('_route') starts with 'product_' ? 'active' : '' }}">
                <i class="bi bi-basket me-1"></i> Products
            </a>
            <a href="{{ path('order_index') }}" class="{{ app.request.attributes.get('_route') starts with 'order_' ? 'active' : '' }}">
                <i class="bi bi-receipt me-1"></i> Orders
            </a>

            {% if is_granted('ROLE_ADMIN') %}
                <div class="nav-section mt-3">Administration</div>
                <a href="{{ path('user_index') }}" class="{{ app.request.attributes.get('_route') starts with 'user_' ? 'active' : '' }}">
                    <i class="bi bi-people me-1"></i> Users
                </a>
                <a href="{{ path('role_index') }}" class="{{ app.request.attributes.get('_route') starts with 'role_' ? 'active' : '' }}">
                    <i class="bi bi-shield-check me-1"></i> Roles
                </a>
            {% endif %}
        </nav>

        <main class="col-lg-10 py-0 ps-lg-4">
            <div class="content-shell">
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle me-1"></i> {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}
                {% for message in app.flashes('error') %}
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle me-1"></i> {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}

                {% block body %}{% endblock %}
            </div>
        </main>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}AgriCloud{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Philosopher:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        :root {
            --agri-green: #77b81e;
            --agri-green-dark: #5a9014;
            --agri-green-light: #f0f7e0;
            --agri-sidebar-bg: #1a2e0a;
            --agri-sidebar-width: 240px;
        }

        * { box-sizing: border-box; }
        body { font-family: 'Philosopher', sans-serif; margin: 0; padding: 0; background: #f4f6f0; }

        /* ── Top Navbar ── */
        .agri-topbar {
            position: fixed; top: 0; left: 0; width: 100%; z-index: 1050;
            height: 60px;
            background: var(--agri-green);
            display: flex; align-items: center; justify-content: space-between;
            padding: 0 24px 0 calc(var(--agri-sidebar-width) + 24px);
            box-shadow: 0 2px 16px rgba(0,0,0,.2);
        }
        .agri-topbar .topbar-title {
            font-size: 1rem; color: rgba(255,255,255,.9); font-weight: 700;
        }
        .agri-topbar .topbar-actions { display: flex; align-items: center; gap: 12px; }
        .topbar-user { color: rgba(255,255,255,.9); text-decoration: none; font-size: .9rem; display: flex; align-items: center; gap: 6px; }
        .topbar-user:hover { color: #fff; }
        .topbar-logout {
            border: 1.5px solid rgba(255,255,255,.7); border-radius: 8px;
            padding: 5px 16px; color: #fff; text-decoration: none; font-size: .85rem;
            display: flex; align-items: center; gap: 5px; transition: all .2s;
        }
        .topbar-logout:hover { background: rgba(255,255,255,.15); color: #fff; }

        /* ── Notification bell ── */
        .notif-btn {
            position: relative; background: none; border: none; cursor: pointer;
            color: rgba(255,255,255,.9); font-size: 1.3rem; padding: 4px 6px;
            display: flex; align-items: center;
        }
        .notif-btn:hover { color: #fff; }
        .notif-badge {
            position: absolute; top: -2px; right: -2px;
            background: #ef4444; color: #fff;
            font-size: .6rem; font-weight: 700;
            min-width: 16px; height: 16px; border-radius: 8px;
            display: flex; align-items: center; justify-content: center;
            padding: 0 3px; display: none;
        }
        .notif-dropdown {
            position: absolute; top: 54px; right: 16px;
            width: 320px; background: #fff;
            border-radius: 14px; box-shadow: 0 8px 32px rgba(0,0,0,.18);
            z-index: 2000; display: none; overflow: hidden;
        }
        .notif-dropdown.open { display: block; }
        .notif-header {
            display: flex; align-items: center; justify-content: space-between;
            padding: 14px 16px 10px;
            border-bottom: 1px solid #f0f0f0;
            font-weight: 700; color: #1a2e0a; font-size: .9rem;
        }
        .notif-mark-all {
            font-size: .75rem; color: #77b81e; cursor: pointer;
            background: none; border: none; font-weight: 600;
        }
        .notif-list { max-height: 320px; overflow-y: auto; }
        .notif-item {
            display: flex; align-items: flex-start; gap: 10px;
            padding: 12px 16px; border-bottom: 1px solid #f8f8f8;
            cursor: pointer; text-decoration: none; color: inherit;
            transition: background .15s;
        }
        .notif-item:hover { background: #f8faf4; }
        .notif-item.unread { background: #f0f7e0; }
        .notif-icon {
            width: 34px; height: 34px; border-radius: 50%; flex-shrink: 0;
            display: flex; align-items: center; justify-content: center;
            font-size: .9rem;
        }
        .notif-icon.approved { background: #dcfce7; color: #16a34a; }
        .notif-icon.rejected { background: #fee2e2; color: #dc2626; }
        .notif-icon.default  { background: #f0f7e0; color: #77b81e; }
        .notif-msg { font-size: .83rem; color: #333; line-height: 1.4; flex: 1; }
        .notif-time { font-size: .72rem; color: #aaa; margin-top: 2px; }
        .notif-empty { padding: 28px 16px; text-align: center; color: #aaa; font-size: .85rem; }

        /* ── Sidebar ── */
        .agri-sidebar {
            position: fixed; top: 0; left: 0;
            width: var(--agri-sidebar-width);
            height: 100vh;
            background: var(--agri-sidebar-bg);
            display: flex; flex-direction: column;
            z-index: 1060;
            overflow-y: auto;
            overflow-x: hidden;
        }
        .agri-sidebar::-webkit-scrollbar { width: 4px; }
        .agri-sidebar::-webkit-scrollbar-thumb { background: rgba(255,255,255,.1); border-radius: 4px; }

        .sidebar-brand {
            height: 60px; display: flex; align-items: center;
            padding: 0 20px;
            background: rgba(255,255,255,.05);
            border-bottom: 1px solid rgba(255,255,255,.07);
            text-decoration: none; flex-shrink: 0;
        }
        .sidebar-brand span { font-size: 1.35rem; font-weight: 700; color: #fff; }
        .sidebar-brand i { color: var(--agri-green); font-size: 1.4rem; margin-right: 8px; }

        .sidebar-nav { padding: 16px 12px; flex-grow: 1; }

        .sidebar-section {
            font-size: .65rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 1.5px;
            color: rgba(255,255,255,.35);
            padding: 18px 10px 6px;
        }

        .sidebar-link {
            display: flex; align-items: center; gap: 10px;
            padding: 9px 12px; border-radius: 10px;
            color: rgba(255,255,255,.65); text-decoration: none;
            font-size: .9rem; transition: all .18s;
            margin-bottom: 2px;
        }
        .sidebar-link i { font-size: 1rem; width: 20px; text-align: center; flex-shrink: 0; }
        .sidebar-link:hover { background: rgba(255,255,255,.08); color: #fff; }
        .sidebar-link.active { background: var(--agri-green); color: #fff; box-shadow: 0 4px 12px rgba(119,184,30,.35); }
        .sidebar-link.active i { color: #fff; }

        /* ── Main content ── */
        .agri-main {
            margin-left: var(--agri-sidebar-width);
            margin-top: 60px;
            padding: 32px 32px 48px;
            min-height: calc(100vh - 60px);
        }

        /* ── Flash messages ── */
        .flash-zone { margin-bottom: 24px; }
        .flash-zone .alert { border: none; border-radius: 12px; font-size: .9rem; }

        .knp-pagination-nav { width: 100%; }
        .knp-pagination-nav .pagination { align-items: center; }
        .knp-pagination-nav .page-link-nav {
            width: auto !important;
            min-width: 112px;
            padding-inline: 14px !important;
            gap: 8px;
        }
        .knp-pagination-nav .page-link-dots {
            width: auto !important;
            min-width: 34px;
            padding-inline: 10px !important;
        }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>

{# ── Sidebar ── #}
<aside class="agri-sidebar">
    <a href="{{ path('home') }}" class="sidebar-brand">
        <i class="bi bi-tree-fill"></i>
        <span>AgriCloud</span>
    </a>
    <nav class="sidebar-nav">
        <a href="{{ path('home') }}" class="sidebar-link">
            <i class="bi bi-house-door"></i> Home
        </a>
        <a href="{{ path('dashboard') }}" class="sidebar-link {{ app.request.attributes.get('_route') == 'dashboard' ? 'active' : '' }}">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>

        <div class="sidebar-section">Farming</div>
        <a href="{{ path('farm_index') }}" class="sidebar-link {{ app.request.attributes.get('_route') starts with 'farm_' or app.request.attributes.get('_route') starts with 'field_' ? 'active' : '' }}">
            <i class="bi bi-house-heart"></i> Farms
        </a>

        <div class="sidebar-section">Events</div>
        <a href="{{ path('event_index') }}" class="sidebar-link {{ app.request.attributes.get('_route') starts with 'event_' ? 'active' : '' }}">
            <i class="bi bi-calendar-event"></i> Events
        </a>

        <div class="sidebar-section">Blog</div>
        <a href="{{ path('blog_index') }}" class="sidebar-link {{ app.request.attributes.get('_route') starts with 'blog_' ? 'active' : '' }}">
            <i class="bi bi-journal-richtext"></i> Blog
        </a>

        <div class="sidebar-section">Market</div>
        <a href="{{ path('market_index') }}" class="sidebar-link {{ app.request.attributes.get('_route') in ['market_index','product_show'] ? 'active' : '' }}">
            <i class="bi bi-shop"></i> Marketplace
        </a>
        {% if is_granted('ROLE_FARMER') or is_granted('ROLE_ADMIN') %}
        <a href="{{ path('my_products') }}" class="sidebar-link {{ app.request.attributes.get('_route') in ['my_products','product_new','product_edit'] ? 'active' : '' }}">
            <i class="bi bi-box-seam"></i> My Products
        </a>
        {% endif %}
        <a href="{{ path('cart_index') }}" class="sidebar-link {{ app.request.attributes.get('_route') starts with 'cart_' ? 'active' : '' }}">
            <i class="bi bi-cart"></i> Cart
        </a>
        <a href="{{ path('order_index') }}" class="sidebar-link {{ app.request.attributes.get('_route') starts with 'order_' ? 'active' : '' }}">
            <i class="bi bi-receipt"></i> Orders
        </a>
        {% if is_granted('ROLE_ADMIN') %}
        <div class="sidebar-section">Administration</div>
        <a href="{{ path('user_index') }}" class="sidebar-link {{ app.request.attributes.get('_route') starts with 'user_' ? 'active' : '' }}">
            <i class="bi bi-people"></i> Users
        </a>
        <a href="{{ path('role_index') }}" class="sidebar-link {{ app.request.attributes.get('_route') starts with 'role_' ? 'active' : '' }}">
            <i class="bi bi-shield-check"></i> Roles
        </a>
        <a href="{{ path('blog_admin_comments') }}" class="sidebar-link {{ app.request.attributes.get('_route') == 'blog_admin_comments' ? 'active' : '' }}">
            <i class="bi bi-chat-dots"></i> Comments
        </a>
        {% endif %}
    </nav>
</aside>

{# ── Top bar ── #}
<header class="agri-topbar">
    <span class="topbar-title">{% block page_title %}{% endblock %}</span>
    <div class="topbar-actions">
        {% if app.user %}
        <button class="notif-btn" id="notifBtn" title="Notifications">
            <i class="bi bi-bell-fill"></i>
            <span class="notif-badge" id="notifBadge"></span>
        </button>
        {% endif %}
        <a href="{{ path('profile_show') }}" class="topbar-user">
            <i class="bi bi-person-circle fs-5"></i>
            {{ app.user.name ?? 'Guest' }}
        </a>
        <a href="{{ path('app_logout') }}" class="topbar-logout">
            <i class="bi bi-box-arrow-right"></i> Logout
        </a>
    </div>
</header>

{% if app.user %}
<div class="notif-dropdown" id="notifDropdown">
    <div class="notif-header">
        <span><i class="bi bi-bell me-1"></i> Notifications</span>
        <button class="notif-mark-all" id="notifMarkAll">Mark all read</button>
    </div>
    <div class="notif-list" id="notifList">
        <div class="notif-empty">Loading…</div>
    </div>
</div>
{% endif %}

{# ── Main ── #}
<main class="agri-main">
    <div class="flash-zone">
        {% for message in app.flashes('success') %}
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>{{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>{{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    </div>

    {% block body %}{% endblock %}
</main>

{% include 'chatbot/_market_widget.html.twig' %}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}

{% if app.user %}
<script>
(function () {
    const btn      = document.getElementById('notifBtn');
    const dropdown = document.getElementById('notifDropdown');
    const badge    = document.getElementById('notifBadge');
    const list     = document.getElementById('notifList');
    const markAll  = document.getElementById('notifMarkAll');

    if (!btn) return;

    function iconClass(type) {
        if (type === 'farm_approved') return 'approved';
        if (type === 'farm_rejected') return 'rejected';
        return 'default';
    }
    function iconGlyph(type) {
        if (type === 'farm_approved') return 'bi-check-circle-fill';
        if (type === 'farm_rejected') return 'bi-x-circle-fill';
        return 'bi-bell-fill';
    }

    function loadNotifications() {
        fetch('{{ path('notifications_unread') }}')
            .then(r => r.json())
            .then(data => {
                badge.textContent = data.count > 9 ? '9+' : data.count;
                badge.style.display = data.count > 0 ? 'flex' : 'none';

                if (data.items.length === 0) {
                    list.innerHTML = '<div class="notif-empty"><i class="bi bi-bell-slash me-1"></i>No notifications yet</div>';
                    return;
                }

                list.innerHTML = data.items.map(n => `
                    <a class="notif-item ${n.isRead ? '' : 'unread'}" href="${n.link || '#'}"
                       data-id="${n.id}" data-read="${n.isRead}">
                        <div class="notif-icon ${iconClass(n.type)}">
                            <i class="bi ${iconGlyph(n.type)}"></i>
                        </div>
                        <div>
                            <div class="notif-msg">${n.message}</div>
                            <div class="notif-time">${n.createdAt}</div>
                        </div>
                    </a>
                `).join('');

                list.querySelectorAll('.notif-item').forEach(el => {
                    el.addEventListener('click', function (e) {
                        const id   = this.dataset.id;
                        const read = this.dataset.read === 'true';
                        if (!read) {
                            fetch(`/notifications/${id}/read`, { method: 'POST' });
                            this.classList.remove('unread');
                            this.dataset.read = 'true';
                            const cur = parseInt(badge.textContent) || 0;
                            const next = Math.max(0, cur - 1);
                            badge.textContent = next > 9 ? '9+' : next;
                            badge.style.display = next > 0 ? 'flex' : 'none';
                        }
                    });
                });
            })
            .catch(() => {});
    }

    btn.addEventListener('click', function (e) {
        e.stopPropagation();
        const open = dropdown.classList.toggle('open');
        if (open) loadNotifications();
    });

    document.addEventListener('click', function (e) {
        if (!dropdown.contains(e.target) && e.target !== btn) {
            dropdown.classList.remove('open');
        }
    });

    markAll.addEventListener('click', function () {
        fetch('{{ path('notifications_read_all') }}', { method: 'POST' })
            .then(() => {
                badge.style.display = 'none';
                list.querySelectorAll('.notif-item.unread').forEach(el => el.classList.remove('unread'));
            });
    });

    // Poll every 30 seconds
    loadNotifications();
    setInterval(loadNotifications, 30000);
})();
</script>
{% endif %}
</body>
</html>

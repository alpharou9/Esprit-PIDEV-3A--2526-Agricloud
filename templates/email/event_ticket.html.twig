<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Your Event Ticket — {{ event.title }}</title>
<style>
  body { margin:0; padding:0; background:#f4f6f0; font-family:'Helvetica Neue',Arial,sans-serif; }
  .wrapper { max-width:600px; margin:32px auto; background:#fff; border-radius:16px; overflow:hidden; box-shadow:0 4px 24px rgba(0,0,0,.08); }
  .header { background:linear-gradient(135deg,#1a3a08,#2d5c10); padding:32px 40px; text-align:center; }
  .header h1 { color:#fff; margin:0 0 4px; font-size:1.6rem; }
  .header p  { color:rgba(255,255,255,.75); margin:0; font-size:.9rem; }
  .ticket { margin:24px 32px; border:2px dashed #dde8cc; border-radius:14px; padding:24px; position:relative; }
  .ticket::before { content:'✓ CONFIRMED'; position:absolute; top:14px; right:16px; background:#e8f8ee; color:#166534; font-size:.7rem; font-weight:700; padding:3px 10px; border-radius:20px; letter-spacing:.5px; }
  .event-title { font-size:1.3rem; font-weight:700; color:#1a2e0a; margin-bottom:16px; }
  .info-row { display:flex; gap:10px; align-items:center; margin-bottom:10px; color:#555; font-size:.9rem; }
  .info-row i { width:20px; text-align:center; color:#77b81e; font-weight:700; }
  .divider { border:none; border-top:1px dashed #dde8cc; margin:20px 0; }
  .qr-section { text-align:center; padding:16px 0 8px; }
  .qr-section img { border-radius:8px; border:3px solid #dde8cc; }
  .qr-section p { color:#aaa; font-size:.78rem; margin-top:8px; }
  .ticket-id { text-align:center; font-size:.75rem; color:#bbb; font-family:monospace; margin-top:4px; }
  .footer { padding:20px 32px 28px; text-align:center; color:#aaa; font-size:.8rem; border-top:1px solid #f0f0f0; }
  .footer a { color:#77b81e; text-decoration:none; }
</style>
</head>
<body>
<div class="wrapper">

  <div class="header">
    <h1>🌿 AgriCloud</h1>
    <p>Your registration is confirmed!</p>
  </div>

  <div style="padding:24px 32px 8px">
    <p style="color:#555;font-size:.95rem">Hi <strong>{{ participation.user.name }}</strong>,</p>
    <p style="color:#555;font-size:.92rem">You're registered for the following event. Show the QR code at the entrance.</p>
  </div>

  <div class="ticket">
    <div class="event-title">{{ event.title }}</div>

    <div class="info-row">
      <i>📅</i>
      <span>{{ event.eventDate|date('l, d F Y') }}
        {% if event.endDate %} — {{ event.endDate|date('d F Y') }}{% endif %}
      </span>
    </div>

    {% if event.location %}
    <div class="info-row">
      <i>📍</i>
      <span>{{ event.location }}</span>
    </div>
    {% endif %}

    {% if event.category %}
    <div class="info-row">
      <i>🏷</i>
      <span>{{ event.category|capitalize }}</span>
    </div>
    {% endif %}

    <div class="info-row">
      <i>👤</i>
      <span>{{ participation.user.name }} — {{ participation.user.email }}</span>
    </div>

    <hr class="divider">

    <div class="qr-section">
      {% set qrData = 'AGRICLOUD-TICKET|' ~ participation.id ~ '|' ~ event.title ~ '|' ~ event.eventDate|date('Y-m-d') ~ '|' ~ participation.user.email %}
      <img src="https://api.qrserver.com/v1/create-qr-code/?size=160x160&data={{ qrData|url_encode }}" alt="Ticket QR Code" width="160" height="160">
      <p>Scan at the entrance</p>
      <div class="ticket-id">Ticket #{{ '%06d'|format(participation.id) }}</div>
    </div>
  </div>

  <div class="footer">
    <p>This ticket was generated by <a href="#">AgriCloud</a>. Please do not forward it to others.</p>
    <p style="margin-top:4px">© {{ "now"|date("Y") }} AgriCloud · All rights reserved</p>
  </div>

</div>
</body>
</html>

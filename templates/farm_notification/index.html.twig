{% extends 'base.html.twig' %}
{% block title %}Farm Notifications - AgriCloud{% endblock %}

{% block body %}
<div class="d-flex align-items-center gap-2 mb-4">
    <a href="{{ path('farm_index') }}" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h5 class="fw-bold mb-0">Farm Notifications</h5>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body p-4">
        {% if notifications is empty %}
            <div class="text-center text-muted py-5">
                <i class="bi bi-bell fs-1 d-block mb-3"></i>
                No farm review notifications yet.
            </div>
        {% else %}
            <div class="d-flex flex-column gap-3">
                {% for notification in notifications %}
                    <a href="{{ path('farm_notification_open', {id: notification.id}) }}"
                       class="text-decoration-none text-dark">
                        <div class="card border {{ notification.isRead ? 'border-light' : 'border-success-subtle' }} rounded-4">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start gap-3">
                                    <div>
                                        <div class="fw-semibold">{{ notification.title }}</div>
                                        <div class="text-muted small mt-1">{{ notification.message }}</div>
                                        <div class="text-muted small mt-2">{{ notification.createdAt|date('d M Y H:i') }}</div>
                                    </div>
                                    <span class="badge {{ notification.status == 'approved' ? 'bg-success' : 'bg-danger' }}">
                                        {{ notification.status|capitalize }}
                                    </span>
                                </div>
                            </div>
                        </div>
                    </a>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}

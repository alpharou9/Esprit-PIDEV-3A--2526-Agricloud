<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}AgriCloud{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <style>
        .button,
        .button_1 {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: .5rem;
            min-height: 42px;
            padding: .7rem 1.2rem;
            border-radius: .75rem;
            border: 1px solid #198754;
            font-weight: 600;
            text-decoration: none;
            transition: all .2s ease;
        }

        .button,
        .bg_green {
            background: #198754;
            color: #fff !important;
        }

        .button:hover,
        .bg_green:hover {
            background: #157347;
            border-color: #157347;
            color: #fff !important;
        }

        .button_1 {
            background: #fff;
            color: #198754;
        }

        .button_1:hover {
            background: #f8f9fa;
            color: #157347;
            border-color: #157347;
        }

        .border_light {
            border: 1px solid #dee2e6;
            border-radius: 1rem;
        }

        .hero-panel {
            background: linear-gradient(135deg, rgba(25, 135, 84, 0.92), rgba(92, 184, 92, 0.86));
            border-radius: 1.5rem;
            overflow: hidden;
        }

        .hero-image {
            min-height: 280px;
            height: 100%;
            object-fit: cover;
        }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body class="bg-light">

<nav class="navbar navbar-expand-lg navbar-dark bg-success px-4">
    <a class="navbar-brand fw-bold" href="{{ path('market_index') }}">
        <i class="bi bi-tree-fill me-1"></i> AgriCloud
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
        <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navMenu">
        <ul class="navbar-nav me-auto">
            <li class="nav-item">
                <a class="nav-link {{ app.request.attributes.get('_route') starts with 'market_' ? 'active fw-semibold' : '' }}"
                   href="{{ path('market_index') }}">
                    <i class="bi bi-shop me-1"></i>Catalog
                </a>
            </li>
            {% if is_granted('ROLE_CUSTOMER') %}
                <li class="nav-item">
                    <a class="nav-link {{ app.request.attributes.get('_route') starts with 'cart_' ? 'active fw-semibold' : '' }}"
                       href="{{ path('cart_index') }}">
                        <i class="bi bi-cart3 me-1"></i>Cart
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link {{ app.request.attributes.get('_route') starts with 'customer_order_' ? 'active fw-semibold' : '' }}"
                       href="{{ path('customer_order_index') }}">
                        <i class="bi bi-receipt me-1"></i>My Orders
                    </a>
                </li>
            {% endif %}
            {% if is_granted('ROLE_FARMER') or is_granted('ROLE_ADMIN') %}
                <li class="nav-item">
                    <a class="nav-link" href="{{ path('dashboard') }}">
                        <i class="bi bi-speedometer2 me-1"></i>Backoffice
                    </a>
                </li>
            {% endif %}
        </ul>
        <ul class="navbar-nav ms-auto align-items-center gap-2">
            {% if app.user %}
                <li class="nav-item">
                    <a href="{{ path('profile_show') }}" class="btn btn-outline-light btn-sm">
                        <i class="bi bi-person-circle me-1"></i>{{ app.user.name ?? app.user.email }}
                    </a>
                </li>
                <li class="nav-item">
                    <a href="{{ path('app_logout') }}" class="btn btn-outline-light btn-sm">
                        <i class="bi bi-box-arrow-right me-1"></i>Logout
                    </a>
                </li>
            {% else %}
                <li class="nav-item">
                    <a href="{{ path('app_login') }}" class="btn btn-outline-light btn-sm">
                        <i class="bi bi-box-arrow-in-right me-1"></i>Login
                    </a>
                </li>
            {% endif %}
        </ul>
    </div>
</nav>

<div class="container py-4">
    <section class="hero-panel text-white mb-4">
        <div class="row g-0 align-items-center">
            <div class="col-lg-7 p-4 p-lg-5">
                <div class="small text-uppercase fw-semibold mb-2">AgriCloud Market</div>
                <h1 class="display-4 fw-bold mb-3">{% block hero_title %}Fresh farms, trusted products{% endblock %}</h1>
                <p class="lead mb-0">{% block hero_text %}Browse approved farm products, manage your cart, and explore the market with the master branch front template.{% endblock %}</p>
            </div>
            <div class="col-lg-5">
                <img src="/images/decor/farm.jpg" alt="Farm landscape" class="w-100 hero-image">
            </div>
        </div>
    </section>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-1"></i> {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle me-1"></i> {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    {% block maincontainer %}{% endblock %}
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>

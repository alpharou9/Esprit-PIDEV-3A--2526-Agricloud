{% extends 'front_base.html.twig' %}

{% block title %}My Cart - AgriCloud{% endblock %}

{% block maincontainer %}
<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h2 class="fw-bold mb-1">My Cart</h2>
        <p class="text-muted mb-0">Shopping cart interface based on your `shopping_cart` table.</p>
    </div>
    <a href="{{ path('market_index') }}" class="btn btn-outline-success">
        <i class="bi bi-arrow-left me-1"></i>Continue shopping
    </a>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="card-body">
        {% if items is empty %}
            <div class="text-center py-5 text-muted">
                <i class="bi bi-cart-x fs-1 d-block mb-3"></i>
                Your cart is empty.
            </div>
        {% else %}
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Seller</th>
                            <th>Price</th>
                            <th>Quantity</th>
                            <th>Subtotal</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for item in items %}
                        <tr>
                            <td>
                                <div class="fw-semibold">{{ item.product ? item.product.name : 'N/A' }}</div>
                                <div class="text-muted small">{{ item.product and item.product.farm ? item.product.farm.name : 'No farm' }}</div>
                            </td>
                            <td>{{ item.product and item.product.user ? item.product.user.name : 'N/A' }}</td>
                            <td>{{ item.product ? item.product.price|number_format(2, '.', ' ') : '0.00' }}</td>
                            <td style="max-width: 170px;">
                                <form method="post" action="{{ path('cart_update', {id: item.id}) }}" class="d-flex gap-2">
                                    <input type="hidden" name="_token" value="{{ csrf_token('cart_update_' ~ item.id) }}">
                                    <input type="number" min="1" max="{{ item.product ? item.product.quantity : 1 }}" name="quantity" value="{{ item.quantity }}" class="form-control form-control-sm">
                                    <button class="btn btn-sm btn-outline-success">Update</button>
                                </form>
                            </td>
                            <td>{{ ((item.product ? item.product.price : 0) * item.quantity)|number_format(2, '.', ' ') }}</td>
                            <td class="text-end">
                                <form method="post" action="{{ path('cart_remove', {id: item.id}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('cart_remove_' ~ item.id) }}">
                                    <button class="btn btn-sm btn-outline-danger">Remove</button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>

            <div class="d-flex justify-content-end mt-4">
                <div class="p-3 rounded-4 bg-light" style="min-width: 260px;">
                    <div class="small text-uppercase text-muted fw-semibold">Cart total</div>
                    <div class="display-6 fw-bold">{{ cartTotal|number_format(2, '.', ' ') }}</div>
                    <div class="small text-muted mb-3">Checkout can be connected later to your `orders` workflow.</div>
                    <a href="{{ path('customer_order_index') }}" class="btn btn-success w-100">View my orders</a>
                </div>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Welcome to AgriCloud{% endblock %}

{# We override the body block to remove the sidebar for the landing page #}
{% block body %}
<style>
    /* Custom styles to center the content since there is no sidebar on this page */
    .role-selection-container {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 80vh;
    }
    .role-card {
        transition: transform 0.2s;
        cursor: pointer;
        text-decoration: none;
        color: inherit;
    }
    .role-card:hover {
        transform: translateY(-5px);
        text-decoration: none;
        color: inherit;
    }
    /* Hide the sidebar for this specific landing page */
    #sidebarMenu {
        display: none !important;
    }
    main {
        margin-left: 0 !important;
        width: 100% !important;
    }
</style>

<div class="role-selection-container">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-success">AgriCloud</h1>
        <p class="lead text-muted">Smart Farm & Field Management Ecosystem</p>
    </div>

    <div class="row w-100 justify-content-center" style="max-width: 800px;">
        {# Farmer Role #}
        <div class="col-md-5 mb-4">
            <a href="{{ path('app_my_farms') }}" class="card role-card shadow border-success h-100">
                <div class="card-body text-center p-5">
                    <div class="display-1 mb-3">👨‍🌾</div>
                    <h2 class="h4 fw-bold">Farmer</h2>
                    <p class="text-muted">Manage your farms, add fields, and track your agricultural resources.</p>
                    <span class="btn btn-success mt-3">Access Portal</span>
                </div>
            </a>
        </div>

        {# Admin Role #}
        <div class="col-md-5 mb-4">
            <a href="{{ path('admin_dashboard') }}" class="card role-card shadow border-primary h-100">
                <div class="card-body text-center p-5">
                    <div class="display-1 mb-3">🛡️</div>
                    <h2 class="h4 fw-bold">Administrator</h2>
                    <p class="text-muted">Review pending farm submissions and manage platform approvals.</p>
                    <span class="btn btn-primary mt-3">Admin Login</span>
                </div>
            </a>
        </div>
    </div>
    
    <div class="mt-4">
        <a href="{{ path('app_farm_index') }}" class="text-secondary text-decoration-none">
            <small>Browse Public Farm Marketplace →</small>
        </a>
    </div>
</div>
{% endblock %}
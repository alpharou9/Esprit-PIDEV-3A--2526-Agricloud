{% extends 'base.html.twig' %}
{% block title %}{{ event.title }} — AgriCloud{% endblock %}

{% block body %}
{% set confirmed = event.confirmedCount %}
{% set capacity = event.capacity %}
{% if capacity %}
    {% set ratio = confirmed / capacity %}
    {% if confirmed >= capacity %}
        {% set availability = {label:'Full', color:'#c0392b', background:'#fdeeed'} %}
    {% elseif ratio < 0.5 %}
        {% set availability = {label:'Many spots left', color:'#198754', background:'#eaf7ef'} %}
    {% elseif ratio < 0.85 %}
        {% set availability = {label:'Filling up', color:'#d97706', background:'#fff4df'} %}
    {% else %}
        {% set availability = {label:'Almost full', color:'#c0392b', background:'#fdeeed'} %}
    {% endif %}
{% else %}
    {% set availability = {label:'Open registration', color:'#198754', background:'#eaf7ef'} %}
{% endif %}
<div class="d-flex align-items-center gap-2 mb-4">
    <a href="{{ path('event_index') }}" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h5 class="fw-bold mb-0">{{ event.title }}</h5>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        {% if event.image %}
            <img src="{{ asset('uploads/events/' ~ event.image) }}" class="w-100 rounded-4 mb-4" style="max-height:380px;object-fit:cover" alt="{{ event.title }}">
        {% else %}
            <div class="rounded-4 d-flex align-items-center justify-content-center mb-4" style="height:260px;background:linear-gradient(135deg,#d1e7dd,#a3cfbb);font-size:5rem;color:#198754">
                <i class="bi bi-calendar-event"></i>
            </div>
        {% endif %}

        <div class="d-flex gap-2 flex-wrap mb-3">
            {% set sc = {upcoming:'success',ongoing:'primary',completed:'secondary',cancelled:'danger'} %}
            <span class="badge bg-{{ sc[event.status] ?? 'secondary' }}">{{ event.status|capitalize }}</span>
            <span class="badge border" style="background:{{ availability.background }};color:{{ availability.color }};border-color:{{ availability.color }}33 !important;">
                <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:{{ availability.color }};margin-right:6px;"></span>{{ availability.label }}
            </span>
            {% if event.category %}<span class="badge bg-light text-dark border">{{ event.category }}</span>{% endif %}
            <span class="text-muted small"><i class="bi bi-people me-1"></i>{{ event.confirmedCount }} registered{% if event.capacity %} / {{ event.capacity }} capacity{% endif %}</span>
        </div>

        <div class="mb-4" style="line-height:1.8;white-space:pre-wrap">{{ event.description }}</div>

        {# Owner / admin actions #}
        {% if event.user == app.user or is_granted('ROLE_ADMIN') %}
        <div class="d-flex gap-2 mb-4">
            <a href="{{ path('event_edit', {id: event.id}) }}" class="btn btn-outline-primary btn-sm"><i class="bi bi-pencil me-1"></i>Edit</a>
            <a href="{{ path('event_participants', {id: event.id}) }}" class="btn btn-outline-secondary btn-sm"><i class="bi bi-people me-1"></i>Participants</a>
            <form method="post" action="{{ path('event_delete', {id: event.id}) }}" onsubmit="return confirm('Delete this event?')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_event_' ~ event.id) }}">
                <button class="btn btn-outline-danger btn-sm"><i class="bi bi-trash me-1"></i>Delete</button>
            </form>
        </div>
        {% endif %}

        {# Registration action #}
        {% if event.user != app.user %}
            {% if myParticipation and myParticipation.status != 'cancelled' %}
                <div class="alert alert-success d-flex justify-content-between align-items-center">
                    <span><i class="bi bi-check-circle me-1"></i>You are registered — <strong>{{ myParticipation.status|capitalize }}</strong></span>
                    {% if myParticipation.status != 'attended' %}
                    <form method="post" action="{{ path('event_cancel_registration', {id: myParticipation.id}) }}" onsubmit="return confirm('Cancel your registration?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('cancel_participation_' ~ myParticipation.id) }}">
                        <button class="btn btn-sm btn-outline-danger">Cancel Registration</button>
                    </form>
                    {% endif %}
                </div>
            {% elseif event.isRegistrationOpen and not event.isFull %}
                <form method="post" action="{{ path('event_register', {id: event.id}) }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('register_event_' ~ event.id) }}">
                    <button class="btn btn-success px-5">
                        <i class="bi bi-ticket-perforated me-1"></i>Register Now
                    </button>
                </form>
            {% elseif event.isFull %}
                <div class="alert alert-warning small"><i class="bi bi-exclamation-triangle me-1"></i>This event is full.</div>
            {% else %}
                <div class="alert alert-secondary small"><i class="bi bi-lock me-1"></i>Registration is closed.</div>
            {% endif %}
        {% endif %}
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 p-3 mb-3">
            <h6 class="fw-semibold mb-3"><i class="bi bi-info-circle me-1"></i>Event Details</h6>
            <ul class="list-unstyled small text-muted mb-0">
                <li class="mb-2"><i class="bi bi-calendar-event me-2 text-success"></i><strong>Start:</strong> {{ event.eventDate ? event.eventDate|date('d M Y, H:i') : '—' }}</li>
                {% if event.endDate %}
                <li class="mb-2"><i class="bi bi-calendar-check me-2 text-success"></i><strong>End:</strong> {{ event.endDate|date('d M Y, H:i') }}</li>
                {% endif %}
                {% if event.registrationDeadline %}
                <li class="mb-2"><i class="bi bi-clock me-2 text-warning"></i><strong>Deadline:</strong> {{ event.registrationDeadline|date('d M Y, H:i') }}</li>
                {% endif %}
                <li class="mb-2"><i class="bi bi-geo-alt me-2 text-success"></i>{{ event.location }}</li>
                <li class="mb-2"><i class="bi bi-person me-2 text-success"></i>Organized by <strong>{{ event.user.name }}</strong></li>
                <li class="mb-2"><i class="bi bi-people me-2 text-success"></i>{{ event.confirmedCount }} registered{% if event.capacity %} / {{ event.capacity }}{% endif %}</li>
                <li><i class="bi bi-calendar-plus me-2 text-success"></i>Created {{ event.createdAt ? event.createdAt|date('d M Y') : '—' }}</li>
            </ul>
        </div>

        {% if event.latitude and event.longitude %}
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <iframe
                src="https://maps.google.com/maps?q={{ event.latitude }},{{ event.longitude }}&z=14&output=embed"
                width="100%" height="220" style="border:0" allowfullscreen loading="lazy"></iframe>
        </div>
        {% endif %}
    </div>
</div>
{% endblock %}

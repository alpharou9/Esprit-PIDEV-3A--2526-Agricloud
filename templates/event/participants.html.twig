{% extends 'base.html.twig' %}
{% block title %}Participants — {{ event.title }}{% endblock %}

{% block body %}
<div class="d-flex align-items-center gap-2 mb-4">
    <a href="{{ path('event_show', {id: event.id}) }}" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h5 class="fw-bold mb-0">Participants — {{ event.title }}</h5>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 p-3 text-center">
            <div class="fs-2 fw-bold text-success">{{ event.participations|length }}</div>
            <div class="text-muted small">Total Registrations</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 p-3 text-center">
            <div class="fs-2 fw-bold text-primary">{{ event.confirmedCount }}</div>
            <div class="text-muted small">Confirmed</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 p-3 text-center">
            <div class="fs-2 fw-bold text-success">{{ event.participations|filter(p => p.isAttended)|length }}</div>
            <div class="text-muted small">Attended</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm rounded-4 p-3 text-center">
            <div class="fs-2 fw-bold text-danger">{{ event.participations|filter(p => p.status == 'cancelled')|length }}</div>
            <div class="text-muted small">Cancelled</div>
        </div>
    </div>
</div>

{% if event.participations is empty %}
<div class="text-center text-muted py-4">No registrations yet.</div>
{% else %}
<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Participant</th>
                    <th>Status</th>
                    <th>Registered On</th>
                    <th>Attended</th>
                    {% if is_granted('ROLE_ADMIN') %}<th>Action</th>{% endif %}
                </tr>
            </thead>
            <tbody>
                {% for p in event.participations %}
                <tr>
                    <td class="fw-semibold">{{ p.user.name }}<br><small class="text-muted fw-normal">{{ p.user.email }}</small></td>
                    <td>
                        {% set sc = {pending:'warning',confirmed:'success',cancelled:'danger',attended:'primary'} %}
                        <span class="badge bg-{{ sc[p.status] ?? 'secondary' }} {% if p.status == 'pending' %}text-dark{% endif %}">{{ p.status|capitalize }}</span>
                    </td>
                    <td class="text-muted small">{{ p.registrationDate ? p.registrationDate|date('d M Y') : '—' }}</td>
                    <td>
                        {% if p.isAttended %}
                            <i class="bi bi-check-circle-fill text-success"></i>
                        {% else %}
                            <i class="bi bi-circle text-muted"></i>
                        {% endif %}
                    </td>
                    {% if is_granted('ROLE_ADMIN') %}
                    <td>
                        {% if p.status != 'cancelled' %}
                        <form method="post" action="{{ path('event_mark_attended', {id: p.id}) }}">
                            <input type="hidden" name="_token" value="{{ csrf_token('attended_' ~ p.id) }}">
                            <button class="btn btn-sm {% if p.isAttended %}btn-success{% else %}btn-outline-success{% endif %}">
                                <i class="bi bi-{{ p.isAttended ? 'person-check-fill' : 'person-check' }}"></i>
                                {{ p.isAttended ? 'Unmark' : 'Mark Attended' }}
                            </button>
                        </form>
                        {% endif %}
                    </td>
                    {% endif %}
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endif %}
{% endblock %}

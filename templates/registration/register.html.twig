<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>AgriCloud — Create Account</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Philosopher:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <script src="https://www.google.com/recaptcha/api.js" async defer></script>
    <style>
        * { box-sizing: border-box; }
        body { font-family: 'Philosopher', sans-serif; margin: 0; padding: 0; min-height: 100vh; display: flex; }

        /* ── Left panel ── */
        .auth-left {
            width: 42%;
            background:
                radial-gradient(ellipse at 20% 20%, rgba(119,184,30,.2) 0%, transparent 50%),
                radial-gradient(ellipse at 90% 80%, rgba(30,80,5,.35) 0%, transparent 50%),
                linear-gradient(145deg, #0d1f05 0%, #2d5c10 50%, #1a3a08 100%);
            display: flex; flex-direction: column;
            justify-content: space-between;
            padding: 40px 52px;
            position: sticky; top: 0; height: 100vh;
            overflow: hidden;
        }
        .auth-left::before {
            content: '';
            position: absolute; inset: 0;
            background-image: radial-gradient(circle at 1px 1px, rgba(119,184,30,.06) 1px, transparent 0);
            background-size: 36px 36px;
            pointer-events: none;
        }
        .auth-left::after {
            content: '';
            position: absolute; top: -80px; left: -80px;
            width: 320px; height: 320px;
            border-radius: 50%;
            background: rgba(119,184,30,.12);
        }

        .auth-brand { display: flex; align-items: center; gap: 10px; text-decoration: none; z-index: 1; }
        .auth-brand span { font-size: 1.6rem; font-weight: 700; color: #fff; }
        .auth-brand i { color: #77b81e; font-size: 1.8rem; }

        .auth-hero-text { z-index: 1; }
        .auth-hero-text h2 { color: #fff; font-size: 2.2rem; font-weight: 700; line-height: 1.25; margin-bottom: 14px; }
        .auth-hero-text h2 span { color: #a3d43a; }
        .auth-hero-text p { color: rgba(255,255,255,.7); font-size: .95rem; max-width: 380px; }

        .auth-steps { display: flex; flex-direction: column; gap: 16px; z-index: 1; }
        .auth-step { display: flex; align-items: flex-start; gap: 14px; }
        .step-num {
            width: 32px; height: 32px; border-radius: 50%;
            background: #77b81e;
            display: flex; align-items: center; justify-content: center;
            color: #fff; font-weight: 700; font-size: .85rem; flex-shrink: 0;
        }
        .auth-step .step-text { color: rgba(255,255,255,.8); font-size: .9rem; padding-top: 5px; }

        /* ── Right panel ── */
        .auth-right {
            width: 58%;
            background: #f8faf4;
            display: flex; align-items: flex-start; justify-content: center;
            padding: 48px 56px;
            overflow-y: auto;
        }
        .auth-form-wrap { width: 100%; max-width: 420px; }

        .auth-form-wrap h3 { font-size: 1.7rem; font-weight: 700; color: #1a2e0a; margin-bottom: 4px; }
        .auth-form-wrap .subtitle { color: #888; font-size: .9rem; margin-bottom: 28px; }

        .form-label { font-weight: 600; font-size: .85rem; color: #444; margin-bottom: 6px; }
        .form-control {
            border-radius: 10px; border: 1.5px solid #dde8cc;
            padding: 11px 14px 11px 38px; font-size: .93rem; background: #fff;
            transition: border-color .2s, box-shadow .2s;
        }
        .form-control:focus {
            border-color: #77b81e;
            box-shadow: 0 0 0 3px rgba(119,184,30,.15);
            outline: none;
        }
        .input-icon { position: relative; }
        .input-icon i {
            position: absolute; left: 13px; top: 50%; transform: translateY(-50%);
            color: #aaa; font-size: .95rem; pointer-events: none;
        }

        .field-group {
            background: #fff; border-radius: 14px;
            padding: 20px 20px 8px;
            box-shadow: 0 2px 12px rgba(0,0,0,.05);
            margin-bottom: 18px;
        }
        .field-group-label {
            font-size: .68rem; font-weight: 700; text-transform: uppercase;
            letter-spacing: 1.5px; color: #77b81e; margin-bottom: 14px;
            display: flex; align-items: center; gap: 6px;
        }

        .btn-auth {
            background: #77b81e; color: #fff; border: none;
            border-radius: 10px; padding: 13px; font-size: 1rem; font-weight: 600;
            width: 100%; transition: background .2s;
            display: flex; align-items: center; justify-content: center; gap: 8px;
            margin-top: 4px;
        }
        .btn-auth:hover { background: #5a9014; color: #fff; }

        .field-hint {
            font-size: .78rem; color: #888; margin-top: 4px;
            padding-left: 2px;
        }
        .password-hint {
            background: #fff8e1; border-left: 3px solid #f59e0b;
            border-radius: 0 8px 8px 0; padding: 9px 12px;
            font-size: .8rem; color: #92400e; margin-top: 6px;
        }

        .role-card { cursor: pointer; }
        .role-card-inner {
            border: 2px solid #dde8cc; border-radius: 12px; padding: 14px 12px;
            display: flex; flex-direction: column; align-items: center; gap: 4px;
            text-align: center; background: #fff; transition: all .2s;
        }
        .role-card-inner i { font-size: 1.6rem; color: #aaa; transition: color .2s; }
        .role-card-inner strong { font-size: .9rem; color: #333; }
        .role-card-inner span { font-size: .75rem; color: #999; }
        .role-card input:checked + .role-card-inner {
            border-color: #77b81e; background: #f0f7e0;
            box-shadow: 0 0 0 3px rgba(119,184,30,.15);
        }
        .role-card input:checked + .role-card-inner i { color: #77b81e; }
        .role-card input:checked + .role-card-inner strong { color: #3a6a0a; }

        .auth-switch { text-align: center; font-size: .88rem; color: #888; margin-top: 20px; }
        .auth-switch a { color: #77b81e; font-weight: 700; text-decoration: none; }
        .auth-switch a:hover { text-decoration: underline; }

        @media (max-width: 768px) {
            .auth-left { display: none; }
            .auth-right { width: 100%; padding: 32px 20px; }
        }
    </style>
</head>
<body>

{# ── Left panel ── #}
<div class="auth-left">
    <a href="{{ path('home') }}" class="auth-brand">
        <i class="bi bi-tree-fill"></i>
        <span>AgriCloud</span>
    </a>

    <div class="auth-hero-text">
        <h2>Join the<br><span>AgriCloud</span><br>Community.</h2>
        <p>Create your free account and start managing your farm, selling your products, and connecting with fellow farmers today.</p>
    </div>

    <div class="auth-steps">
        <div class="auth-step">
            <div class="step-num">1</div>
            <div class="step-text">Create your account with basic information</div>
        </div>
        <div class="auth-step">
            <div class="step-num">2</div>
            <div class="step-text">Register your farm and add your fields</div>
        </div>
        <div class="auth-step">
            <div class="step-num">3</div>
            <div class="step-text">List products and start selling on the marketplace</div>
        </div>
    </div>
</div>

{# ── Right panel ── #}
<div class="auth-right">
    <div class="auth-form-wrap">
        <h3>Create Account</h3>
        <p class="subtitle">Fill in the details below to get started</p>

        {% for message in app.flashes('success') %}
            <div class="alert d-flex align-items-center gap-2 mb-4" style="border-radius:10px;border:none;background:#e8f8ee;color:#166534;font-size:.88rem">
                <i class="bi bi-check-circle-fill"></i> {{ message }}
            </div>
        {% endfor %}

        {% if recaptcha_error %}
            <div class="alert alert-danger d-flex align-items-center gap-2 mb-4" style="border-radius:10px;border:none;background:#fde8e8;color:#b91c1c;font-size:.88rem">
                <i class="bi bi-shield-exclamation"></i>
                {{ recaptcha_error }}
            </div>
        {% endif %}

        {{ form_start(form, {attr: {novalidate: 'novalidate', id: 'registerForm'}}) }}

        {# Personal info #}
        <div class="field-group">
            <div class="field-group-label"><i class="bi bi-person-fill"></i> Personal Information</div>

            <div class="mb-3">
                {{ form_label(form.name) }}
                <div class="input-icon">
                    <i class="bi bi-person"></i>
                    {{ form_widget(form.name, {attr: {class: 'form-control', placeholder: 'Your full name'}}) }}
                </div>
                {{ form_errors(form.name) }}
                <div class="field-hint">Letters, spaces, hyphens and apostrophes only · 2–100 characters</div>
            </div>

            <div class="mb-3">
                {{ form_label(form.email) }}
                <div class="input-icon">
                    <i class="bi bi-envelope"></i>
                    {{ form_widget(form.email, {attr: {class: 'form-control', placeholder: 'your@email.com'}}) }}
                </div>
                {{ form_errors(form.email) }}
                <div class="field-hint">Must be a valid email address · Maximum 150 characters · Must be unique</div>
            </div>

            <div class="mb-3">
                {{ form_label(form.phone) }}
                <div class="input-icon">
                    <i class="bi bi-telephone"></i>
                    {{ form_widget(form.phone, {attr: {class: 'form-control', placeholder: '+216 XX XXX XXX'}}) }}
                </div>
                {{ form_errors(form.phone) }}
                <div class="field-hint">Optional · 8–20 digits, may start with +</div>
            </div>
        </div>

        {# Password #}
        <div class="field-group">
            <div class="field-group-label"><i class="bi bi-lock-fill"></i> Security</div>

            <div class="mb-3">
                {{ form_label(form.plainPassword) }}
                <div class="input-icon">
                    <i class="bi bi-lock"></i>
                    {{ form_widget(form.plainPassword, {attr: {class: 'form-control', placeholder: 'Min. 6 characters'}}) }}
                </div>
                {{ form_errors(form.plainPassword) }}
                <div class="field-hint">At least 6 characters · Must include one uppercase letter and one number</div>
            </div>
        </div>

        {# Account type #}
        <div class="field-group">
            <div class="field-group-label"><i class="bi bi-people-fill"></i> I am registering as</div>
            <div class="d-flex gap-3 mb-2">
                <label class="role-card flex-fill" for="role_customer">
                    <input type="radio" name="account_type" id="role_customer" value="customer" checked hidden>
                    <div class="role-card-inner">
                        <i class="bi bi-bag-heart-fill"></i>
                        <strong>Customer</strong>
                        <span>Browse &amp; buy products</span>
                    </div>
                </label>
                <label class="role-card flex-fill" for="role_farmer">
                    <input type="radio" name="account_type" id="role_farmer" value="farmer" hidden>
                    <div class="role-card-inner">
                        <i class="bi bi-house-heart-fill"></i>
                        <strong>Farmer</strong>
                        <span>Sell products &amp; manage farms</span>
                    </div>
                </label>
            </div>
        </div>

        {% if recaptcha_key %}
        <div class="g-recaptcha mb-3" data-sitekey="{{ recaptcha_key }}"></div>
        {% endif %}

        <button type="submit" class="btn-auth">
            <i class="bi bi-person-plus"></i> Create My Account
        </button>

        {{ form_end(form) }}

        <div style="display:flex;align-items:center;gap:12px;margin:20px 0 4px">
            <div style="flex:1;height:1px;background:#dde8cc"></div>
            <span style="color:#aaa;font-size:.82rem;white-space:nowrap">or register with</span>
            <div style="flex:1;height:1px;background:#dde8cc"></div>
        </div>

        <a href="{{ path('auth_google') }}" class="btn-guest mt-2" style="gap:10px">
            <svg width="18" height="18" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
                <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.18 1.48-4.97 2.36-8.16 2.36-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                <path fill="none" d="M0 0h48v48H0z"/>
            </svg>
            Continue with Google
        </a>

        <div class="auth-switch" style="margin-top:16px">
            Already have an account? <a href="{{ path('app_login') }}">Sign in</a>
        </div>

        <div class="text-center mt-3">
            <a href="{{ path('home') }}" class="text-muted text-decoration-none" style="font-size:.82rem">
                <i class="bi bi-arrow-left me-1"></i>Back to homepage
            </a>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

{% extends 'base.html.twig' %}
{% block title %}{{ post.title }} — AgriCloud{% endblock %}

{% block body %}
<div class="d-flex align-items-center gap-2 mb-4">
    <a href="{{ path('blog_index') }}" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h5 class="fw-bold mb-0">{{ post.title }}</h5>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        {# Cover image #}
        {% if post.image %}
            <img src="{{ asset('uploads/posts/' ~ post.image) }}" class="w-100 rounded-4 mb-4" style="max-height:380px;object-fit:cover" alt="{{ post.title }}">
        {% endif %}

        {# Meta badges #}
        <div class="d-flex gap-2 flex-wrap align-items-center mb-3">
            {% if post.category %}
                <span class="badge bg-light text-dark border">{{ post.category }}</span>
            {% endif %}
            <span class="badge {% if post.status == 'published' %}bg-success{% elseif post.status == 'draft' %}bg-secondary{% else %}bg-warning text-dark{% endif %}">{{ post.status|capitalize }}</span>
            <span class="text-muted small"><i class="bi bi-eye me-1"></i>{{ post.views }} views</span>
            <span class="text-muted small"><i class="bi bi-chat me-1"></i>{{ post.approvedComments|length }} comments</span>
        </div>

        {# Author + date #}
        <div class="d-flex gap-3 mb-4 text-muted small">
            <span><i class="bi bi-person me-1"></i>By <strong>{{ post.user.name }}</strong></span>
            <span><i class="bi bi-calendar me-1"></i>{{ post.publishedAt ? post.publishedAt|date('d M Y') : post.createdAt|date('d M Y') }}</span>
        </div>

        {# Read mode toolbar #}
        <div class="d-flex gap-2 mb-2 align-items-center flex-wrap">
            <button id="btn-tts" class="btn btn-outline-success btn-sm" onclick="toggleTTS()">
                <i class="bi bi-volume-up me-1"></i>Read Aloud
            </button>
            <button id="btn-summary" class="btn btn-outline-primary btn-sm" onclick="generateSummary()">
                <i class="bi bi-stars me-1"></i>AI Summary
            </button>
        </div>
        <div id="summary-box" class="d-none alert alert-success small mb-3">
            <strong><i class="bi bi-stars me-1"></i>Summary:</strong>
            <span id="summary-text"></span>
        </div>

        {# Content #}
        <div id="post-content" class="mb-4" style="line-height:1.8;white-space:pre-wrap">{{ post.content }}</div>

        {# Tags #}
        {% if post.tags %}
        <div class="mb-4">
            {% for tag in post.tags %}
                <span class="badge bg-light text-muted border me-1">#{{ tag }}</span>
            {% endfor %}
        </div>
        {% endif %}

        {# Owner actions #}
        {% if post.user == app.user or is_granted('ROLE_ADMIN') %}
        <div class="d-flex gap-2 mb-5">
            <a href="{{ path('blog_edit', {id: post.id}) }}" class="btn btn-outline-primary btn-sm"><i class="bi bi-pencil me-1"></i>Edit</a>
            <form method="post" action="{{ path('blog_delete', {id: post.id}) }}" onsubmit="return confirm('Delete this post?')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_post_' ~ post.id) }}">
                <button class="btn btn-outline-danger btn-sm"><i class="bi bi-trash me-1"></i>Delete</button>
            </form>
        </div>
        {% endif %}

        {# Comments section #}
        <hr class="my-4">
        <h6 class="fw-bold mb-3"><i class="bi bi-chat-dots me-2"></i>Comments ({{ post.approvedComments|length }})</h6>

        {% for comment in post.approvedComments %}
        <div class="d-flex gap-3 mb-4">
            <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center flex-shrink-0" style="width:38px;height:38px;font-size:.85rem;font-weight:600">
                {{ comment.user.name|slice(0,1)|upper }}
            </div>
            <div class="flex-grow-1">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <strong class="small">{{ comment.user.name }}</strong>
                    <div class="d-flex align-items-center gap-2">
                        <span class="text-muted" style="font-size:.75rem">{{ comment.createdAt ? comment.createdAt|date('d M Y, H:i') : '' }}</span>
                        {% if is_granted('ROLE_ADMIN') %}
                        <form method="post" action="{{ path('user_toggle_block', {id: comment.user.id}) }}" class="d-inline" onsubmit="return confirm('Block/unblock {{ comment.user.name }}?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('toggle_block_' ~ comment.user.id) }}">
                            <input type="hidden" name="_redirect" value="{{ app.request.pathInfo }}">
                            <button class="btn btn-warning btn-sm py-0 px-1" title="Block/Unblock user" style="font-size:.7rem">
                                <i class="bi bi-person-slash"></i>
                            </button>
                        </form>
                        <form method="post" action="{{ path('comment_delete', {id: comment.id}) }}" class="d-inline" onsubmit="return confirm('Delete this comment?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_comment_' ~ comment.id) }}">
                            <button class="btn btn-danger btn-sm py-0 px-1" title="Delete comment" style="font-size:.7rem">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                        {% endif %}
                    </div>
                </div>
                <p class="mb-2 small">{{ comment.content }}</p>

                {# Replies #}
                {% for reply in comment.replies %}
                    {% if reply.status == 'approved' %}
                    <div class="d-flex gap-2 mt-2 ms-3 ps-3 border-start border-2">
                        <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center flex-shrink-0" style="width:30px;height:30px;font-size:.75rem;font-weight:600">
                            {{ reply.user.name|slice(0,1)|upper }}
                        </div>
                        <div>
                            <strong class="small">{{ reply.user.name }}</strong>
                            <span class="text-muted ms-2" style="font-size:.75rem">{{ reply.createdAt ? reply.createdAt|date('d M Y') : '' }}</span>
                            <p class="mb-0 small">{{ reply.content }}</p>
                        </div>
                    </div>
                    {% endif %}
                {% endfor %}

                {# Reply form — plain HTML to avoid re-rendering the shared commentForm #}
                {% if post.status == 'published' %}
                <button class="btn btn-link btn-sm p-0 text-muted mt-1" data-bs-toggle="collapse" data-bs-target="#reply-{{ comment.id }}">
                    <i class="bi bi-reply me-1"></i>Reply
                </button>
                <div class="collapse mt-2" id="reply-{{ comment.id }}">
                    <form method="post" action="{{ path('blog_comment_add', {id: post.id}) }}" class="d-flex gap-2">
                        <input type="hidden" name="_token" value="{{ csrf_token('comment_add_' ~ post.id) }}">
                        <input type="hidden" name="parent_id" value="{{ comment.id }}">
                        <textarea name="comment[content]" class="form-control form-control-sm" rows="2" placeholder="Write a reply…" required></textarea>
                        <button class="btn btn-success btn-sm">Post</button>
                    </form>
                </div>
                {% endif %}
            </div>
        </div>
        {% else %}
        <p class="text-muted small">No approved comments yet. Be the first!</p>
        {% endfor %}

        {# New comment form #}
        {% if post.status == 'published' %}
        <div class="card border-0 bg-light rounded-4 p-3 mt-4">
            <h6 class="fw-semibold mb-3"><i class="bi bi-pencil me-1"></i>Leave a Comment</h6>
            {{ form_start(commentForm, {attr: {novalidate: 'novalidate'}}) }}
            {{ form_widget(commentForm.content) }}
            {{ form_errors(commentForm.content) }}
            <button type="submit" class="btn btn-success btn-sm mt-2">
                <i class="bi bi-send me-1"></i>Submit Comment
            </button>
            {{ form_end(commentForm) }}
            <div class="form-text mt-1"><i class="bi bi-info-circle me-1"></i>Comments are reviewed before appearing.</div>
        </div>
        {% endif %}
    </div>

    {# Sidebar #}
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 p-3 mb-3">
            <h6 class="fw-semibold mb-2"><i class="bi bi-info-circle me-1"></i>Post Info</h6>
            <ul class="list-unstyled small text-muted mb-0">
                <li class="mb-1"><i class="bi bi-person me-1"></i>{{ post.user.name }}</li>
                <li class="mb-1"><i class="bi bi-calendar me-1"></i>{{ post.createdAt ? post.createdAt|date('d M Y') : '—' }}</li>
                {% if post.publishedAt %}<li class="mb-1"><i class="bi bi-send me-1"></i>Published {{ post.publishedAt|date('d M Y') }}</li>{% endif %}
                <li class="mb-1"><i class="bi bi-eye me-1"></i>{{ post.views }} views</li>
                <li><i class="bi bi-chat me-1"></i>{{ post.approvedComments|length }} comments</li>
            </ul>
        </div>

        {# Translator widget #}
        <div class="card border-0 shadow-sm rounded-4 p-3 mb-3">
            <h6 class="fw-semibold mb-2"><i class="bi bi-translate me-1"></i>Translate Article</h6>
            <select id="trans-lang" class="form-select form-select-sm mb-2">
                <option value="">— Select language —</option>
                <option value="fr">French</option>
                <option value="ar">Arabic</option>
                <option value="es">Spanish</option>
                <option value="de">German</option>
                <option value="it">Italian</option>
                <option value="pt">Portuguese</option>
                <option value="zh">Chinese</option>
                <option value="ru">Russian</option>
            </select>
            <button id="btn-translate" class="btn btn-outline-success btn-sm w-100 mb-2">
                <i class="bi bi-globe me-1"></i>Translate
            </button>
            <div id="trans-result" class="d-none">
                <hr class="my-2">
                <div id="trans-text" class="small" style="max-height:320px;overflow-y:auto;white-space:pre-wrap;line-height:1.7"></div>
                <button id="btn-trans-close" class="btn btn-link btn-sm p-0 mt-1 text-muted">Close</button>
            </div>
            <div id="trans-loading" class="d-none text-center text-muted small py-2">Translating…</div>
        </div>
    </div>
</div>

{# Floating chatbot widget #}
<div id="chatbot-btn" style="position:fixed;bottom:28px;right:28px;z-index:1050">
    <button class="btn btn-success rounded-circle shadow" style="width:56px;height:56px;font-size:1.4rem" onclick="toggleChat()" title="AgriBot">
        <i class="bi bi-robot"></i>
    </button>
</div>
<div id="chatbot-box" class="d-none shadow-lg rounded-4 bg-white" style="position:fixed;bottom:96px;right:28px;z-index:1049;width:340px;max-height:480px;display:flex;flex-direction:column;overflow:hidden">
    <div class="d-flex align-items-center justify-content-between px-3 py-2 bg-success text-white rounded-top-4">
        <span class="fw-semibold"><i class="bi bi-robot me-1"></i>AgriBot</span>
        <button class="btn-close btn-close-white btn-sm" onclick="toggleChat()"></button>
    </div>
    <div id="chat-messages" style="flex:1;overflow-y:auto;padding:12px;display:flex;flex-direction:column;gap:8px">
        <div class="small bg-light rounded-3 p-2 align-self-start" style="max-width:85%">Hi! I'm AgriBot 🌿 Ask me anything about agriculture.</div>
    </div>
    <div class="d-flex gap-1 p-2 border-top">
        <input id="chat-input" type="text" class="form-control form-control-sm" placeholder="Ask a question…">
        <button class="btn btn-success btn-sm" onclick="sendChat()"><i class="bi bi-send"></i></button>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
// ── Text-to-Speech ────────────────────────────────────────────
var ttsUtterance = null;
var ttsSpeaking  = false;
function toggleTTS() {
    var btn = document.getElementById('btn-tts');
    if (ttsSpeaking) {
        window.speechSynthesis.cancel();
        ttsSpeaking = false;
        btn.innerHTML = '<i class="bi bi-volume-up me-1"></i>Read Aloud';
        return;
    }
    var text = document.getElementById('post-content').innerText;
    ttsUtterance = new SpeechSynthesisUtterance(text);
    ttsUtterance.lang = 'en-US';
    ttsUtterance.rate = 0.95;
    ttsUtterance.onend = function() { ttsSpeaking = false; btn.innerHTML = '<i class="bi bi-volume-up me-1"></i>Read Aloud'; };
    window.speechSynthesis.speak(ttsUtterance);
    ttsSpeaking = true;
    btn.innerHTML = '<i class="bi bi-stop-circle me-1"></i>Stop Reading';
}

// ── AI Summary ────────────────────────────────────────────────
function generateSummary() {
    var btn = document.getElementById('btn-summary');
    var box = document.getElementById('summary-box');
    var txt = document.getElementById('summary-text');
    btn.disabled = true;
    btn.innerHTML = '<i class="bi bi-hourglass me-1"></i>Generating…';
    box.classList.remove('d-none');
    txt.textContent = 'Generating summary…';

    var content = document.getElementById('post-content').innerText.slice(0, 800);
    var form = new FormData();
    form.append('message', 'Summarize this article in 3 short sentences: ' + content);

    fetch('{{ path('blog_chatbot') }}', { method: 'POST', body: form })
        .then(function(r){ return r.json(); })
        .then(function(data){
            txt.textContent = data.reply || 'Could not generate summary.';
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-stars me-1"></i>AI Summary';
        })
        .catch(function(){
            txt.textContent = 'Summary unavailable.';
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-stars me-1"></i>AI Summary';
        });
}

// ── Translator ────────────────────────────────────────────────
(function () {
    var originalText = {{ post.content|json_encode|raw }};

    document.getElementById('btn-translate').addEventListener('click', function () {
        var lang = document.getElementById('trans-lang').value;
        if (!lang) { alert('Please select a language.'); return; }
        document.getElementById('trans-loading').classList.remove('d-none');
        document.getElementById('trans-result').classList.add('d-none');

        fetch('https://api.mymemory.translated.net/get?q=' + encodeURIComponent(originalText.slice(0, 500)) + '&langpair=en|' + lang)
            .then(function (r) { return r.json(); })
            .then(function (data) {
                document.getElementById('trans-loading').classList.add('d-none');
                var text = (data.responseData && data.responseData.translatedText) ? data.responseData.translatedText : 'Translation failed.';
                document.getElementById('trans-text').textContent = text;
                document.getElementById('trans-result').classList.remove('d-none');
            })
            .catch(function () {
                document.getElementById('trans-loading').classList.add('d-none');
                document.getElementById('trans-text').textContent = 'Translation service unavailable.';
                document.getElementById('trans-result').classList.remove('d-none');
            });
    });

    document.getElementById('btn-trans-close').addEventListener('click', function () {
        document.getElementById('trans-result').classList.add('d-none');
    });
})();

// ── Chatbot ───────────────────────────────────────────────────
function toggleChat() {
    var box = document.getElementById('chatbot-box');
    box.classList.toggle('d-none');
    if (!box.classList.contains('d-none')) {
        document.getElementById('chat-input').focus();
    }
}

function sendChat() {
    var input = document.getElementById('chat-input');
    var msg = input.value.trim();
    if (!msg) return;
    appendMessage(msg, 'user');
    input.value = '';

    var thinking = appendMessage('…', 'bot');
    var form = new FormData();
    form.append('message', msg);

    fetch('{{ path('blog_chatbot') }}', { method: 'POST', body: form })
        .then(function (r) { return r.json(); })
        .then(function (data) { thinking.textContent = data.reply || 'No response.'; })
        .catch(function () { thinking.textContent = 'Error contacting chatbot.'; });
}

function appendMessage(text, who) {
    var div = document.createElement('div');
    div.className = 'small rounded-3 p-2 ' + (who === 'user' ? 'bg-success text-white align-self-end' : 'bg-light align-self-start');
    div.style.maxWidth = '85%';
    div.textContent = text;
    var msgs = document.getElementById('chat-messages');
    msgs.appendChild(div);
    msgs.scrollTop = msgs.scrollHeight;
    return div;
}

document.getElementById('chat-input').addEventListener('keydown', function (e) {
    if (e.key === 'Enter') { e.preventDefault(); sendChat(); }
});
</script>
{% endblock %}

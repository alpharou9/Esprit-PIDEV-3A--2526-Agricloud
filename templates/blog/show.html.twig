{% extends 'base.html.twig' %}
{% block title %}{{ post.title }} — AgriCloud{% endblock %}

{% block body %}
<div class="d-flex align-items-center gap-2 mb-4">
    <a href="{{ path('blog_index') }}" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h5 class="fw-bold mb-0">{{ post.title }}</h5>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        {# Cover image #}
        {% if post.image %}
            <img src="{{ asset('uploads/posts/' ~ post.image) }}" class="w-100 rounded-4 mb-4" style="max-height:380px;object-fit:cover" alt="{{ post.title }}">
        {% endif %}

        {# Meta badges #}
        <div class="d-flex gap-2 flex-wrap align-items-center mb-3">
            {% if post.category %}
                <span class="badge bg-light text-dark border">{{ post.category }}</span>
            {% endif %}
            <span class="badge {% if post.status == 'published' %}bg-success{% elseif post.status == 'draft' %}bg-secondary{% else %}bg-warning text-dark{% endif %}">{{ post.status|capitalize }}</span>
            <span class="text-muted small"><i class="bi bi-eye me-1"></i>{{ post.views }} views</span>
            <span class="text-muted small"><i class="bi bi-chat me-1"></i>{{ post.approvedComments|length }} comments</span>
        </div>

        {# Author + date #}
        <div class="d-flex gap-3 mb-4 text-muted small">
            <span><i class="bi bi-person me-1"></i>By <strong>{{ post.user.name }}</strong></span>
            <span><i class="bi bi-calendar me-1"></i>{{ post.publishedAt ? post.publishedAt|date('d M Y') : post.createdAt|date('d M Y') }}</span>
        </div>

        {# Content #}
        <div class="mb-4" style="line-height:1.8;white-space:pre-wrap">{{ post.content }}</div>

        {# Tags #}
        {% if post.tags %}
        <div class="mb-4">
            {% for tag in post.tags %}
                <span class="badge bg-light text-muted border me-1">#{{ tag }}</span>
            {% endfor %}
        </div>
        {% endif %}

        {# Owner actions #}
        {% if post.user == app.user or is_granted('ROLE_ADMIN') %}
        <div class="d-flex gap-2 mb-5">
            <a href="{{ path('blog_edit', {id: post.id}) }}" class="btn btn-outline-primary btn-sm"><i class="bi bi-pencil me-1"></i>Edit</a>
            <form method="post" action="{{ path('blog_delete', {id: post.id}) }}" onsubmit="return confirm('Delete this post?')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_post_' ~ post.id) }}">
                <button class="btn btn-outline-danger btn-sm"><i class="bi bi-trash me-1"></i>Delete</button>
            </form>
        </div>
        {% endif %}

        {# Comments section #}
        <hr class="my-4">
        <h6 class="fw-bold mb-3"><i class="bi bi-chat-dots me-2"></i>Comments ({{ post.approvedComments|length }})</h6>

        {% for comment in post.approvedComments %}
        <div class="d-flex gap-3 mb-4">
            <div class="rounded-circle bg-success text-white d-flex align-items-center justify-content-center flex-shrink-0" style="width:38px;height:38px;font-size:.85rem;font-weight:600">
                {{ comment.user.name|slice(0,1)|upper }}
            </div>
            <div class="flex-grow-1">
                <div class="d-flex justify-content-between align-items-center mb-1">
                    <strong class="small">{{ comment.user.name }}</strong>
                    <div class="d-flex align-items-center gap-2">
                        <span class="text-muted" style="font-size:.75rem">{{ comment.createdAt ? comment.createdAt|date('d M Y, H:i') : '' }}</span>
                        {% if is_granted('ROLE_ADMIN') %}
                        <form method="post" action="{{ path('user_toggle_block', {id: comment.user.id}) }}" class="d-inline" onsubmit="return confirm('Block/unblock {{ comment.user.name }}?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('toggle_block_' ~ comment.user.id) }}">
                            <input type="hidden" name="_redirect" value="{{ app.request.pathInfo }}">
                            <button class="btn btn-warning btn-sm py-0 px-1" title="Block/Unblock user" style="font-size:.7rem">
                                <i class="bi bi-person-slash"></i>
                            </button>
                        </form>
                        <form method="post" action="{{ path('comment_delete', {id: comment.id}) }}" class="d-inline" onsubmit="return confirm('Delete this comment?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_comment_' ~ comment.id) }}">
                            <button class="btn btn-danger btn-sm py-0 px-1" title="Delete comment" style="font-size:.7rem">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                        {% endif %}
                    </div>
                </div>
                <p class="mb-2 small">{{ comment.content }}</p>

                {# Replies #}
                {% for reply in comment.replies %}
                    {% if reply.status == 'approved' %}
                    <div class="d-flex gap-2 mt-2 ms-3 ps-3 border-start border-2">
                        <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center flex-shrink-0" style="width:30px;height:30px;font-size:.75rem;font-weight:600">
                            {{ reply.user.name|slice(0,1)|upper }}
                        </div>
                        <div>
                            <strong class="small">{{ reply.user.name }}</strong>
                            <span class="text-muted ms-2" style="font-size:.75rem">{{ reply.createdAt ? reply.createdAt|date('d M Y') : '' }}</span>
                            <p class="mb-0 small">{{ reply.content }}</p>
                        </div>
                    </div>
                    {% endif %}
                {% endfor %}

                {# Reply form — plain HTML to avoid re-rendering the shared commentForm #}
                {% if post.status == 'published' %}
                <button class="btn btn-link btn-sm p-0 text-muted mt-1" data-bs-toggle="collapse" data-bs-target="#reply-{{ comment.id }}">
                    <i class="bi bi-reply me-1"></i>Reply
                </button>
                <div class="collapse mt-2" id="reply-{{ comment.id }}">
                    <form method="post" action="{{ path('blog_comment_add', {id: post.id}) }}" class="d-flex gap-2">
                        <input type="hidden" name="_token" value="{{ csrf_token('comment_add_' ~ post.id) }}">
                        <input type="hidden" name="parent_id" value="{{ comment.id }}">
                        <textarea name="comment[content]" class="form-control form-control-sm" rows="2" placeholder="Write a reply…" required></textarea>
                        <button class="btn btn-success btn-sm">Post</button>
                    </form>
                </div>
                {% endif %}
            </div>
        </div>
        {% else %}
        <p class="text-muted small">No approved comments yet. Be the first!</p>
        {% endfor %}

        {# New comment form #}
        {% if post.status == 'published' %}
        <div class="card border-0 bg-light rounded-4 p-3 mt-4">
            <h6 class="fw-semibold mb-3"><i class="bi bi-pencil me-1"></i>Leave a Comment</h6>
            {{ form_start(commentForm, {attr: {novalidate: 'novalidate'}}) }}
            {{ form_widget(commentForm.content) }}
            {{ form_errors(commentForm.content) }}
            <button type="submit" class="btn btn-success btn-sm mt-2">
                <i class="bi bi-send me-1"></i>Submit Comment
            </button>
            {{ form_end(commentForm) }}
            <div class="form-text mt-1"><i class="bi bi-info-circle me-1"></i>Comments are reviewed before appearing.</div>
        </div>
        {% endif %}
    </div>

    {# Sidebar #}
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 p-3 mb-3">
            <h6 class="fw-semibold mb-2"><i class="bi bi-info-circle me-1"></i>Post Info</h6>
            <ul class="list-unstyled small text-muted mb-0">
                <li class="mb-1"><i class="bi bi-person me-1"></i>{{ post.user.name }}</li>
                <li class="mb-1"><i class="bi bi-calendar me-1"></i>{{ post.createdAt ? post.createdAt|date('d M Y') : '—' }}</li>
                {% if post.publishedAt %}<li class="mb-1"><i class="bi bi-send me-1"></i>Published {{ post.publishedAt|date('d M Y') }}</li>{% endif %}
                <li class="mb-1"><i class="bi bi-eye me-1"></i>{{ post.views }} views</li>
                <li><i class="bi bi-chat me-1"></i>{{ post.approvedComments|length }} comments</li>
            </ul>
        </div>

        {# Translator #}
        <div class="card border-0 shadow-sm rounded-4 p-3 mb-3">
            <h6 class="fw-semibold mb-2"><i class="bi bi-translate me-1"></i>Translate Post</h6>
            <select id="translateLang" class="form-select form-select-sm mb-2">
                <option value="">— Select language —</option>
                <option value="fr">French</option>
                <option value="ar">Arabic</option>
                <option value="es">Spanish</option>
                <option value="de">German</option>
                <option value="it">Italian</option>
                <option value="pt">Portuguese</option>
                <option value="zh">Chinese</option>
            </select>
            <button id="translateBtn" class="btn btn-sm btn-outline-success w-100">
                <i class="bi bi-translate me-1"></i>Translate
            </button>
            <div id="translateStatus" class="form-text mt-1"></div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
// ── Translator (MyMemory API) ─────────────────────────────
document.getElementById('translateBtn').addEventListener('click', function () {
    const lang   = document.getElementById('translateLang').value;
    const status = document.getElementById('translateStatus');
    if (!lang) { status.textContent = 'Please select a language.'; return; }

    const contentEl = document.querySelector('[style*="white-space:pre-wrap"]');
    if (!contentEl) return;

    const original = contentEl.innerText.trim();
    const text     = original.substring(0, 500);
    if (!text) return;

    this.disabled = true;
    status.textContent = 'Translating…';

    fetch(`https://api.mymemory.translated.net/get?q=${encodeURIComponent(text)}&langpair=en|${lang}`)
        .then(r => r.json())
        .then(data => {
            const translated = data.responseData?.translatedText;
            if (translated && data.responseStatus === 200) {
                contentEl.innerText = translated;
                status.innerHTML = `<span class="text-success">Translated · <a href="#" id="restoreOriginal">Restore original</a></span>`;
                document.getElementById('restoreOriginal').addEventListener('click', function (e) {
                    e.preventDefault();
                    contentEl.innerText = original;
                    status.textContent = '';
                    document.getElementById('translateBtn').disabled = false;
                });
            } else {
                status.textContent = 'Translation failed. Try again.';
                document.getElementById('translateBtn').disabled = false;
            }
        })
        .catch(() => {
            status.textContent = 'Service unavailable.';
            document.getElementById('translateBtn').disabled = false;
        });
});

// ── Chatbot ───────────────────────────────────────────────
document.getElementById('chatToggle').addEventListener('click', () => {
    const chatBox = document.getElementById('chatBox');
    chatBox.style.display = chatBox.style.display === 'none' ? 'flex' : 'none';
    if (chatBox.style.display === 'flex' && document.getElementById('chatMessages').children.length === 0) {
        appendMessage('bot', 'Hi! I\'m the AgriCloud assistant. Ask me anything about farming.');
    }
});

document.getElementById('chatSend').addEventListener('click', sendMessage);
document.getElementById('chatInput').addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); sendMessage(); }
});

function appendMessage(role, text) {
    const msgs   = document.getElementById('chatMessages');
    const div    = document.createElement('div');
    div.style.cssText = `margin-bottom:10px;display:flex;${role === 'user' ? 'justify-content:flex-end' : ''}`;
    const bubble = document.createElement('div');
    bubble.style.cssText = `max-width:78%;padding:9px 13px;border-radius:${role === 'user' ? '14px 14px 4px 14px' : '14px 14px 14px 4px'};font-size:.875rem;line-height:1.5;${role === 'user' ? 'background:#77b81e;color:#fff' : 'background:#f0f4e8;color:#1a2e0a'}`;
    bubble.textContent = text;
    div.appendChild(bubble);
    msgs.appendChild(div);
    msgs.scrollTop = msgs.scrollHeight;
}

async function sendMessage() {
    const input = document.getElementById('chatInput');
    const btn   = document.getElementById('chatSend');
    const msgs  = document.getElementById('chatMessages');
    const text  = input.value.trim();
    if (!text) return;
    input.value = '';
    btn.disabled = true;
    appendMessage('user', text);

    const typing = document.createElement('div');
    typing.style.cssText = 'margin-bottom:10px;color:#aaa;font-size:.8rem;font-style:italic';
    typing.textContent = 'Typing…';
    msgs.appendChild(typing);
    msgs.scrollTop = msgs.scrollHeight;

    try {
        const res  = await fetch('/blog/chatbot', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ message: text }),
        });
        const data = await res.json();
        typing.remove();
        appendMessage('bot', data.reply || 'Sorry, I could not answer that.');
    } catch {
        typing.remove();
        appendMessage('bot', 'Service unavailable right now.');
    }
    btn.disabled = false;
}
</script>

<div id="chatToggle" style="position:fixed;bottom:28px;right:28px;z-index:1050;width:52px;height:52px;border-radius:50%;background:#77b81e;color:#fff;display:flex;align-items:center;justify-content:center;cursor:pointer;box-shadow:0 4px 18px rgba(0,0,0,.2);font-size:1.4rem" title="AgriCloud Assistant">
    <i class="bi bi-chat-dots-fill"></i>
</div>
<div id="chatBox" style="display:none;position:fixed;bottom:90px;right:28px;z-index:1050;width:320px;height:420px;background:#fff;border-radius:16px;box-shadow:0 8px 32px rgba(0,0,0,.15);flex-direction:column;overflow:hidden">
    <div style="background:linear-gradient(135deg,#1a3a08,#2d5c10);padding:14px 18px;color:#fff;font-weight:600;font-size:.95rem">
        <i class="bi bi-robot me-2"></i>AgriCloud Assistant
    </div>
    <div id="chatMessages" style="flex:1;overflow-y:auto;padding:14px;background:#fafcf7"></div>
    <div style="padding:10px 12px;border-top:1px solid #eee;display:flex;gap:8px">
        <input id="chatInput" type="text" placeholder="Ask about farming…" style="flex:1;border:1.5px solid #dde8cc;border-radius:8px;padding:8px 12px;font-size:.85rem;outline:none">
        <button id="chatSend" style="background:#77b81e;color:#fff;border:none;border-radius:8px;padding:8px 14px;font-weight:600;cursor:pointer">
            <i class="bi bi-send-fill"></i>
        </button>
    </div>
</div>
{% endblock %}

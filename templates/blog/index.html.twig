{% extends 'base.html.twig' %}
{% block title %}Blog — AgriCloud{% endblock %}

{% block stylesheets %}
<style>
.post-card{border-radius:14px;border:none;box-shadow:0 2px 10px rgba(0,0,0,.07);transition:transform .15s,box-shadow .15s;overflow:hidden}
.post-card:hover{transform:translateY(-3px);box-shadow:0 6px 20px rgba(0,0,0,.12)}
.post-img{height:180px;object-fit:cover;width:100%}
.post-img-placeholder{height:180px;background:linear-gradient(135deg,#d1e7dd,#a3cfbb);display:flex;align-items:center;justify-content:center;font-size:3rem;color:#198754}
.category-pill{cursor:pointer;border-radius:20px;padding:4px 14px;font-size:.8rem;border:1px solid #dee2e6;background:#fff;transition:all .15s;text-decoration:none;color:#495057}
.category-pill:hover,.category-pill.active{background:#198754;color:#fff;border-color:#198754}
</style>
{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0"><i class="bi bi-journal-richtext me-2"></i>Blog</h5>
    <div class="d-flex gap-2">
        <a href="{{ path('blog_my_posts') }}" class="btn btn-outline-success btn-sm"><i class="bi bi-pencil-square me-1"></i>My Posts</a>
        <a href="{{ path('blog_new') }}" class="btn btn-success btn-sm"><i class="bi bi-plus-lg me-1"></i>Write Post</a>
    </div>
</div>

<form method="get" class="mb-3">
    <div class="d-flex gap-2 mb-3" style="max-width:480px">
        <input type="text" name="q" value="{{ q }}" class="form-control form-control-sm" placeholder="Search posts…">
        <input type="hidden" name="category" value="{{ category }}">
        <button class="btn btn-outline-secondary btn-sm"><i class="bi bi-search"></i></button>
        {% if q or category %}<a href="{{ path('blog_index') }}" class="btn btn-outline-danger btn-sm"><i class="bi bi-x"></i></a>{% endif %}
    </div>
</form>
<div class="d-flex gap-2 flex-wrap mb-4">
    <a href="{{ path('blog_index', {q: q}) }}" class="category-pill {{ category == '' ? 'active' : '' }}">All</a>
    {% for label in ['News','Farming Guide','Tips & Tricks','Technology','Market','Other'] %}
        <a href="{{ path('blog_index', {q: q, category: label}) }}" class="category-pill {{ category == label ? 'active' : '' }}">{{ label }}</a>
    {% endfor %}
</div>

{% if pagination.totalItemCount == 0 %}
<div class="text-center text-muted py-5">
    <i class="bi bi-journal-richtext" style="font-size:3rem;opacity:.3"></i>
    <p class="mt-2">No posts found.</p>
</div>
{% else %}
<div class="row g-3">
    {% for post in pagination %}
    <div class="col-md-4">
        <div class="card post-card h-100">
            {% if post.image %}
                <img src="{{ asset('uploads/posts/' ~ post.image) }}" class="post-img" alt="{{ post.title }}">
            {% else %}
                <div class="post-img-placeholder"><i class="bi bi-journal-text"></i></div>
            {% endif %}
            <div class="card-body d-flex flex-column">
                <div class="d-flex justify-content-between align-items-start mb-1">
                    <h6 class="fw-bold mb-0 flex-grow-1 me-2">{{ post.title }}</h6>
                    {% if post.category %}
                        <span class="badge bg-light text-dark border small text-nowrap">{{ post.category }}</span>
                    {% endif %}
                </div>
                <p class="text-muted small mb-2 flex-grow-1">
                    {{ (post.excerpt ?? post.content)|slice(0,100) }}{% if (post.excerpt ?? post.content)|length > 100 %}…{% endif %}
                </p>
                {% if post.tags %}
                <div class="mb-2">
                    {% for tag in post.tags %}
                        <span class="badge bg-light text-muted border me-1 small">#{{ tag }}</span>
                    {% endfor %}
                </div>
                {% endif %}
                <div class="d-flex justify-content-between align-items-center mt-auto text-muted small">
                    <span><i class="bi bi-person me-1"></i>{{ post.user.name }}</span>
                    <span><i class="bi bi-eye me-1"></i>{{ post.views }}</span>
                </div>
                <div class="text-muted small mt-1"><i class="bi bi-calendar me-1"></i>{{ post.publishedAt ? post.publishedAt|date('d M Y') : '—' }}</div>
            </div>
            <div class="card-footer bg-white border-0 pb-3">
                <a href="{{ path('blog_show', {slug: post.slug}) }}" class="btn btn-success btn-sm w-100">
                    <i class="bi bi-book me-1"></i>Read Post
                </a>
            </div>
        </div>
    </div>
    {% endfor %}
</div>

{% if pagination.pageCount > 1 %}
<div class="d-flex justify-content-center mt-4">
    {{ knp_pagination_render(pagination) }}
</div>
{% endif %}
{% endif %}
{% endblock %}

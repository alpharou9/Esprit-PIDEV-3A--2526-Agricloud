{% extends 'base.html.twig' %}
{% block title %}Comment Moderation — AgriCloud{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0"><i class="bi bi-chat-dots me-2"></i>Comment Moderation</h5>
    <a href="{{ path('blog_index') }}" class="btn btn-outline-secondary btn-sm"><i class="bi bi-journal-richtext me-1"></i>Blog</a>
</div>

<form method="get" class="d-flex gap-2 mb-4">
    <select name="status" class="form-select form-select-sm" style="max-width:180px">
        <option value="">All statuses</option>
        <option value="pending"  {{ status == 'pending'  ? 'selected' : '' }}>Pending</option>
        <option value="approved" {{ status == 'approved' ? 'selected' : '' }}>Approved</option>
        <option value="rejected" {{ status == 'rejected' ? 'selected' : '' }}>Rejected</option>
    </select>
    <button class="btn btn-outline-secondary btn-sm"><i class="bi bi-filter"></i> Filter</button>
    {% if status %}<a href="{{ path('blog_admin_comments') }}" class="btn btn-outline-danger btn-sm"><i class="bi bi-x"></i></a>{% endif %}
</form>

{% if pagination.totalItemCount == 0 %}
<div class="text-center text-muted py-5">
    <i class="bi bi-chat-slash" style="font-size:3rem;opacity:.3"></i>
    <p class="mt-2">No comments found.</p>
</div>
{% else %}
<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Comment</th>
                    <th>Author</th>
                    <th>Post</th>
                    <th>Status</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for comment in pagination %}
                <tr>
                    <td class="text-muted small">{{ comment.id }}</td>
                    <td style="max-width:280px">
                        <span class="small">{{ comment.content|slice(0,100) }}{% if comment.content|length > 100 %}…{% endif %}</span>
                    </td>
                    <td class="small fw-semibold">{{ comment.user.name }}</td>
                    <td class="small">
                        <a href="{{ path('blog_show', {slug: comment.post.slug}) }}" class="text-decoration-none text-success">
                            {{ comment.post.title|slice(0,40) }}{% if comment.post.title|length > 40 %}…{% endif %}
                        </a>
                    </td>
                    <td>
                        {% set sc = {pending:'warning',approved:'success',rejected:'danger',deleted:'secondary'} %}
                        <span class="badge bg-{{ sc[comment.status] ?? 'secondary' }} {% if comment.status == 'pending' %}text-dark{% endif %}">{{ comment.status|capitalize }}</span>
                    </td>
                    <td class="text-muted small">{{ comment.createdAt ? comment.createdAt|date('d M Y') : '—' }}</td>
                    <td>
                        <div class="d-flex gap-1">
                            {% if comment.status != 'approved' %}
                            <form method="post" action="{{ path('comment_approve', {id: comment.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('approve_comment_' ~ comment.id) }}">
                                <button class="btn btn-sm btn-success" title="Approve"><i class="bi bi-check-lg"></i></button>
                            </form>
                            {% endif %}
                            {% if comment.status != 'rejected' %}
                            <form method="post" action="{{ path('comment_reject', {id: comment.id}) }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('reject_comment_' ~ comment.id) }}">
                                <button class="btn btn-sm btn-danger" title="Reject"><i class="bi bi-x-lg"></i></button>
                            </form>
                            {% endif %}
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% if pagination.pageCount > 1 %}
<div class="d-flex justify-content-center mt-4">
    {{ knp_pagination_render(pagination) }}
</div>
{% endif %}
{% endif %}
{% endblock %}

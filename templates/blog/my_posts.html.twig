{% extends 'base.html.twig' %}
{% block title %}My Posts — AgriCloud{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0"><i class="bi bi-pencil-square me-2"></i>{{ is_granted('ROLE_ADMIN') ? 'All Posts' : 'My Posts' }}</h5>
    <a href="{{ path('blog_new') }}" class="btn btn-success btn-sm"><i class="bi bi-plus-lg me-1"></i>Write Post</a>
</div>

<form method="get" class="d-flex gap-2 mb-4 flex-wrap" style="max-width:600px">
    <input type="text" name="q" value="{{ q }}" class="form-control form-control-sm" placeholder="Search by title…" style="max-width:260px">
    {% if is_granted('ROLE_ADMIN') %}
    <select name="status" class="form-select form-select-sm" style="max-width:160px">
        <option value="">All statuses</option>
        <option value="draft" {{ status == 'draft' ? 'selected' : '' }}>Draft</option>
        <option value="published" {{ status == 'published' ? 'selected' : '' }}>Published</option>
        <option value="unpublished" {{ status == 'unpublished' ? 'selected' : '' }}>Unpublished</option>
    </select>
    {% endif %}
    <button class="btn btn-outline-secondary btn-sm"><i class="bi bi-search"></i></button>
    {% if q or status %}<a href="{{ path('blog_my_posts') }}" class="btn btn-outline-danger btn-sm"><i class="bi bi-x"></i></a>{% endif %}
</form>

{% if pagination.totalItemCount == 0 %}
<div class="text-center text-muted py-5">
    <i class="bi bi-journal-x" style="font-size:3rem;opacity:.3"></i>
    <p class="mt-2">No posts yet. <a href="{{ path('blog_new') }}">Write your first post →</a></p>
</div>
{% else %}
<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Title</th>
                    <th>Category</th>
                    {% if is_granted('ROLE_ADMIN') %}<th>Author</th>{% endif %}
                    <th>Status</th>
                    <th>Views</th>
                    <th>Comments</th>
                    <th>Date</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                {% for post in pagination %}
                <tr>
                    <td class="fw-semibold">
                        <a href="{{ path('blog_show', {slug: post.slug}) }}" class="text-decoration-none text-dark">{{ post.title }}</a>
                    </td>
                    <td>
                        {% if post.category %}<span class="badge bg-light text-dark border">{{ post.category }}</span>{% else %}<span class="text-muted">—</span>{% endif %}
                    </td>
                    {% if is_granted('ROLE_ADMIN') %}
                    <td class="text-muted small">{{ post.user.name }}</td>
                    {% endif %}
                    <td>
                        {% set sc = {draft:'secondary',published:'success',unpublished:'warning'} %}
                        <span class="badge bg-{{ sc[post.status] ?? 'secondary' }} {% if post.status == 'unpublished' %}text-dark{% endif %}">{{ post.status|capitalize }}</span>
                    </td>
                    <td class="text-muted small"><i class="bi bi-eye me-1"></i>{{ post.views }}</td>
                    <td class="text-muted small"><i class="bi bi-chat me-1"></i>{{ post.approvedComments|length }}</td>
                    <td class="text-muted small">{{ post.createdAt ? post.createdAt|date('d M Y') : '—' }}</td>
                    <td>
                        <div class="d-flex gap-1">
                            <a href="{{ path('blog_edit', {id: post.id}) }}" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                            <form method="post" action="{{ path('blog_delete', {id: post.id}) }}" onsubmit="return confirm('Delete this post?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_post_' ~ post.id) }}">
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% if pagination.pageCount > 1 %}
<div class="d-flex justify-content-center mt-4">
    {{ knp_pagination_render(pagination) }}
</div>
{% endif %}
{% endif %}
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Farms - AgriCloud{% endblock %}

{% block body %}
<style>
    .farm-card {
        transition: all 0.3s ease;
        border: none;
        border-radius: 15px;
        overflow: hidden;
    }
    .farm-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.1) !important;
    }
    .farm-image-container {
        height: 220px;
        background-color: #f8f9fa;
        overflow: hidden;
        position: relative;
    }
    .farm-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .status-badge {
        position: absolute;
        top: 15px;
        right: 15px;
        padding: 8px 15px;
        border-radius: 50px;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.7rem;
        letter-spacing: 1px;
    }
</style>

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold text-success">Farms</h1>
        <p class="lead text-muted">Explore our verified agricultural ecosystem and connect with local producers.</p>
        <div class="mx-auto bg-success" style="height: 4px; width: 60px; border-radius: 2px;"></div>
    </div>

    <div class="row g-4">
        {% for farm in farms %}
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 farm-card shadow-sm">
                    {# Farm Image & Status #}
                    <div class="farm-image-container">
                        {% if farm.image %}
        {# Update the path to point to your uploads folder #}
        <img src="{{ asset('uploads/farms/' ~ farm.image) }}" class="farm-image" alt="{{ farm.name }}">
    {% else %}
        <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted bg-light">
            <i class="bi bi-tree-fill display-4"></i>
            <small class="mt-2">No image available</small>
        </div>
    {% endif %}
                        <span class="status-badge bg-success text-white shadow">
                            <i class="bi bi-patch-check-fill me-1"></i> Verified
                        </span>
                    </div>

                    <div class="card-body p-4">
                        <div class="mb-2">
                            <span class="badge bg-light text-success border border-success-subtle rounded-pill">
                                {{ farm.farmType }}
                            </span>
                        </div>
                        
                        <h4 class="card-title fw-bold mb-3">{{ farm.name }}</h4>
                        
                        <div class="d-flex align-items-center mb-2 text-muted">
                            <i class="bi bi-geo-alt-fill text-danger me-2"></i>
                            <span>{{ farm.location }}</span>
                        </div>

                        <div class="d-flex align-items-center mb-4 text-muted">
                            <i class="bi bi-arrows-fullscreen text-primary me-2"></i>
                            <span>{{ farm.area }} Hectares</span>
                        </div>

                        <p class="card-text text-secondary mb-4">
                            {{ farm.description|length > 110 ? farm.description|slice(0, 110) ~ '...' : farm.description }}
                        </p>

                        <div class="d-grid">
                            <a href="{{ path('app_farm_show', {'id': farm.id}) }}" class="btn btn-success btn-lg shadow-sm">
                                View Full Details
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center py-5">
                <div class="card p-5 border-dashed bg-light">
                    <i class="bi bi-search display-1 text-muted"></i>
                    <h3 class="mt-4">No farms found</h3>
                    <p class="text-muted">We couldn't find any approved farms at the moment. Please check back later.</p>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
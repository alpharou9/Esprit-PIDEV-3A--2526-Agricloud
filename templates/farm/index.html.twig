{% extends 'base.html.twig' %}

{% block title %}Farm index{% endblock %}

{% block body %}
    <h1>Farm index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Location</th>
                <th>Latidude</th>
                <th>Longitude</th>
                <th>Area</th>
                <th>Farm_type</th>
                <th>Description</th>
                <th>Image</th>
                <th>Status</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for farm in farms %}
            <tr>
                <td>{{ farm.id }}</td>
                <td>{{ farm.name }}</td>
                <td>{{ farm.location }}</td>
                <td>{{ farm.latitude }}</td>
                <td>{{ farm.longitude }}</td>
                <td>{{ farm.area }}</td>
                <td>{{ farm.farmType }}</td>
                <td>{{ farm.description }}</td>
                <td>{{ farm.image }}</td>
                <td>{{ farm.status }}</td>
                <td>
                    <a href="{{ path('app_farm_show', {'id': farm.id}) }}">show</a>
                    <a href="{{ path('app_farm_edit', {'id': farm.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="11">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_farm_new') }}">Create new</a>
{% endblock %}

{% extends 'base.html.twig' %}
{% block title %}New Farm — AgriCloud{% endblock %}

{% block body %}
<div class="d-flex align-items-center gap-2 mb-4">
    <a href="{{ path('farm_index') }}" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h5 class="fw-bold mb-0">Add New Farm</h5>
</div>

<div class="card border-0 shadow-sm rounded-4" style="max-width:680px">
    <div class="card-body p-4">
        {{ form_start(form, {attr: {enctype: 'multipart/form-data', novalidate: 'novalidate'}}) }}

        <div class="row g-3">
            <div class="col-md-8">
                <div class="mb-3">
                    {{ form_label(form.name) }}
                    {{ form_widget(form.name) }}
                    {{ form_errors(form.name) }}
                    <div class="form-text">Required · 2–150 characters</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="mb-3">
                    {{ form_label(form.farmType) }}
                    {{ form_widget(form.farmType) }}
                    {{ form_errors(form.farmType) }}
                    <div class="form-text">Optional</div>
                </div>
            </div>
        </div>

        <div class="mb-3">
            {{ form_label(form.location) }}
            {{ form_widget(form.location) }}
            {{ form_errors(form.location) }}
            <div class="form-text">Required · City, region or address</div>
        </div>

        <div class="mb-3">
            {{ form_label(form.area) }}
            {{ form_widget(form.area) }}
            {{ form_errors(form.area) }}
            <div class="form-text">Optional · Positive number · Max 999,999 ha</div>
        </div>

        {# Map coordinate picker #}
        <div class="mb-3">
            <label class="form-label fw-semibold"><i class="bi bi-geo-alt me-1"></i>Coordinates — click the map to set</label>
            <div id="farm-map" class="rounded-3 border mb-2" style="height:260px"></div>
            <button type="button" id="btn-geolocate" class="btn btn-outline-secondary btn-sm mb-2">
                <i class="bi bi-crosshair me-1"></i>Use my location
            </button>
            <div class="row g-2">
                <div class="col-md-6">
                    {{ form_label(form.latitude) }}
                    {{ form_widget(form.latitude, {attr: {id: 'farm_latitude', step: 'any', placeholder: 'e.g. 36.8065'}}) }}
                    {{ form_errors(form.latitude) }}
                </div>
                <div class="col-md-6">
                    {{ form_label(form.longitude) }}
                    {{ form_widget(form.longitude, {attr: {id: 'farm_longitude', step: 'any', placeholder: 'e.g. 10.1815'}}) }}
                    {{ form_errors(form.longitude) }}
                </div>
            </div>
        </div>

        <div class="mb-3">
            {{ form_label(form.description) }}
            {{ form_widget(form.description) }}
            {{ form_errors(form.description) }}
            <div class="form-text">Optional · Brief description of the farm</div>
        </div>

        <div class="mb-4">
            {{ form_label(form.imageFile) }}
            {{ form_widget(form.imageFile) }}
            {{ form_errors(form.imageFile) }}
            <div class="form-text">Optional · Max 2MB — JPG, PNG or WEBP</div>
        </div>

        <div class="alert alert-info small mb-4">
            <i class="bi bi-info-circle me-1"></i>
            Your farm will be reviewed by an administrator before being approved.
        </div>

        <button type="submit" class="btn btn-success">
            <i class="bi bi-check-lg me-1"></i> Submit Farm
        </button>
        <a href="{{ path('farm_index') }}" class="btn btn-outline-secondary ms-2">Cancel</a>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function () {
    var latInput = document.getElementById('farm_latitude');
    var lngInput = document.getElementById('farm_longitude');
    var initLat = parseFloat(latInput.value) || 36.8;
    var initLng = parseFloat(lngInput.value) || 10.18;

    var map = L.map('farm-map').setView([initLat, initLng], 6);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap contributors'
    }).addTo(map);

    var marker = null;

    function setMarker(lat, lng) {
        lat = parseFloat(lat.toFixed(6));
        lng = parseFloat(lng.toFixed(6));
        latInput.value = lat;
        lngInput.value = lng;
        if (marker) { marker.setLatLng([lat, lng]); }
        else { marker = L.marker([lat, lng]).addTo(map); }
    }

    if (latInput.value && lngInput.value) {
        setMarker(initLat, initLng);
    }

    map.on('click', function (e) { setMarker(e.latlng.lat, e.latlng.lng); });

    [latInput, lngInput].forEach(function (inp) {
        inp.addEventListener('change', function () {
            var lat = parseFloat(latInput.value);
            var lng = parseFloat(lngInput.value);
            if (!isNaN(lat) && !isNaN(lng)) { setMarker(lat, lng); map.setView([lat, lng], 10); }
        });
    });

    document.getElementById('btn-geolocate').addEventListener('click', function () {
        if (!navigator.geolocation) { alert('Geolocation not supported.'); return; }
        navigator.geolocation.getCurrentPosition(function (pos) {
            setMarker(pos.coords.latitude, pos.coords.longitude);
            map.setView([pos.coords.latitude, pos.coords.longitude], 12);
        }, function () { alert('Could not get your location.'); });
    });
})();
</script>
{% endblock %}

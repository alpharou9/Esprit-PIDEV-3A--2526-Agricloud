{% extends 'base.html.twig' %}

{% block title %}My Farms Dashboard - AgriCloud{% endblock %}

{% block body %}
<style>
    :root {
        --agri-dark: #1d3108; /* Dark forest green header */
        --agri-lime: #82b414; /* AgriCloud primary green */
        --agri-bg: #f4f7f2;   /* Soft background tint */
        --agri-cyan: #00bcd4; /* Color for the fields button */
    }

    body { background-color: var(--agri-bg); }

    .agri-card {
        background: white;
        border-radius: 20px;
        border: none;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        margin-bottom: 1.5rem;
    }

    .agri-banner {
        background-color: var(--agri-dark);
        height: 180px;
        padding: 2rem;
        color: white;
        border-radius: 20px 20px 0 0;
    }

    .agri-status-box {
        background: white;
        padding: 1.2rem;
        border-radius: 15px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.08);
        min-width: 140px;
        text-align: center;
        margin-top: -45px;
        z-index: 5;
    }

    .farm-item-row {
        background: white;
        border: 1px solid #eee;
        border-radius: 16px;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
        padding: 1.2rem;
        margin-bottom: 1rem;
    }

    .farm-item-row:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(0,0,0,0.06);
        border-color: var(--agri-lime);
    }

    .farm-avatar {
        width: 65px;
        height: 65px;
        border-radius: 14px;
        object-fit: cover;
    }

    .btn-fields {
        background-color: var(--agri-cyan);
        color: white;
        border-radius: 50px;
        font-weight: 700;
        font-size: 0.85rem;
        padding: 8px 20px;
        border: none;
        transition: 0.2s;
        text-decoration: none;
    }

    .btn-fields:hover { background-color: #00acc1; color: white; transform: scale(1.05); }

    .action-circle {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #e0e0e0;
        background: #fff;
        color: #555;
        transition: 0.2s;
    }

    .action-circle:hover { background: #f8f9fa; color: var(--agri-lime); border-color: var(--agri-lime); }
</style>

<div class="container py-4">
    <div class="agri-card">
        <div class="agri-banner d-flex justify-content-between align-items-start">
            <div>
                <h1 class="fw-bold h2 mb-1">My Farms Dashboard</h1>
                <p class="opacity-75">Manage your fields and monitor agricultural production.</p>
            </div>
            <a href="{{ path('app_farm_new') }}" class="btn btn-light fw-bold rounded-pill px-4 shadow-sm" style="color: var(--agri-dark);">
                <i class="bi bi-plus-lg me-2"></i>Add New Farm
            </a>
        </div>
        
        <div class="d-flex gap-4 px-4 mb-4">
            <div class="agri-status-box">
                <div class="text-muted small">Status</div>
                <div class="fw-bold text-success">Active</div>
            </div>
            <div class="agri-status-box">
                <div class="text-muted small">Total Farms</div>
                <div class="fw-bold">{{ farms|length }}</div>
            </div>
        </div>
    </div>

    <div class="agri-card p-4">
        <h5 class="fw-bold mb-4 text-dark">Your Registered Farms</h5>

        {% for farm in farms %}
            <div class="farm-item-row">
                <div class="d-flex align-items-center" style="flex: 2;">
                    <div class="me-3">
                        {% if farm.image %}
                            <img src="{{ asset('uploads/farms/' ~ farm.image) }}" class="farm-avatar shadow-sm">
                        {% else %}
                            <div class="farm-avatar d-flex align-items-center justify-content-center bg-light border">
                                <i class="bi bi-image text-muted fs-4"></i>
                            </div>
                        {% endif %}
                    </div>
                    <div>
                        <h6 class="mb-0 fw-bold text-dark">{{ farm.name }}</h6>
                        <div class="text-muted small">
                            <i class="bi bi-geo-alt me-1"></i>{{ farm.location }} • {{ farm.area }} ha
                        </div>
                    </div>
                </div>

                <div style="flex: 1;" class="text-center">
                    <a href="{{ path('app_field_index', {'farm_id': farm.id}) }}" class="btn-fields shadow-sm d-inline-flex align-items-center">
                        <i class="bi bi-grid-3x3-gap-fill me-2"></i>
                        {{ farm.fields|length }} Fields
                    </a>
                </div>

                <div style="flex: 1;" class="text-center">
                    {% if farm.status == 'approved' %}
                        <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3 py-2">
                            Approved & Published
                        </span>
                    {% else %}
                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle rounded-pill px-3 py-2">
                            Pending Review
                        </span>
                    {% endif %}
                </div>

                <div style="flex: 1;" class="text-end d-flex justify-content-end gap-2">
                    <a href="{{ path('app_farm_show', {'id': farm.id}) }}" class="action-circle" title="View Details">
                        <i class="bi bi-eye"></i>
                    </a>
                    <a href="{{ path('app_farm_edit', {'id': farm.id}) }}" class="action-circle" title="Edit Farm">
                        <i class="bi bi-pencil"></i>
                    </a>
                </div>
            </div>
        {% else %}
            <div class="text-center py-5">
                <div class="mb-3 text-muted opacity-50">
                    <i class="bi bi-tree display-1"></i>
                </div>
                <h5 class="text-muted">No farms found. Start by adding your first one!</h5>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
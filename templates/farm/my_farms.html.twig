{% extends 'base.html.twig' %}

{% block title %}My Farms{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2">My Farms</h1>
    <a href="{{ path('app_farm_new') }}" class="btn btn-success shadow-sm">
        <i class="bi bi-plus-lg"></i> + Add New Farm
    </a>
</div>

<div class="row">
    {% for farm in farms %}
        <div class="col-md-6 col-lg-4 mb-4">
            <div class="card h-100 shadow-sm border-0 border-top border-4 {% if farm.status == 'approved' %}border-success{% else %}border-warning{% endif %}">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h5 class="card-title fw-bold mb-0">{{ farm.name }}</h5>
                        <span class="badge {% if farm.status == 'approved' %}bg-success{% else %}bg-warning text-dark{% endif %}">
                            {{ farm.status|capitalize }}
                        </span>
                    </div>
                    
                    <p class="text-muted small mb-3">
                        <i class="bi bi-geo-alt"></i> 📍 {{ farm.location }}
                    </p>

                    <div class="row mb-3">
                        <div class="col-6">
                            <small class="text-muted d-block">Area</small>
                            <strong>{{ farm.area }} ha</strong>
                        </div>
                        <div class="col-6">
                            <small class="text-muted d-block">Type</small>
                            <strong>{{ farm.farmType }}</strong>
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        {# Button to see the list of fields for this specific farm #}
                        <a href="{{ path('app_farm_show', {'id': farm.id}) }}" class="btn btn-info text-white btn-sm d-flex justify-content-between align-items-center">
                            <span>🌾 View Fields</span>
                            <span class="badge bg-white text-info">{{ farm.fields|length }}</span>
                        </a>
                        
                        <div class="btn-group w-100">
                            <a href="{{ path('app_farm_edit', {'id': farm.id}) }}" class="btn btn-outline-primary btn-sm">Update</a>
                            
                            {# The Delete Button #}
                            <form method="post" action="{{ path('app_farm_delete', {'id': farm.id}) }}" onsubmit="return confirm('Are you sure you want to delete this farm? This will also remove all associated fields.');" style="display: contents;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ farm.id) }}">
                                <button class="btn btn-outline-danger btn-sm" style="border-top-left-radius: 0; border-bottom-left-radius: 0;">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0">
                    <small class="text-muted">Farm ID: #{{ farm.id }}</small>
                </div>
            </div>
        </div>
    {% else %}
        <div class="col-12 text-center py-5">
            <div class="p-5 bg-light rounded-3">
                <i class="bi bi-tree text-muted" style="font-size: 3rem;"></i>
                <h3 class="mt-3">No farms yet</h3>
                <p class="text-muted">Register your first farm to start managing your fields.</p>
                <a href="{{ path('app_farm_new') }}" class="btn btn-primary">Get Started</a>
            </div>
        </div>
    {% endfor %}
</div>
{% endblock %}
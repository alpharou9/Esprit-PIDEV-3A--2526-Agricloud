<div class="mb-3">
    <label class="form-label fw-semibold">
        <i class="bi bi-geo-alt-fill text-success me-1"></i>Select the exact farm location
    </label>
    <div id="farmMap" class="farm-map mb-2"></div>
    <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
        <button type="button" id="locateMe" class="btn btn-sm btn-outline-success">
            <i class="bi bi-crosshair me-1"></i>Use my location
        </button>
        <span id="farmMapStatus" class="small text-muted">Click on the map to drop a pin.</span>
    </div>
    <div class="row g-3">
        <div class="col-md-6">
            {{ form_label(form.latitude) }}
            {{ form_widget(form.latitude) }}
            {{ form_errors(form.latitude) }}
            <div class="form-text">Filled automatically when you pin the farm.</div>
        </div>
        <div class="col-md-6">
            {{ form_label(form.longitude) }}
            {{ form_widget(form.longitude) }}
            {{ form_errors(form.longitude) }}
            <div class="form-text">You can still adjust the coordinates manually.</div>
        </div>
    </div>
</div>

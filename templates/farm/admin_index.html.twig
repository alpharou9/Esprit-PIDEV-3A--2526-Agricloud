{% extends 'base.html.twig' %}

{% block title %}Admin - Farm Management{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h2">Admin: Farm Management</h1>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Id</th>
                        <th>Name</th>
                        <th>Location</th>
                        <th>Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for farm in farms %}
                    <tr>
                        <td>{{ farm.id }}</td>
                        <td><strong>{{ farm.name }}</strong></td>
                        <td>{{ farm.location }}</td>
                        <td>
                            <span class="badge {{ farm.status == 'approved' ? 'bg-success' : 'bg-warning text-dark' }}">
                                {{ farm.status|upper }}
                            </span>
                        </td>
                        <td>
                            <div class="d-flex justify-content-center gap-2">
                                <a href="{{ path('app_farm_show', {'id': farm.id}) }}" class="btn btn-sm btn-outline-info">Show</a>
                                
                                {% if farm.status == 'pending' %}
                                    <form method="post" action="{{ path('app_farm_approve', {'id': farm.id}) }}" onsubmit="return confirm('Confirm approval?');">
                                        <button class="btn btn-sm btn-success">Approve</button>
                                    </form>
                                {% endif %}

                                {{ include('farm/_delete_form.html.twig') }}
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center py-4">No records found</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
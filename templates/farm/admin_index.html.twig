{% extends 'base.html.twig' %}

{% block title %}Admin Management - AgriCloud{% endblock %}

{% block body %}
<div class="pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2 text-primary">Farm Management Console</h1>
    <p class="text-muted">Reviewing all registered farms. Approved farms remain here for tracking.</p>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0">Global Farm List</h5>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width: 50px;">ID</th>
                    <th>Farm Name</th>
                    <th>Location</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for farm in farms %}
                {# Highlight pending rows to grab admin attention #}
                <tr class="{% if farm.status == 'pending' %}table-warning{% endif %}">
                    <td>{{ farm.id }}</td>
                    <td>
                        <strong>{{ farm.name }}</strong>
                        <br><small class="text-muted">{{ farm.area }} ha</small>
                    </td>
                    <td>{{ farm.location }}</td>
                    <td>{{ farm.farmType }}</td>
                    <td>
                        {% if farm.status == 'approved' %}
                            <span class="badge bg-success shadow-sm">
                                <i class="bi bi-check-circle"></i> Approved
                            </span>
                        {% else %}
                            <span class="badge bg-warning text-dark shadow-sm">
                                <i class="bi bi-clock"></i> Pending
                            </span>
                        {% endif %}
                    </td>
                    <td class="text-end">
                        <div class="btn-group shadow-sm">
                            {# Approval Action: Only visible if pending #}
                            {% if farm.status == 'pending' %}
                                <form method="post" action="{{ path('app_farm_approve', {'id': farm.id}) }}" onsubmit="return confirm('Confirm approval for {{ farm.name }}?');" style="display:inline;">
                                    <button class="btn btn-sm btn-success">Approve</button>
                                </form>
                            {% endif %}

                            <a href="{{ path('app_farm_show', {'id': farm.id}) }}" class="btn btn-sm btn-outline-secondary">Details</a>

                            {# Delete Action #}
                            <form method="post" action="{{ path('app_farm_delete', {'id': farm.id}) }}?from=admin" onsubmit="return confirm('Are you sure you want to reject/delete this farm?');" style="display:inline;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ farm.id) }}">
                                <button class="btn btn-sm btn-outline-danger">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="text-center py-5">
                        <p class="text-muted mb-0">No farms have been registered yet.</p>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<div class="mt-4">
    <div class="row text-center">
        <div class="col-md-4">
            <div class="p-3 bg-light rounded border">
                <h6 class="text-muted mb-1">Total Farms</h6>
                <h3 class="fw-bold">{{ farms|length }}</h3>
            </div>
        </div>
        {# Example of filtering counts in Twig #}
        {% set pending_count = 0 %}
        {% for f in farms %}{% if f.status == 'pending' %}{% set pending_count = pending_count + 1 %}{% endif %}{% endfor %}
        <div class="col-md-4">
            <div class="p-3 bg-light rounded border">
                <h6 class="text-muted mb-1">Awaiting Review</h6>
                <h3 class="fw-bold text-warning">{{ pending_count }}</h3>
            </div>
        </div>
    </div>
</div>
{% endblock %}
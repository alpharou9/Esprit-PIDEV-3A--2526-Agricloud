{% extends 'base.html.twig' %}

{% block title %}Farm{% endblock %}

{% block body %}
    <h1>Farm</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ farm.id }}</td>
            </tr>
            <tr>
                <th>Name</th>
                <td>{{ farm.name }}</td>
            </tr>
            <tr>
                <th>Location</th>
                <td>{{ farm.location }}</td>
            </tr>
            <tr>
                <th>Area</th>
                <td>{{ farm.area }}</td>
            </tr>
            <tr>
                <th>FarmType</th>
                <td>{{ farm.farmType }}</td>
            </tr>
            <tr>
                <th>Description</th>
                <td>{{ farm.description }}</td>
            </tr>
            <tr>
                <th>Status</th>
                <td>{{ farm.status }}</td>
            </tr>
            <tr>
                <th>Nbfields</th>
                <td>{{ farm.nbfields }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_farm_index') }}">back to list</a>

    <a href="{{ path('app_farm_edit', {'id': farm.id}) }}">edit</a>

    {{ include('farm/_delete_form.html.twig') }}
{% endblock %}

{% extends 'base.html.twig' %}
{% block title %}{{ farm.name }} — AgriCloud{% endblock %}

{% block body %}
<div class="d-flex align-items-center gap-2 mb-4">
    <a href="{{ path('farm_index') }}" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i></a>
    <h5 class="fw-bold mb-0">{{ farm.name }}</h5>
    <span class="badge ms-1
        {% if farm.status == 'approved' %}bg-success
        {% elseif farm.status == 'pending' %}bg-warning text-dark
        {% elseif farm.status == 'rejected' %}bg-danger
        {% else %}bg-secondary{% endif %}">
        {{ farm.status|capitalize }}
    </span>
</div>

<div class="row g-4">
    {# Left: farm details #}
    <div class="col-md-5">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            {% if farm.image %}
                <img src="{{ asset('uploads/farms/' ~ farm.image) }}" class="w-100" style="height:220px;object-fit:cover" alt="{{ farm.name }}">
            {% else %}
                <div style="height:220px;background:linear-gradient(135deg,#d1e7dd,#a3cfbb);display:flex;align-items:center;justify-content:center;font-size:4rem;color:#198754">
                    <i class="bi bi-tree-fill"></i>
                </div>
            {% endif %}
            <div class="card-body p-4">
                <dl class="row mb-0">
                    <dt class="col-sm-5 text-muted">Owner</dt>
                    <dd class="col-sm-7">{{ farm.user.name }}</dd>

                    <dt class="col-sm-5 text-muted">Location</dt>
                    <dd class="col-sm-7">{{ farm.location }}</dd>

                    <dt class="col-sm-5 text-muted">Type</dt>
                    <dd class="col-sm-7">{{ farm.farmType ? farm.farmType|capitalize : '—' }}</dd>

                    <dt class="col-sm-5 text-muted">Area</dt>
                    <dd class="col-sm-7">{{ farm.area ? farm.area ~ ' ha' : '—' }}</dd>

                    {% if farm.latitude and farm.longitude %}
                    <dt class="col-sm-5 text-muted">Coordinates</dt>
                    <dd class="col-sm-7 small">{{ farm.latitude }}, {{ farm.longitude }}</dd>
                    {% endif %}

                    <dt class="col-sm-5 text-muted">Created</dt>
                    <dd class="col-sm-7 small text-muted">{{ farm.createdAt ? farm.createdAt|date('d M Y') : '—' }}</dd>

                    {% if farm.approvedBy %}
                    <dt class="col-sm-5 text-muted">Approved by</dt>
                    <dd class="col-sm-7 small">{{ farm.approvedBy.name }} — {{ farm.approvedAt|date('d M Y') }}</dd>
                    {% endif %}
                </dl>

                {% if farm.description %}
                <hr>
                <p class="text-muted small mb-0">{{ farm.description }}</p>
                {% endif %}
            </div>

            <div class="card-footer bg-white border-0 d-flex flex-wrap gap-2 pb-3 px-4">
                <a href="{{ path('farm_edit', {id: farm.id}) }}" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-pencil me-1"></i>Edit
                </a>

                {% if is_granted('ROLE_ADMIN') and farm.status == 'pending' %}
                <form method="post" action="{{ path('farm_approve', {id: farm.id}) }}" class="d-inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('approve_farm_' ~ farm.id) }}">
                    <button class="btn btn-success btn-sm"><i class="bi bi-check-lg me-1"></i>Approve</button>
                </form>
                <form method="post" action="{{ path('farm_reject', {id: farm.id}) }}" class="d-inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('reject_farm_' ~ farm.id) }}">
                    <button class="btn btn-danger btn-sm"><i class="bi bi-x-lg me-1"></i>Reject</button>
                </form>
                {% endif %}

                <form method="post" action="{{ path('farm_delete', {id: farm.id}) }}" class="d-inline ms-auto"
                      onsubmit="return confirm('Delete this farm and all its fields?')">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_farm_' ~ farm.id) }}">
                    <button class="btn btn-outline-danger btn-sm"><i class="bi bi-trash me-1"></i>Delete</button>
                </form>
            </div>
        </div>
    </div>

    {# Right: weather + map + fields #}
    <div class="col-md-7">

        {% if farm.latitude and farm.longitude %}
        {# Weather widget #}
        <div class="card border-0 shadow-sm rounded-4 mb-4">
            <div class="card-body p-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <i class="bi bi-cloud-sun-fill text-warning fs-5"></i>
                    <span class="fw-semibold">Current Weather</span>
                    <span class="text-muted small ms-1">at farm location</span>
                </div>
                <div id="weatherWidget">
                    <div class="text-muted small"><i class="bi bi-hourglass-split me-1"></i>Loading weather…</div>
                </div>
            </div>
        </div>

        {# Mini map #}
        <div class="card border-0 shadow-sm rounded-4 mb-4 overflow-hidden">
            <div id="farmShowMap" style="height:200px"></div>
        </div>
        {% endif %}

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h6 class="fw-bold mb-0"><i class="bi bi-grid me-2"></i>Fields ({{ farm.fields|length }})</h6>
            <a href="{{ path('field_new', {farmId: farm.id}) }}" class="btn btn-success btn-sm">
                <i class="bi bi-plus-lg me-1"></i> Add Field
            </a>
        </div>

        {% if farm.fields is empty %}
            <div class="text-center text-muted py-4 bg-light rounded-4">
                <i class="bi bi-grid" style="font-size:2rem;opacity:.4"></i>
                <p class="mt-2 small">No fields yet. Add your first field.</p>
            </div>
        {% else %}
            <div class="d-flex flex-column gap-3">
                {% for field in farm.fields %}
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-body py-3 px-4">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <div class="fw-semibold">{{ field.name }}</div>
                                <div class="d-flex gap-2 mt-1 flex-wrap">
                                    <span class="badge bg-light text-dark border small"><i class="bi bi-rulers me-1"></i>{{ field.area }} ha</span>
                                    {% if field.soilType %}<span class="badge bg-light text-dark border small">{{ field.soilType|capitalize }} soil</span>{% endif %}
                                    {% if field.cropType %}<span class="badge bg-light text-dark border small"><i class="bi bi-flower1 me-1"></i>{{ field.cropType }}</span>{% endif %}
                                    <span class="badge small
                                        {% if field.status == 'active' %}bg-success
                                        {% elseif field.status == 'fallow' %}bg-warning text-dark
                                        {% else %}bg-secondary{% endif %}">
                                        {{ field.status|capitalize }}
                                    </span>
                                </div>
                            </div>
                            <div class="d-flex gap-1">
                                <a href="{{ path('field_edit', {farmId: farm.id, id: field.id}) }}" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" action="{{ path('field_delete', {farmId: farm.id, id: field.id}) }}"
                                      onsubmit="return confirm('Delete field {{ field.name }}?')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete_field_' ~ field.id) }}">
                                    <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}

{% if farm.latitude and farm.longitude %}
{% block stylesheets %}{{ parent() }}<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>{% endblock %}
{% block javascripts %}
{{ parent() }}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
(function () {
    const lat = {{ farm.latitude }};
    const lng = {{ farm.longitude }};

    const map = L.map('farmShowMap', { zoomControl: true, dragging: true, scrollWheelZoom: false })
                  .setView([lat, lng], 13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap contributors'
    }).addTo(map);
    L.marker([lat, lng]).addTo(map).bindPopup('{{ farm.name|e('js') }}').openPopup();

    const WMO = {
        0:'Clear sky',1:'Mainly clear',2:'Partly cloudy',3:'Overcast',
        45:'Fog',48:'Icy fog',51:'Light drizzle',53:'Drizzle',55:'Heavy drizzle',
        61:'Light rain',63:'Rain',65:'Heavy rain',71:'Light snow',73:'Snow',75:'Heavy snow',
        80:'Rain showers',81:'Showers',82:'Heavy showers',95:'Thunderstorm',99:'Thunderstorm w/ hail'
    };
    const WMO_ICON = {
        0:'sun',1:'sun',2:'cloud-sun',3:'clouds',45:'cloud-fog',48:'cloud-fog',
        51:'cloud-drizzle',53:'cloud-drizzle',55:'cloud-drizzle',
        61:'cloud-rain',63:'cloud-rain',65:'cloud-rain-heavy',
        71:'cloud-snow',73:'cloud-snow',75:'cloud-snow',
        80:'cloud-rain',81:'cloud-rain',82:'cloud-rain-heavy',
        95:'cloud-lightning-rain',99:'cloud-lightning-rain'
    };

    fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lng}&current_weather=true`)
        .then(r => r.json())
        .then(data => {
            const w    = data.current_weather;
            const code = w.weathercode;
            const icon = WMO_ICON[code] || 'cloud';
            const desc = WMO[code]      || 'Unknown';
            document.getElementById('weatherWidget').innerHTML =
                `<div class="d-flex align-items-center gap-4 flex-wrap">
                    <div class="d-flex align-items-center gap-2">
                        <i class="bi bi-${icon}-fill" style="font-size:2rem;color:#f59e0b"></i>
                        <span style="font-size:2rem;font-weight:700">${w.temperature}°C</span>
                    </div>
                    <div>
                        <div class="fw-semibold">${desc}</div>
                        <div class="text-muted small">
                            <i class="bi bi-wind me-1"></i>${w.windspeed} km/h wind
                        </div>
                    </div>
                </div>`;
        })
        .catch(() => {
            document.getElementById('weatherWidget').innerHTML =
                '<span class="text-muted small">Weather unavailable</span>';
        });
})();
</script>
{% endblock %}
{% endif %}

{% extends 'base.html.twig' %}

{% block title %}Orders - AgriCloud{% endblock %}

{% block body %}
<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4">
    <div>
        <h3 class="fw-bold mb-1">Orders</h3>
        <p class="text-muted mb-0">Track customer orders with product, customer, and seller references.</p>
    </div>
    <a href="{{ path('order_new') }}" class="btn btn-success">
        <i class="bi bi-plus-circle me-1"></i>Add order
    </a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        <form method="get" class="row g-2 mb-4">
            <div class="col-md-10">
                <input type="text" name="q" value="{{ q }}" class="form-control" placeholder="Search by product, customer, seller, or status">
            </div>
            <div class="col-md-2 d-grid">
                <button class="btn btn-outline-success">Search</button>
            </div>
        </form>

        <div class="table-responsive">
            <table class="table align-middle">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Product</th>
                        <th>Customer</th>
                        <th>Seller</th>
                        <th>Total</th>
                        <th>Status</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for order in orders %}
                    <tr>
                        <td>#{{ order.id }}</td>
                        <td>
                            <div class="fw-semibold">{{ order.product ? order.product.name : 'N/A' }}</div>
                            <div class="text-muted small">{{ order.quantity }} x {{ order.unitPrice|number_format(2, '.', ' ') }}</div>
                        </td>
                        <td>{{ order.customer ? order.customer.name : 'N/A' }}</td>
                        <td>{{ order.seller ? order.seller.name : 'N/A' }}</td>
                        <td>{{ order.totalPrice|number_format(2, '.', ' ') }}</td>
                        <td>
                            <span class="badge text-bg-{{ order.status == 'delivered' ? 'success' : (order.status == 'pending' ? 'warning' : (order.status == 'cancelled' ? 'danger' : 'primary')) }}">
                                {{ order.status }}
                            </span>
                        </td>
                        <td class="text-end">
                            <a href="{{ path('order_edit', {id: order.id}) }}" class="btn btn-sm btn-outline-primary">Edit</a>
                            <form method="post" action="{{ path('order_delete', {id: order.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete_order_' ~ order.id) }}">
                                <button class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this order?')">Delete</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">No orders found.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}

{% set currentRoute = app.request.attributes.get('_route') ?? '' %}
{% set showMarketAssistant = currentRoute in ['market_index', 'my_products', 'product_show', 'product_new', 'product_edit', 'cart_index', 'cart_checkout', 'order_index', 'order_show'] %}

{% if showMarketAssistant %}
    <style>
        .market-assistant-widget{position:fixed;right:28px;bottom:28px;z-index:1085}
        .market-assistant-toggle{width:64px;height:64px;border:none;border-radius:22px;background:linear-gradient(135deg,#77b81e 0%,#4f7f15 100%);color:#fff;box-shadow:0 18px 34px rgba(44,81,12,.28);display:flex;align-items:center;justify-content:center;font-size:1.4rem;transition:transform .18s ease,box-shadow .18s ease}
        .market-assistant-toggle:hover{transform:translateY(-2px) scale(1.02);box-shadow:0 22px 40px rgba(44,81,12,.32)}
        .market-assistant-panel{position:absolute;right:0;bottom:82px;width:min(390px,calc(100vw - 32px));height:min(620px,calc(100vh - 120px));background:#fff;border:1px solid rgba(119,184,30,.15);border-radius:28px;overflow:hidden;display:none;flex-direction:column;box-shadow:0 26px 60px rgba(28,43,16,.2)}
        .market-assistant-panel.is-open{display:flex}
        .market-assistant-header{padding:1.15rem 1.2rem;background:linear-gradient(135deg,#77b81e 0%,#5d9318 100%);color:#fff;display:flex;align-items:flex-start;justify-content:space-between;gap:1rem}
        .market-assistant-header h5{margin:0 0 .25rem;font-size:1.2rem}
        .market-assistant-header p{margin:0;font-size:.93rem;opacity:.92;line-height:1.6}
        .market-assistant-close{border:none;background:rgba(255,255,255,.15);color:#fff;width:38px;height:38px;border-radius:12px;flex-shrink:0}
        .market-assistant-body{display:flex;flex-direction:column;flex:1;min-height:0;background:radial-gradient(circle at top right,rgba(119,184,30,.08),transparent 34%),#fbfcf8}
        .market-assistant-suggestions{padding:.95rem 1rem .3rem;display:flex;flex-wrap:wrap;gap:.55rem}
        .market-assistant-chip{border:none;border-radius:999px;padding:.5rem .8rem;background:#eef5e2;color:#3d5c18;font-weight:700;font-size:.84rem;box-shadow:inset 0 0 0 1px rgba(119,184,30,.14);transition:all .16s ease}
        .market-assistant-chip:hover{background:#77b81e;color:#fff}
        .market-assistant-messages{padding:1rem;display:flex;flex-direction:column;gap:.9rem;overflow-y:auto;flex:1}
        .market-assistant-message{display:flex;gap:.7rem;max-width:86%}
        .market-assistant-message.user{margin-left:auto;flex-direction:row-reverse}
        .market-assistant-avatar{width:38px;height:38px;border-radius:13px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
        .market-assistant-message.bot .market-assistant-avatar{background:#eaf4d7;color:#4d7219}
        .market-assistant-message.user .market-assistant-avatar{background:#183109;color:#fff}
        .market-assistant-bubble{padding:.9rem 1rem;border-radius:18px;font-size:.95rem;line-height:1.65;box-shadow:0 12px 24px rgba(30,47,16,.06)}
        .market-assistant-message.bot .market-assistant-bubble{background:#fff;border:1px solid #e5edd8;color:#2e4320;border-top-left-radius:8px}
        .market-assistant-message.user .market-assistant-bubble{background:linear-gradient(135deg,#77b81e 0%,#5f9818 100%);color:#fff;border-top-right-radius:8px}
        .market-assistant-form{padding:1rem;border-top:1px solid #edf2e3;background:#fff}
        .market-assistant-input-row{display:flex;gap:.7rem;align-items:flex-end}
        .market-assistant-input{resize:none;min-height:58px;max-height:140px;border-radius:18px;border:1px solid #d8e4ca;padding:.9rem 1rem;font-size:.95rem;line-height:1.55;box-shadow:none}
        .market-assistant-input:focus{border-color:rgba(119,184,30,.72);box-shadow:0 0 0 .2rem rgba(119,184,30,.12)}
        .market-assistant-send{min-width:112px;height:52px;border:none;border-radius:16px;background:#198754;color:#fff;font-weight:700;box-shadow:0 12px 24px rgba(25,135,84,.18)}
        .market-assistant-note{margin-top:.55rem;font-size:.82rem;color:#718260}
        .market-assistant-recipes,.market-assistant-preview{margin-top:.8rem;display:grid;gap:.7rem}
        .market-assistant-recipe-card,.market-assistant-preview-card{border:1px solid #e2ecd5;border-radius:16px;padding:.85rem .95rem;background:#f8fbf2}
        .market-assistant-recipe-card h6,.market-assistant-preview-card h6{margin:0 0 .35rem;font-size:.96rem;color:#243616}
        .market-assistant-recipe-card p,.market-assistant-preview-card p{margin:0;font-size:.84rem;color:#617252;line-height:1.6}
        .market-assistant-action{margin-top:.7rem}
        .market-assistant-action button{border:none;border-radius:12px;padding:.6rem .85rem;background:#198754;color:#fff;font-weight:700;font-size:.84rem}
        .market-assistant-list{margin:.55rem 0 0;padding-left:1rem;font-size:.85rem;color:#425534}
        .market-assistant-list li + li{margin-top:.25rem}
        .market-assistant-missing{margin-top:.5rem;font-size:.83rem;color:#a46a09}
        @media (max-width: 575.98px){
            .market-assistant-widget{right:14px;bottom:14px}
            .market-assistant-panel{right:-2px;bottom:76px;width:min(100vw - 20px,390px);height:min(72vh,620px)}
            .market-assistant-input-row{flex-direction:column}
            .market-assistant-send{width:100%}
        }
    </style>

    <div class="market-assistant-widget" id="marketAssistantWidget">
        <div class="market-assistant-panel" id="marketAssistantPanel" aria-hidden="true">
            <div class="market-assistant-header">
                <div>
                    <h5><i class="bi bi-stars me-2"></i>Market Assistant</h5>
                    <p>Quick help for products, cart, checkout, and order questions.</p>
                </div>
                <button type="button" class="market-assistant-close" id="marketAssistantClose" aria-label="Close assistant">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="market-assistant-body">
                <div class="market-assistant-suggestions">
                    <button type="button" class="market-assistant-chip" data-market-question="How do I add a product?">Add product</button>
                    <button type="button" class="market-assistant-chip" data-market-question="How do I use the cart and checkout?">Cart help</button>
                    <button type="button" class="market-assistant-chip" data-market-question="How can I track my order status?">Order status</button>
                    <button type="button" class="market-assistant-chip" data-market-question="Suggest a recipe with marketplace ingredients">Recipe ideas</button>
                    <button type="button" class="market-assistant-chip" data-market-question="Show me a breakfast recipe">Breakfast</button>
                    <button type="button" class="market-assistant-chip" data-market-question="Suggest a chicken recipe">Chicken dishes</button>
                </div>

                <div class="market-assistant-messages" id="marketAssistantMessages">
                    <div class="market-assistant-message bot">
                        <div class="market-assistant-avatar"><i class="bi bi-robot"></i></div>
                        <div class="market-assistant-bubble">
                            Hello {{ app.user.name ?? 'there' }}. I’m here to help with products, cart, checkout, and order questions while you browse the market.
                        </div>
                    </div>
                </div>

                <div class="market-assistant-form">
                    <div class="market-assistant-input-row">
                        <textarea id="marketAssistantInput" class="form-control market-assistant-input" placeholder="Ask something about the marketplace..."></textarea>
                        <button id="marketAssistantSend" type="button" class="market-assistant-send">
                            <i class="bi bi-send-fill me-2"></i>Send
                        </button>
                    </div>
                    <div class="market-assistant-note">Press Enter to send, or Shift + Enter for a new line.</div>
                </div>
            </div>
        </div>

        <button type="button" class="market-assistant-toggle" id="marketAssistantToggle" aria-label="Open market assistant">
            <i class="bi bi-chat-dots-fill"></i>
        </button>
    </div>

    <script>
    document.addEventListener('DOMContentLoaded', () => {
        const widget = document.getElementById('marketAssistantWidget');
        const panel = document.getElementById('marketAssistantPanel');
        const toggle = document.getElementById('marketAssistantToggle');
        const closeButton = document.getElementById('marketAssistantClose');
        const messages = document.getElementById('marketAssistantMessages');
        const input = document.getElementById('marketAssistantInput');
        const sendButton = document.getElementById('marketAssistantSend');
        const endpoint = '{{ path('chatbot_message') }}';
        const addRecipeEndpoint = '{{ path('chatbot_recipe_add') }}';
        const recipeToken = '{{ csrf_token('chatbot_recipe_add') }}';
        const suggestionButtons = document.querySelectorAll('[data-market-question]');

        if (!widget || !panel || !toggle || !messages || !input || !sendButton) {
            return;
        }

        function setOpen(isOpen) {
            panel.classList.toggle('is-open', isOpen);
            panel.setAttribute('aria-hidden', isOpen ? 'false' : 'true');

            if (isOpen) {
                input.focus();
            }
        }

        function addMessage(type, text, payload = {}) {
            const wrapper = document.createElement('div');
            wrapper.className = `market-assistant-message ${type}`;

            const avatar = document.createElement('div');
            avatar.className = 'market-assistant-avatar';
            avatar.innerHTML = type === 'bot'
                ? '<i class="bi bi-robot"></i>'
                : '<i class="bi bi-person-fill"></i>';

            const bubble = document.createElement('div');
            bubble.className = 'market-assistant-bubble';
            bubble.textContent = text;

            if (type === 'bot' && Array.isArray(payload.recipes) && payload.recipes.length > 0) {
                bubble.appendChild(buildRecipeSuggestions(payload.recipes));
            }

            if (type === 'bot' && payload.recipePreview) {
                bubble.appendChild(buildRecipePreview(payload.recipePreview));
            }

            wrapper.appendChild(avatar);
            wrapper.appendChild(bubble);
            messages.appendChild(wrapper);
            messages.scrollTop = messages.scrollHeight;
        }

        function buildRecipeSuggestions(recipes) {
            const container = document.createElement('div');
            container.className = 'market-assistant-recipes';

            recipes.forEach((recipe) => {
                const card = document.createElement('div');
                card.className = 'market-assistant-recipe-card';

                const title = document.createElement('h6');
                title.textContent = recipe.name;

                const description = document.createElement('p');
                description.textContent = `${recipe.description} (${recipe.ingredientCount} ingredients)`;

                const actions = document.createElement('div');
                actions.className = 'market-assistant-action';

                const button = document.createElement('button');
                button.type = 'button';
                button.textContent = 'Choose this dish';
                button.addEventListener('click', () => requestRecipePreview(recipe.slug, recipe.name));

                actions.appendChild(button);
                card.appendChild(title);
                card.appendChild(description);
                card.appendChild(actions);
                container.appendChild(card);
            });

            return container;
        }

        function buildRecipePreview(recipePreview) {
            const card = document.createElement('div');
            card.className = 'market-assistant-preview';

            const panel = document.createElement('div');
            panel.className = 'market-assistant-preview-card';

            const title = document.createElement('h6');
            title.textContent = recipePreview.name;

            const description = document.createElement('p');
            description.textContent = recipePreview.description;

            const ingredientList = document.createElement('ul');
            ingredientList.className = 'market-assistant-list';

            recipePreview.matches.forEach((match) => {
                const item = document.createElement('li');
                item.textContent = `${match.label}: ${match.productName} (${match.productPrice} TND / ${match.productUnit})`;
                ingredientList.appendChild(item);
            });

            panel.appendChild(title);
            panel.appendChild(description);
            panel.appendChild(ingredientList);

            if (Array.isArray(recipePreview.missing) && recipePreview.missing.length > 0) {
                const missing = document.createElement('div');
                missing.className = 'market-assistant-missing';
                missing.textContent = `Missing ingredients: ${recipePreview.missing.join(', ')}`;
                panel.appendChild(missing);
            }

            if (recipePreview.canAdd) {
                const actions = document.createElement('div');
                actions.className = 'market-assistant-action';

                const button = document.createElement('button');
                button.type = 'button';
                button.textContent = 'Add ingredients to cart';
                button.addEventListener('click', () => confirmRecipeAdd(recipePreview.slug));

                actions.appendChild(button);
                panel.appendChild(actions);
            }

            card.appendChild(panel);

            return card;
        }

        async function requestRecipePreview(slug, recipeName) {
            sendButton.disabled = true;

            try {
                const response = await fetch(endpoint, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({ recipe: slug })
                });

                const data = await response.json();
                addMessage('user', `I choose ${recipeName}`);
                addMessage('bot', data.reply || 'Here is the recipe preview.', {
                    recipePreview: data.recipePreview || null
                });
            } catch (error) {
                addMessage('bot', 'I could not load the recipe ingredients right now. Please try again.');
            } finally {
                sendButton.disabled = false;
                sendButton.innerHTML = '<i class="bi bi-send-fill me-2"></i>Send';
            }
        }

        async function confirmRecipeAdd(slug) {
            try {
                const response = await fetch(addRecipeEndpoint, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({ recipe: slug, _token: recipeToken })
                });

                const data = await response.json();
                addMessage('bot', data.reply || 'Recipe update complete.');

                if (data.ok && data.redirectUrl) {
                    window.setTimeout(() => {
                        window.location.href = data.redirectUrl;
                    }, 900);
                }
            } catch (error) {
                addMessage('bot', 'I could not add the ingredients to your cart right now. Please try again.');
            }
        }

        async function sendMessage() {
            const message = input.value.trim();

            if (!message) {
                return;
            }

            setOpen(true);
            addMessage('user', message);
            input.value = '';
            input.style.height = '58px';
            sendButton.disabled = true;
            sendButton.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Sending';

            try {
                const response = await fetch(endpoint, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest'
                    },
                    body: JSON.stringify({ message })
                });

                const data = await response.json();
                addMessage('bot', data.reply || 'Something went wrong while reading the assistant response.', {
                    recipes: data.recipes || [],
                    recipePreview: data.recipePreview || null
                });
            } catch (error) {
                addMessage('bot', 'The market assistant is temporarily unavailable. Please try again in a moment.');
            } finally {
                sendButton.disabled = false;
                sendButton.innerHTML = '<i class="bi bi-send-fill me-2"></i>Send';
                input.focus();
            }
        }

        toggle.addEventListener('click', () => setOpen(!panel.classList.contains('is-open')));
        closeButton?.addEventListener('click', () => setOpen(false));

        sendButton.addEventListener('click', sendMessage);

        input.addEventListener('keydown', (event) => {
            if (event.key === 'Enter' && !event.shiftKey) {
                event.preventDefault();
                sendMessage();
            }
        });

        input.addEventListener('input', () => {
            input.style.height = '58px';
            input.style.height = `${Math.min(input.scrollHeight, 140)}px`;
        });

        suggestionButtons.forEach((button) => {
            button.addEventListener('click', () => {
                setOpen(true);
                input.value = button.dataset.marketQuestion;
                input.focus();
            });
        });

        document.addEventListener('click', (event) => {
            if (!widget.contains(event.target) && panel.classList.contains('is-open')) {
                setOpen(false);
            }
        });
    });
    </script>
{% endif %}

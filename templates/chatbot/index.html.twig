{% extends 'base.html.twig' %}

{% block title %}Platform Assistant - AgriCloud{% endblock %}
{% block page_title %}Platform Assistant{% endblock %}

{% block stylesheets %}
<style>
.assistant-shell{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:320px minmax(0,1fr);gap:1.4rem}
.assistant-side,.assistant-chat{background:#fff;border:1px solid rgba(119,184,30,.12);border-radius:28px;box-shadow:0 18px 42px rgba(31,48,18,.08)}
.assistant-side{padding:1.5rem;background:linear-gradient(180deg,#f7fbeF 0%,#ffffff 100%)}
.assistant-badge{display:inline-flex;align-items:center;gap:.55rem;padding:.45rem .85rem;border-radius:999px;background:#eef6df;color:#4d7019;font-weight:700;font-size:.88rem}
.assistant-title{font-size:2rem;line-height:1.1;margin:1rem 0 .7rem;color:#1f3012}
.assistant-copy{font-size:1rem;line-height:1.8;color:#60724d;margin-bottom:1.3rem}
.assistant-suggestion-grid{display:flex;flex-wrap:wrap;gap:.65rem}
.assistant-suggestion{border:none;border-radius:999px;padding:.7rem 1rem;background:#f1f6e7;color:#365118;font-weight:700;transition:all .16s ease;box-shadow:inset 0 0 0 1px rgba(119,184,30,.14)}
.assistant-suggestion:hover{background:#77b81e;color:#fff;transform:translateY(-1px)}
.assistant-chat{display:flex;flex-direction:column;min-height:72vh;overflow:hidden}
.assistant-chat-header{padding:1.3rem 1.5rem;border-bottom:1px solid #edf2e3;background:linear-gradient(135deg,#77b81e 0%,#5d9318 100%);color:#fff}
.assistant-chat-header h5{margin:0 0 .35rem;font-size:1.35rem}
.assistant-chat-header p{margin:0;opacity:.92}
.assistant-messages{padding:1.4rem;display:flex;flex-direction:column;gap:1rem;overflow-y:auto;flex:1;background:radial-gradient(circle at top right,rgba(119,184,30,.08),transparent 34%),#fbfcf8}
.assistant-message{display:flex;gap:.85rem;max-width:86%}
.assistant-message.user{margin-left:auto;flex-direction:row-reverse}
.assistant-avatar{width:42px;height:42px;border-radius:14px;display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:1.15rem}
.assistant-message.bot .assistant-avatar{background:#eaf4d7;color:#4e7219}
.assistant-message.user .assistant-avatar{background:#1a2e0a;color:#fff}
.assistant-bubble{padding:1rem 1.1rem;border-radius:20px;font-size:1rem;line-height:1.7;box-shadow:0 10px 24px rgba(30,47,16,.06)}
.assistant-message.bot .assistant-bubble{background:#fff;border:1px solid #e5edd8;color:#2e4320;border-top-left-radius:8px}
.assistant-message.user .assistant-bubble{background:linear-gradient(135deg,#77b81e 0%,#5f9818 100%);color:#fff;border-top-right-radius:8px}
.assistant-form{padding:1.2rem 1.35rem;border-top:1px solid #edf2e3;background:#fff}
.assistant-input-row{display:flex;gap:.8rem;align-items:flex-end}
.assistant-input{resize:none;min-height:66px;max-height:160px;border-radius:20px;border:1px solid #d8e4ca;padding:1rem 1.1rem;font-size:1rem;line-height:1.6;box-shadow:none}
.assistant-input:focus{border-color:rgba(119,184,30,.72);box-shadow:0 0 0 .22rem rgba(119,184,30,.12)}
.assistant-send{min-width:132px;height:56px;border:none;border-radius:18px;background:#198754;color:#fff;font-weight:700;box-shadow:0 12px 24px rgba(25,135,84,.18);transition:all .18s ease}
.assistant-send:hover{transform:translateY(-1px);background:#157347}
.assistant-note{margin-top:.75rem;font-size:.88rem;color:#6d7d5f}
@media (max-width: 991.98px){.assistant-shell{grid-template-columns:1fr}.assistant-chat{min-height:68vh}}
@media (max-width: 575.98px){.assistant-input-row{flex-direction:column}.assistant-send{width:100%}.assistant-message{max-width:100%}}
</style>
{% endblock %}

{% block body %}
<div class="assistant-shell">
    <section class="assistant-side">
        <span class="assistant-badge">
            <i class="bi bi-stars"></i>
            AgriCloud Guide
        </span>
        <h1 class="assistant-title">Ask the platform assistant</h1>
        <p class="assistant-copy">
            This chatbot helps users with common questions about products, orders, checkout, farms, events, and account navigation inside AgriCloud.
        </p>

        <div class="assistant-suggestion-grid">
            <button class="assistant-suggestion" type="button" data-question="How do I add a product?">Add a product</button>
            <button class="assistant-suggestion" type="button" data-question="How can I track my order status?">Track an order</button>
            <button class="assistant-suggestion" type="button" data-question="How do I use the cart and checkout?">Cart and checkout</button>
            <button class="assistant-suggestion" type="button" data-question="What can I do in the farms section?">Farms section</button>
            <button class="assistant-suggestion" type="button" data-question="How does the blog section work?">Blog help</button>
            <button class="assistant-suggestion" type="button" data-question="How do I update my profile?">Profile help</button>
        </div>
    </section>

    <section class="assistant-chat">
        <div class="assistant-chat-header">
            <h5>AgriCloud Platform Assistant</h5>
            <p>Quick answers for the main features of the application.</p>
        </div>

        <div id="chatMessages" class="assistant-messages">
            <div class="assistant-message bot">
                <div class="assistant-avatar">
                    <i class="bi bi-robot"></i>
                </div>
                <div class="assistant-bubble">
                    Hello {{ app.user.name ?? 'there' }}. I can help with products, cart, orders, farms, events, the blog, and account navigation. What would you like to know?
                </div>
            </div>
        </div>

        <div class="assistant-form">
            <div class="assistant-input-row">
                <textarea id="chatInput" class="form-control assistant-input" placeholder="Type your question here..."></textarea>
                <button id="chatSend" class="assistant-send" type="button">
                    <i class="bi bi-send-fill me-2"></i>Send
                </button>
            </div>
            <div class="assistant-note">Tip: Press Enter to send, or Shift + Enter for a new line.</div>
        </div>
    </section>
</div>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', () => {
    const messages = document.getElementById('chatMessages');
    const input = document.getElementById('chatInput');
    const sendButton = document.getElementById('chatSend');
    const suggestions = document.querySelectorAll('[data-question]');
    const endpoint = '{{ path('chatbot_message') }}';

    function addMessage(type, text) {
        const wrapper = document.createElement('div');
        wrapper.className = `assistant-message ${type}`;

        const avatar = document.createElement('div');
        avatar.className = 'assistant-avatar';
        avatar.innerHTML = type === 'bot'
            ? '<i class="bi bi-robot"></i>'
            : '<i class="bi bi-person-fill"></i>';

        const bubble = document.createElement('div');
        bubble.className = 'assistant-bubble';
        bubble.textContent = text;

        wrapper.appendChild(avatar);
        wrapper.appendChild(bubble);
        messages.appendChild(wrapper);
        messages.scrollTop = messages.scrollHeight;
    }

    async function sendMessage() {
        const message = input.value.trim();

        if (!message) {
            return;
        }

        addMessage('user', message);
        input.value = '';
        input.style.height = '66px';
        sendButton.disabled = true;
        sendButton.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Sending';

        try {
            const response = await fetch(endpoint, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({ message })
            });

            const data = await response.json();
            addMessage('bot', data.reply || 'Something went wrong while reading the assistant response.');
        } catch (error) {
            addMessage('bot', 'The assistant is temporarily unavailable. Please try again in a moment.');
        } finally {
            sendButton.disabled = false;
            sendButton.innerHTML = '<i class="bi bi-send-fill me-2"></i>Send';
            input.focus();
        }
    }

    sendButton.addEventListener('click', sendMessage);

    input.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' && !event.shiftKey) {
            event.preventDefault();
            sendMessage();
        }
    });

    input.addEventListener('input', () => {
        input.style.height = '66px';
        input.style.height = `${Math.min(input.scrollHeight, 160)}px`;
    });

    suggestions.forEach((button) => {
        button.addEventListener('click', () => {
            input.value = button.dataset.question;
            input.focus();
        });
    });
});
</script>
{% endblock %}

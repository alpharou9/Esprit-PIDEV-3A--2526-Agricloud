<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Farm {{ status|capitalize }} — AgriCloud</title>
<style>
  body { margin:0; padding:0; background:#f4f6f9; font-family:Arial,sans-serif; }
  .wrap { max-width:540px; margin:32px auto; background:#fff; border-radius:16px; overflow:hidden; box-shadow:0 4px 20px rgba(0,0,0,.08); }
  .header { background:{% if status == 'approved' %}linear-gradient(135deg,#198754,#20c997){% else %}linear-gradient(135deg,#dc3545,#c82333){% endif %}; padding:36px 32px; text-align:center; color:#fff; }
  .header h1 { margin:0 0 4px; font-size:22px; }
  .body { padding:28px 32px; }
  .status-badge { display:inline-block; padding:6px 18px; border-radius:20px; font-weight:bold; font-size:14px; background:{% if status == 'approved' %}#d1e7dd; color:#0a3622{% else %}#f8d7da; color:#58151c{% endif %}; margin-bottom:16px; }
  .footer { background:#f8f9fa; padding:16px 32px; text-align:center; font-size:12px; color:#aaa; border-top:1px solid #e9ecef; }
  .btn { display:inline-block; background:#198754; color:#fff; text-decoration:none; padding:11px 26px; border-radius:8px; font-weight:bold; margin-top:16px; }
</style>
</head>
<body>
<div class="wrap">
  <div class="header">
    <h1>🌿 AgriCloud</h1>
    <p style="margin:0;opacity:.9;font-size:14px">Farm Status Update</p>
  </div>
  <div class="body">
    <p style="font-size:15px;color:#333">Hi <strong>{{ user.name }}</strong>,</p>
    <div class="status-badge">{{ status|upper }}</div>
    <p style="font-size:14px;color:#555">
      {% if status == 'approved' %}
        Great news! Your farm <strong>{{ farm.name }}</strong> has been <strong>approved</strong> by our team. You can now list products and manage your fields.
      {% else %}
        Unfortunately, your farm <strong>{{ farm.name }}</strong> has been <strong>rejected</strong>. Please review and update your farm details, then resubmit for approval.
      {% endif %}
    </p>
    <p style="font-size:13px;color:#888">Farm: {{ farm.name }}<br>Location: {{ farm.location }}<br>Submitted: {{ farm.createdAt ? farm.createdAt|date('d M Y') : '—' }}</p>
    <a href="{{ farm_url }}" class="btn">View My Farm →</a>
  </div>
  <div class="footer">© {{ "now"|date("Y") }} AgriCloud · Automated notification</div>
</div>
</body>
</html>

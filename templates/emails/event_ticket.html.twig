<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Event Ticket</title>
</head>
<body style="margin:0;padding:0;background:#f4f7f2;font-family:Arial,sans-serif;color:#163020;">
    <div style="max-width:680px;margin:0 auto;padding:32px 20px;">
        <div style="background:#ffffff;border-radius:20px;overflow:hidden;box-shadow:0 12px 30px rgba(0,0,0,0.08);">
            <div style="padding:28px 32px;background:linear-gradient(135deg,#0f5132,#198754);color:#ffffff;">
                {% if logo_cid %}
                    <img src="{{ logo_cid }}" alt="AgriCloud" style="height:34px;margin-bottom:18px;">
                {% endif %}
                <div style="font-size:12px;letter-spacing:0.16em;text-transform:uppercase;opacity:0.85;">Event Ticket</div>
                <h1 style="margin:10px 0 6px;font-size:30px;line-height:1.2;">{{ event.title }}</h1>
                <p style="margin:0;font-size:15px;opacity:0.92;">Your registration is confirmed. Your ticket PDF is attached to this email.</p>
            </div>

            <div style="padding:28px 32px;">
                <p style="margin-top:0;font-size:16px;">Hello {{ participant.name }},</p>
                <p style="font-size:15px;line-height:1.7;">
                    Thank you for registering for <strong>{{ event.title }}</strong>. Here are your event details and ticket reference.
                </p>

                <div style="margin:18px 0 24px;padding:14px 16px;border-radius:14px;background:{{ availability.background }};border:1px solid {{ availability.color }}22;">
                    <div style="display:inline-block;width:11px;height:11px;border-radius:50%;background:{{ availability.color }};margin-right:8px;"></div>
                    <span style="font-size:14px;font-weight:700;color:{{ availability.color }};">{{ availability.label }}</span>
                    {% if availability.remainingSlots is not null %}
                        <span style="font-size:14px;color:#48654e;">, {{ availability.remainingSlots }} slot{{ availability.remainingSlots == 1 ? '' : 's' }} left out of {{ availability.capacity }}</span>
                    {% endif %}
                </div>

                <div style="margin:24px 0;padding:20px;border:1px solid #dce7dc;border-radius:16px;background:#f8fbf7;">
                    <p style="margin:0 0 10px;font-size:14px;"><strong>Ticket number:</strong> {{ ticketNumber }}</p>
                    <p style="margin:0 0 10px;font-size:14px;"><strong>Date:</strong> {{ event.eventDate ? event.eventDate|date('d M Y, H:i') : 'TBD' }}</p>
                    <p style="margin:0 0 10px;font-size:14px;"><strong>End date:</strong> {{ event.endDate ? event.endDate|date('d M Y, H:i') : 'Not specified' }}</p>
                    <p style="margin:0 0 10px;font-size:14px;"><strong>Location:</strong> {{ event.location }}</p>
                    <p style="margin:0;font-size:14px;"><strong>Registered on:</strong> {{ participation.registrationDate ? participation.registrationDate|date('d M Y, H:i') : 'Just now' }}</p>
                </div>

                {% if qrCodeUrl and mapSearchUrl %}
                    <div style="margin:24px 0 0;padding:20px;border:1px solid #dce7dc;border-radius:16px;background:#ffffff;">
                        <h2 style="margin:0 0 12px;font-size:18px;color:#0f5132;">Scan To Open The Location</h2>
                        <p style="margin:0 0 16px;font-size:14px;line-height:1.7;color:#48654e;">
                            Scan this QR code to open <strong>{{ event.location }}</strong> in maps.
                        </p>
                        <img src="{{ qrCodeUrl }}" alt="QR code for {{ event.location }}" style="display:block;width:180px;height:180px;border:1px solid #dce7dc;border-radius:12px;padding:8px;background:#fff;">
                        <p style="margin:14px 0 0;font-size:13px;line-height:1.6;">
                            If scanning is not available, open this link:
                            <a href="{{ mapSearchUrl }}" style="color:#0f5132;">{{ event.location }}</a>
                        </p>
                    </div>
                {% endif %}

                <div style="margin:24px 0 0;">
                    <h2 style="margin:0 0 10px;font-size:18px;color:#0f5132;">Event Description</h2>
                    <p style="margin:0;font-size:15px;line-height:1.8;white-space:pre-line;">{{ event.description }}</p>
                </div>
            </div>
        </div>
    </div>
</body>
</html>

{% extends 'base.html.twig' %}

{% block title %}Dashboard - AgriCloud{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-1">Commerce Dashboard</h4>
        <p class="text-muted mb-0">Workshop-style Symfony back office connected to your shared AgriCloud database.</p>
    </div>
    <span class="text-muted small">Welcome back, <strong>{{ app.user.name }}</strong></span>
</div>

<div class="row g-3">
    <div class="col-md-3">
        <a href="{{ path('product_index') }}" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-success bg-opacity-10 p-3">
                        <i class="bi bi-basket-fill text-success fs-4"></i>
                    </div>
                    <div>
                        <div class="fw-semibold">{{ stats.products }}</div>
                        <div class="text-muted small">Products in catalog</div>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="{{ path('product_index') }}" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-warning bg-opacity-10 p-3">
                        <i class="bi bi-check2-circle text-warning fs-4"></i>
                    </div>
                    <div>
                        <div class="fw-semibold">{{ stats.approved_products }}</div>
                        <div class="text-muted small">Approved products</div>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="{{ path('order_index') }}" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                        <i class="bi bi-receipt-cutoff text-primary fs-4"></i>
                    </div>
                    <div>
                        <div class="fw-semibold">{{ stats.orders }}</div>
                        <div class="text-muted small">Orders tracked</div>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="{{ path('app_farm_index') }}" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-info bg-opacity-10 p-3">
                        <i class="bi bi-house-door-fill text-info fs-4"></i>
                    </div>
                    <div>
                        <div class="fw-semibold">{{ stats.farms }}</div>
                        <div class="text-muted small">Farms managed</div>
                    </div>
                </div>
            </div>
        </a>
    </div>
    <div class="col-md-3">
        <a href="{{ path('order_index') }}" class="text-decoration-none">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-danger bg-opacity-10 p-3">
                        <i class="bi bi-exclamation-diamond text-danger fs-4"></i>
                    </div>
                    <div>
                        <div class="fw-semibold">{{ stats.low_stock_products }}</div>
                        <div class="text-muted small">Products low on stock</div>
                    </div>
                </div>
            </div>
        </a>
    </div>
</div>

<div class="row g-3 mt-1">
    <div class="col-lg-7">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="fw-bold mb-0">Module overview</h5>
                    <span class="badge text-bg-success">Connected</span>
                </div>
                <p class="text-muted mb-3">
                    This Symfony project now follows the workshop structure and reuses the Esprit PIDEV template,
                    while mapping directly to your `products`, `orders`, `users`, and `roles` tables.
                </p>
                <div class="row g-3">
                    <div class="col-md-4">
                        <div class="p-3 rounded-4 bg-light h-100">
                            <div class="small text-uppercase text-muted fw-semibold">Pending orders</div>
                            <div class="display-6 fw-bold">{{ stats.pending_orders }}</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 rounded-4 bg-light h-100">
                            <div class="small text-uppercase text-muted fw-semibold">Delivered revenue</div>
                            <div class="display-6 fw-bold">{{ stats.delivered_revenue|number_format(2, '.', ' ') }}</div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="p-3 rounded-4 bg-light h-100">
                            <div class="small text-uppercase text-muted fw-semibold">Quick access</div>
                            <div class="mt-2 d-grid gap-2">
                                <a href="{{ path('product_new') }}" class="btn btn-success btn-sm">Add product</a>
                                <a href="{{ path('app_farm_new') }}" class="btn btn-outline-success btn-sm">Add farm</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body">
                <h5 class="fw-bold mb-3">Workshop scope</h5>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item px-0">Doctrine entities mapped to the shared MySQL database.</li>
                    <li class="list-group-item px-0">Bootstrap and Twig templates styled from the Esprit PIDEV starter.</li>
                    <li class="list-group-item px-0">CRUD pages for products, farms, and orders.</li>
                    <li class="list-group-item px-0">Security and login kept from the workshop template.</li>
                </ul>
            </div>
        </div>
    </div>
</div>
{% endblock %}

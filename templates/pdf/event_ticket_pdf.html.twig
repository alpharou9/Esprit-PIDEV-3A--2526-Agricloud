{# templates/pdf/event_ticket_pdf.html.twig #}
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: 'DejaVu Sans', sans-serif; }
        .ticket-box { border: 2px dashed #333; padding: 20px; width: 100%; }
        .header { text-align: center; background-color: #f4f4f4; padding: 10px; }
        .details { margin-top: 20px; }
        .footer { margin-top: 30px; font-size: 12px; color: #777; }
    </style>
</head>
<body>
    <div class="ticket-box">
        <div class="header">
            <h1>EVENT TICKET</h1>
            <h2>{{ event.title }}</h2>
        </div>

        <div class="details">
            <p><strong>Attendee:</strong> {{ user.name }}</p>
            <p><strong>Date:</strong> {{ event.createdAt|date('d-m-Y H:i') }}</p>
            <p><strong>Location:</strong> {{ event.location|default('Online/TBD') }}</p>
            <p><strong>Ticket ID:</strong> #{{ participation.id }}</p>
        </div>

        <div class="footer">
            <p>Please present this ticket at the entrance. Powered by AgriCloud.</p>
        </div>
    </div>
</body>
</html>

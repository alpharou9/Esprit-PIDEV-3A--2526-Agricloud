{% extends 'base.html.twig' %}

{% block title %}Field index{% endblock %}

{% block body %}
    <h1>Field index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Area</th>
                <th>Soil_type</th>
                <th>Crop_type</th>
                <th>Coordinates</th>
                <th>Status</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for field in fields %}
            <tr>
                <td>{{ field.id }}</td>
                <td>{{ field.name }}</td>
                <td>{{ field.area }}</td>
                <td>{{ field.soilType }}</td>
                <td>{{ field.cropType }}</td>
                <td>{{ field.coordinates }}</td>
                <td>{{ field.status }}</td>
                <td>
                    <a href="{{ path('app_field_show', {'id': field.id}) }}">show</a>
                    <a href="{{ path('app_field_edit', {'id': field.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="8">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_field_new') }}">Create new</a>
{% endblock %}

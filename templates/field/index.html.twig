{% extends 'base.html.twig' %}

{% block title %}Fields for {{ farm.name }}{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h2">Management: {{ farm.name }} Fields</h1>
        <p class="text-muted">Viewing all fields located in {{ farm.location }}</p>
    </div>
    {# Pass the farm.id to the new route so the controller knows where to add the field #}
    <a href="{{ path('app_field_new', {'farm_id': farm.id}) }}" class="btn btn-success shadow-sm">
        <i class="bi bi-plus-lg"></i> Add New Field
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Id</th>
                    <th>Field Name</th>
                    <th>Area (ha)</th>
                    <th>Soil Type</th>
                    <th>Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for field in fields %}
                <tr class="align-middle">
                    <td>{{ field.id }}</td>
                    <td><strong>{{ field.name }}</strong></td>
                    <td>{{ field.area }} ha</td>
                    <td>
                        <span class="badge bg-light text-dark border">{{ field.soilType }}</span>
                    </td>
                    <td>
                        <span class="badge {{ field.status == 'active' ? 'bg-success' : 'bg-secondary' }}">
                            {{ field.status|upper }}
                        </span>
                    </td>
                    <td>
                        <div class="d-flex justify-content-center gap-2">
                            <a href="{{ path('app_field_edit', {'id': field.id}) }}" class="btn btn-sm btn-warning">
                                <i class="bi bi-pencil"></i> Update
                            </a>
                            
                            {# Standard Symfony delete form #}
                            {{ include('field/_delete_form.html.twig') }}
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="text-center py-5 text-muted">
                        <i class="bi bi-patch-exclamation-fill display-4 d-block mb-2"></i>
                        No fields have been added to this farm yet.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<div class="mt-4">
    <a href="{{ path('app_farmer_my_farms') }}" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left"></i> Back to My Farms
    </a>
</div>
{% endblock %}
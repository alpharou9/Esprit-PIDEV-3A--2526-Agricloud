{{ form_start(form) }}
<div class="row g-3">
    <div class="col-md-6">{{ form_row(form.user) }}</div>
    <div class="col-md-6">{{ form_row(form.farm) }}</div>
    <div class="col-md-6">{{ form_row(form.name) }}</div>
    <div class="col-md-3">{{ form_row(form.price) }}</div>
    <div class="col-md-3">{{ form_row(form.quantity) }}</div>
    <div class="col-md-4">{{ form_row(form.unit) }}</div>
    <div class="col-md-4">{{ form_row(form.category) }}</div>
    <div class="col-md-4">{{ form_row(form.status) }}</div>
    <div class="col-12">{{ form_row(form.imageFile) }}</div>
    <div class="col-12">{{ form_row(form.description) }}</div>
</div>
{% if form.vars.data.image %}
    <div class="mt-3">
        <div class="small text-muted mb-2">Current image</div>
        <img src="/{{ form.vars.data.image }}" alt="Product image" class="img-thumbnail" style="max-height: 180px;">
    </div>
{% endif %}
<div class="mt-4 d-flex gap-2">
    <button class="btn btn-success">{{ button_label|default('Save') }}</button>
    <a href="{{ path('product_index') }}" class="btn btn-outline-secondary">Cancel</a>
</div>
{{ form_end(form) }}

{% extends 'base.html.twig' %}

{% block title %}Edit Product - AgriCloud{% endblock %}

{% block body %}
<div class="mb-4">
    <h3 class="fw-bold mb-1">Edit product #{{ product.id }}</h3>
    <p class="text-muted mb-0">Update catalog information without touching the database schema.</p>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body">
        {% include 'product/_form.html.twig' with {form: form, button_label: 'Save changes'} %}
    </div>
</div>
{% endblock %}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}JavaBlog{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Source+Sans+3&display=swap" rel="stylesheet">
    <style>
        :root {
            --ink: #1a1a2e;
            --accent: #e63946;
            --muted: #6c757d;
            --light-bg: #f8f9fa;
        }
        body { font-family: 'Source Sans 3', sans-serif; color: var(--ink); background: #fff; }
        .navbar-brand { font-family: 'Playfair Display', serif; font-size: 1.6rem; color: var(--accent) !important; }
        .navbar { border-bottom: 2px solid var(--ink); }
        h1, h2, h3 { font-family: 'Playfair Display', serif; }
        .btn-primary { background: var(--ink); border-color: var(--ink); }
        .btn-primary:hover { background: var(--accent); border-color: var(--accent); }
        .btn-danger { background: var(--accent); border-color: var(--accent); }
        .card { border: 1.5px solid #e0e0e0; border-radius: 0; transition: box-shadow 0.2s; }
        .card:hover { box-shadow: 4px 4px 0 var(--ink); }
        .badge-post { background: var(--ink); color: #fff; font-size: 0.7rem; padding: 3px 8px; text-transform: uppercase; letter-spacing: 1px; }
        .flash-success { background: #d4edda; border-left: 4px solid #28a745; }
        .flash-danger  { background: #f8d7da; border-left: 4px solid var(--accent); }
        footer { border-top: 2px solid var(--ink); margin-top: 4rem; }
    </style>
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-light bg-white px-4">
    <a class="navbar-brand" href="{{ path('app_post_index') }}">✍ JavaBlog</a>
    <div class="ms-auto d-flex gap-2">
        <a href="{{ path('app_post_index') }}" class="btn btn-sm btn-outline-dark">Posts</a>
        <a href="{{ path('app_post_new') }}" class="btn btn-sm btn-primary">+ New Post</a>
        <a href="{{ path('app_comment_index') }}" class="btn btn-sm btn-outline-secondary">Comments</a>
    </div>
</nav>

<div class="container py-4">

    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert flash-{{ label }} p-3 mb-3">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</div>

<footer class="text-center py-3 text-muted small">
    JavaBlog &copy; {{ "now"|date("Y") }} — Built with Symfony
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

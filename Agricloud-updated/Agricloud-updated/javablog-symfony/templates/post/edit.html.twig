{% extends 'base.html.twig' %}

{% block title %}Edit Post — JavaBlog{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-lg-7">
        <a href="{{ path('app_post_show', {id: post.id}) }}" class="text-muted small">← Back to post</a>
        <h1 class="mt-2">Edit Post</h1>
        <div class="card p-4 mt-3">
            {{ form_start(form) }}
                {{ form_row(form.title) }}
                {{ form_row(form.author) }}
                {{ form_row(form.content) }}
                <div class="d-flex gap-2 mt-3">
                    {{ form_row(form.save) }}
                    <a href="{{ path('app_post_show', {id: post.id}) }}" class="btn btn-outline-secondary">Cancel</a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}

{% extends 'base.html.twig' %}

{% block title %}Roles — AgriCloud{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0"><i class="bi bi-shield-check me-2"></i>Roles</h5>
    <a href="{{ path('role_new') }}" class="btn btn-success btn-sm">
        <i class="bi bi-plus-lg me-1"></i> New Role
    </a>
</div>

<div class="card border-0 shadow-sm" style="max-width:700px">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th>Description</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for role in roles %}
                <tr>
                    <td class="text-muted small">{{ role.id }}</td>
                    <td><span class="badge bg-secondary fs-6">{{ role.name }}</span></td>
                    <td class="text-muted">{{ role.description ?? '—' }}</td>
                    <td class="text-end">
                        <a href="{{ path('role_edit', {id: role.id}) }}" class="btn btn-sm btn-outline-primary me-1">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form method="post" action="{{ path('role_delete', {id: role.id}) }}" class="d-inline"
                              onsubmit="return confirm('Delete role {{ role.name }}?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_role_' ~ role.id) }}">
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="4" class="text-center text-muted py-4">No roles defined yet.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

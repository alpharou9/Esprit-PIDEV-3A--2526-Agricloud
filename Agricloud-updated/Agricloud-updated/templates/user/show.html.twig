{% extends 'base.html.twig' %}

{% block title %}{{ user.name }} — AgriCloud{% endblock %}

{% block body %}
<div class="d-flex align-items-center mb-3 gap-2">
    <a href="{{ path('user_index') }}" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h5 class="fw-bold mb-0">User Details — {{ user.name }}</h5>
</div>

<div class="card border-0 shadow-sm" style="max-width:600px">
    <div class="card-body p-4">
        <dl class="row mb-0">
            <dt class="col-sm-4 text-muted">ID</dt>
            <dd class="col-sm-8 text-muted small">{{ user.id }}</dd>

            <dt class="col-sm-4 text-muted">Full Name</dt>
            <dd class="col-sm-8 fw-semibold">{{ user.name }}</dd>

            <dt class="col-sm-4 text-muted">Email</dt>
            <dd class="col-sm-8">{{ user.email }}</dd>

            <dt class="col-sm-4 text-muted">Phone</dt>
            <dd class="col-sm-8">{{ user.phone ?? '—' }}</dd>

            <dt class="col-sm-4 text-muted">Role</dt>
            <dd class="col-sm-8">
                {% if user.role %}
                    <span class="badge bg-secondary">{{ user.role.name }}</span>
                {% else %}
                    <span class="text-muted">—</span>
                {% endif %}
            </dd>

            <dt class="col-sm-4 text-muted">Status</dt>
            <dd class="col-sm-8">
                {% if user.status == 'active' %}
                    <span class="badge bg-success">Active</span>
                {% elseif user.status == 'blocked' %}
                    <span class="badge bg-danger">Blocked</span>
                {% else %}
                    <span class="badge bg-secondary">Inactive</span>
                {% endif %}
            </dd>

            <dt class="col-sm-4 text-muted">OAuth Provider</dt>
            <dd class="col-sm-8">{{ user.oauthProvider ?? '—' }}</dd>

            <dt class="col-sm-4 text-muted">Created At</dt>
            <dd class="col-sm-8 text-muted small">{{ user.createdAt ? user.createdAt|date('d M Y H:i') : '—' }}</dd>

            <dt class="col-sm-4 text-muted">Updated At</dt>
            <dd class="col-sm-8 text-muted small">{{ user.updatedAt ? user.updatedAt|date('d M Y H:i') : '—' }}</dd>
        </dl>

        <hr>
        <div class="d-flex gap-2">
            <a href="{{ path('user_edit', {id: user.id}) }}" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-pencil me-1"></i> Edit
            </a>
            <form method="post" action="{{ path('user_toggle_block', {id: user.id}) }}" class="d-inline">
                <input type="hidden" name="_token" value="{{ csrf_token('toggle_block_' ~ user.id) }}">
                <button type="submit" class="btn btn-sm {{ user.status == 'blocked' ? 'btn-outline-success' : 'btn-outline-warning' }}">
                    <i class="bi {{ user.status == 'blocked' ? 'bi-unlock' : 'bi-lock' }} me-1"></i>
                    {{ user.status == 'blocked' ? 'Unblock' : 'Block' }}
                </button>
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% extends 'base.html.twig' %}
{% block title %}{{ post ? 'Edit - ' ~ post.title : 'Write a Post' }} - AgriCloud{% endblock %}

{% block body %}
<div class="d-flex align-items-center gap-2 mb-4">
    <a href="{{ path('blog_my_posts') }}" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <h5 class="fw-bold mb-0">{{ post ? 'Edit Post' : 'Write a New Post' }}</h5>
</div>

{{ form_start(form, {attr: {enctype: 'multipart/form-data', novalidate: 'novalidate'}}) }}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <div class="mb-3">
                    {{ form_label(form.title, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
                    {{ form_widget(form.title) }}
                    {{ form_errors(form.title) }}
                </div>

                <div class="row g-3 mb-3">
                    <div class="col-sm-6">
                        {{ form_label(form.category, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
                        {{ form_widget(form.category) }}
                        {{ form_errors(form.category) }}
                    </div>
                    <div class="col-sm-6">
                        {{ form_label(form.status, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
                        {{ form_widget(form.status) }}
                        {{ form_errors(form.status) }}
                    </div>
                </div>

                <div class="mb-3">
                    <div class="d-flex justify-content-between align-items-center mb-1 gap-2 flex-wrap">
                        {{ form_label(form.excerpt, null, {label_attr: {class: 'form-label fw-semibold mb-0'}}) }}
                        <button type="button" class="btn btn-outline-success btn-sm" id="generate-summary-btn" onclick="generateSummary()">
                            <i class="bi bi-stars me-1"></i>Generate Summary
                        </button>
                    </div>
                    {{ form_widget(form.excerpt) }}
                    {{ form_errors(form.excerpt) }}
                    <div class="form-text">Shown in post listings. Leave blank to auto-generate from content.</div>
                    <div class="alert alert-success small mt-2 d-none" id="summary-result"></div>
                </div>

                <div class="mb-3">
                    {{ form_label(form.content, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
                    {{ form_widget(form.content) }}
                    {{ form_errors(form.content) }}
                </div>

                <div class="mb-3">
                    {{ form_label(form.tagsInput, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
                    {{ form_widget(form.tagsInput) }}
                    {{ form_errors(form.tagsInput) }}
                    <div class="form-text">Separate multiple tags with commas - e.g. <code>organic, soil, wheat</code></div>
                </div>

                <div class="d-flex gap-2 pt-2">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-lg me-1"></i>{{ post ? 'Save Changes' : 'Create Post' }}
                    </button>
                    <a href="{{ path('blog_my_posts') }}" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-body p-4">
                <h6 class="fw-semibold mb-3"><i class="bi bi-image me-1"></i>Cover Image</h6>
                {% if post and post.image %}
                <div class="mb-3">
                    <img src="{{ asset('uploads/posts/' ~ post.image) }}" class="img-fluid rounded-3 w-100" style="max-height:180px;object-fit:cover" alt="Current cover">
                    <div class="form-text">Upload a new image to replace this one.</div>
                </div>
                {% endif %}

                {{ form_label(form.imageFile, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
                {{ form_widget(form.imageFile) }}
                {{ form_errors(form.imageFile) }}
                <div class="form-text mt-1">Max 3 MB - JPG, PNG or WEBP.</div>
            </div>
        </div>

        <div class="card border-0 bg-light rounded-4 mt-3">
            <div class="card-body p-3 small text-muted">
                <p class="fw-semibold mb-2"><i class="bi bi-lightbulb me-1 text-warning"></i>Smart Tools Added</p>
                <ul class="ps-3 mb-0">
                    <li>Summary creates excerpts from your title and content.</li>
                    <li>Moderation reviews comments before they get posted.</li>
                    <li>Recommendations suggest related posts automatically.</li>
                </ul>
            </div>
        </div>
    </div>
</div>

{{ form_end(form) }}
{% endblock %}

{% block javascripts %}
<script>
async function parseApiPayload(response, fallbackMessage) {
    const text = await response.text();
    let data = {};

    try {
        data = text ? JSON.parse(text) : {};
    } catch (error) {
        if (!response.ok) {
            throw new Error(fallbackMessage);
        }

        throw new Error('The server returned an invalid response.');
    }

    if (!response.ok) {
        throw new Error(data.error || fallbackMessage);
    }

    return data;
}

async function generateSummary() {
    const title = document.getElementById('{{ form.title.vars.id }}').value.trim();
    const content = document.getElementById('{{ form.content.vars.id }}').value.trim();
    const excerpt = document.getElementById('{{ form.excerpt.vars.id }}');
    const btn = document.getElementById('generate-summary-btn');
    const result = document.getElementById('summary-result');

    if (!content) {
        alert('Write some content first so the summary tool has something to summarize.');
        return;
    }

    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Generating';
    result.classList.add('d-none');

    try {
        const response = await fetch('{{ path('blog_api_summarize') }}', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({title, content})
        });
        const data = await parseApiPayload(response, 'Summary could not be generated right now.');

        excerpt.value = data.summary || '';
        result.textContent = 'Summary generated using ' + (data.provider || 'summary tool') + '.';
        result.classList.remove('d-none');
    } catch (error) {
        alert(error.message);
    } finally {
        btn.disabled = false;
        btn.innerHTML = '<i class="bi bi-stars me-1"></i>Generate Summary';
    }
}
</script>
{% endblock %}

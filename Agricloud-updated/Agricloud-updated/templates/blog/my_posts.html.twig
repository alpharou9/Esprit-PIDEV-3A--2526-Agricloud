{% extends 'base.html.twig' %}
{% block title %}{{ is_granted('ROLE_ADMIN') ? 'All Posts' : 'My Posts' }} — AgriCloud{% endblock %}

{% block body %}

{# ── Page header ───────────────────────────────────────────── #}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">
        <i class="bi bi-pencil-square me-2"></i>
        {{ is_granted('ROLE_ADMIN') ? 'All Posts' : 'My Posts' }}
    </h5>
    <div class="d-flex gap-2">
        <a href="{{ path('blog_new') }}" class="btn btn-success btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Write Post
        </a>
        {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('blog_admin_comments') }}" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-chat-dots me-1"></i>Moderate Comments
        </a>
        {% endif %}
    </div>
</div>

{# ── Search + filter bar ───────────────────────────────────── #}
<form method="get" class="d-flex gap-2 flex-wrap align-items-center mb-4">
    <div class="input-group input-group-sm" style="max-width:280px">
        <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
        <input type="text" name="q" value="{{ q }}" class="form-control border-start-0"
               placeholder="Search by title…" autocomplete="off">
    </div>

    <select name="status" class="form-select form-select-sm" style="width:auto">
        <option value="">All statuses</option>
        <option value="draft"       {{ status == 'draft'       ? 'selected' : '' }}>Draft</option>
        <option value="published"   {{ status == 'published'   ? 'selected' : '' }}>Published</option>
        <option value="unpublished" {{ status == 'unpublished' ? 'selected' : '' }}>Unpublished</option>
    </select>

    <button class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-filter me-1"></i>Filter
    </button>

    {% if q or status %}
    <a href="{{ path('blog_my_posts') }}" class="btn btn-outline-danger btn-sm">
        <i class="bi bi-x-circle me-1"></i>Clear
    </a>
    {% endif %}
</form>

{# ── Results count ─────────────────────────────────────────── #}
{% if pagination.totalItemCount > 0 %}
<p class="text-muted small mb-2">
    {{ pagination.totalItemCount }} post{{ pagination.totalItemCount != 1 ? 's' : '' }}
    {% if q %}matching "<strong>{{ q }}</strong>"{% endif %}
</p>
{% endif %}

{# ── Table / empty state ───────────────────────────────────── #}
{% if pagination.totalItemCount == 0 %}
<div class="text-center text-muted py-5">
    <i class="bi bi-journal-x" style="font-size:3rem;opacity:.3"></i>
    <p class="mt-2">
        {% if q or status %}
            No posts matched your filters. <a href="{{ path('blog_my_posts') }}">Clear filters</a>
        {% else %}
            No posts yet. <a href="{{ path('blog_new') }}">Write your first post →</a>
        {% endif %}
    </p>
</div>
{% else %}

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Title</th>
                    <th>Category</th>
                    {% if is_granted('ROLE_ADMIN') %}<th>Author</th>{% endif %}
                    <th>Status</th>
                    <th>Views</th>
                    <th>Comments</th>
                    <th>Created</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for post in pagination %}
                {% set statusColors = {draft: 'secondary', published: 'success', unpublished: 'warning'} %}
                <tr>
                    <td>
                        <a href="{{ path('blog_show', {slug: post.slug}) }}"
                           class="fw-semibold text-decoration-none text-dark">
                            {{ post.title|slice(0, 60) }}{% if post.title|length > 60 %}…{% endif %}
                        </a>
                    </td>
                    <td>
                        {% if post.category %}
                            <span class="badge bg-light text-dark border">{{ post.category }}</span>
                        {% else %}
                            <span class="text-muted">—</span>
                        {% endif %}
                    </td>
                    {% if is_granted('ROLE_ADMIN') %}
                    <td class="text-muted small">{{ post.user.name }}</td>
                    {% endif %}
                    <td>
                        <span class="badge bg-{{ statusColors[post.status] ?? 'secondary' }}
                              {{ post.status == 'unpublished' ? 'text-dark' : '' }}">
                            {{ post.status|capitalize }}
                        </span>
                    </td>
                    <td class="text-muted small">
                        <i class="bi bi-eye me-1"></i>{{ post.views }}
                    </td>
                    <td class="text-muted small">
                        <i class="bi bi-chat me-1"></i>{{ post.approvedComments|length }}
                    </td>
                    <td class="text-muted small">
                        {{ post.createdAt ? post.createdAt|date('d M Y') : '—' }}
                    </td>
                    <td class="text-end">
                        <div class="d-flex gap-1 justify-content-end">
                            <a href="{{ path('blog_show', {slug: post.slug}) }}"
                               class="btn btn-sm btn-outline-secondary" title="View">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a href="{{ path('blog_edit', {id: post.id}) }}"
                               class="btn btn-sm btn-outline-primary" title="Edit">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" action="{{ path('blog_delete', {id: post.id}) }}"
                                  onsubmit="return confirm('Permanently delete this post?')">
                                <input type="hidden" name="_token"
                                       value="{{ csrf_token('delete_post_' ~ post.id) }}">
                                <button class="btn btn-sm btn-outline-danger" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{# ── Pagination ────────────────────────────────────────────── #}
{% if pagination.pageCount > 1 %}
<div class="d-flex justify-content-center mt-4">
    {{ knp_pagination_render(pagination) }}
</div>
{% endif %}

{% endif %}{# end table #}
{% endblock %}

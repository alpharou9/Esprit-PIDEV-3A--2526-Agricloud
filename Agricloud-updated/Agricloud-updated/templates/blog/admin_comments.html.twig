{% extends 'base.html.twig' %}
{% block title %}Comment Moderation — AgriCloud{% endblock %}

{% block body %}

{# ── Page header ───────────────────────────────────────────── #}
<div class="d-flex justify-content-between align-items-center mb-4">
    <h5 class="fw-bold mb-0">
        <i class="bi bi-chat-dots me-2"></i>Comment Moderation
    </h5>
    <a href="{{ path('blog_index') }}" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-journal-richtext me-1"></i>Blog
    </a>
</div>

{# ── Filter bar ────────────────────────────────────────────── #}
<form method="get" class="d-flex gap-2 flex-wrap align-items-center mb-4">
    <div class="input-group input-group-sm" style="max-width:260px">
        <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
        <input type="text" name="q" value="{{ q }}" class="form-control border-start-0"
               placeholder="Search comment, author, post…" autocomplete="off">
    </div>

    <select name="status" class="form-select form-select-sm" style="width:auto"
            onchange="this.form.submit()">
        <option value="">All statuses</option>
        <option value="pending"  {{ status == 'pending'  ? 'selected' : '' }}>Pending</option>
        <option value="approved" {{ status == 'approved' ? 'selected' : '' }}>Approved</option>
        <option value="rejected" {{ status == 'rejected' ? 'selected' : '' }}>Rejected</option>
    </select>

    <button class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-filter me-1"></i>Filter
    </button>

    {% if q or status %}
    <a href="{{ path('blog_admin_comments') }}" class="btn btn-outline-danger btn-sm">
        <i class="bi bi-x-circle me-1"></i>Clear
    </a>
    {% endif %}
</form>

{# ── Summary counts ────────────────────────────────────────── #}
{% if pagination.totalItemCount > 0 %}
<p class="text-muted small mb-2">
    {{ pagination.totalItemCount }} comment{{ pagination.totalItemCount != 1 ? 's' : '' }} found
</p>
{% endif %}

{# ── Table / empty state ───────────────────────────────────── #}
{% if pagination.totalItemCount == 0 %}
<div class="text-center text-muted py-5">
    <i class="bi bi-chat-slash" style="font-size:3rem;opacity:.3"></i>
    <p class="mt-2">
        {% if q or status %}
            No comments matched your filters. <a href="{{ path('blog_admin_comments') }}">Clear filters</a>
        {% else %}
            No comments yet.
        {% endif %}
    </p>
</div>
{% else %}

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width:3rem">#</th>
                    <th>Comment</th>
                    <th style="width:12rem">Author</th>
                    <th style="width:16rem">Post</th>
                    <th style="width:7rem">Status</th>
                    <th style="width:8rem">Date</th>
                    <th style="width:9rem" class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for comment in pagination %}
                {% set statusColors = {pending: 'warning', approved: 'success', rejected: 'danger'} %}
                <tr>
                    <td class="text-muted small">{{ comment.id }}</td>

                    <td>
                        <span class="small d-block" style="max-width:320px">
                            {{ comment.content|slice(0, 120) }}{% if comment.content|length > 120 %}…{% endif %}
                        </span>
                    </td>

                    <td class="small fw-semibold">{{ comment.user.name }}</td>

                    <td class="small">
                        <a href="{{ path('blog_show', {slug: comment.post.slug}) }}"
                           class="text-decoration-none text-success" target="_blank">
                            {{ comment.post.title|slice(0, 45) }}{% if comment.post.title|length > 45 %}…{% endif %}
                            <i class="bi bi-box-arrow-up-right ms-1" style="font-size:.7rem"></i>
                        </a>
                    </td>

                    <td>
                        <span class="badge bg-{{ statusColors[comment.status] ?? 'secondary' }}
                              {{ comment.status == 'pending' ? 'text-dark' : '' }}">
                            {{ comment.status|capitalize }}
                        </span>
                    </td>

                    <td class="text-muted small">
                        {{ comment.createdAt ? comment.createdAt|date('d M Y') : '—' }}
                    </td>

                    <td>
                        <div class="d-flex gap-1 justify-content-end">
                            {# Approve #}
                            {% if comment.status != 'approved' %}
                            <form method="post" action="{{ path('comment_approve', {id: comment.id}) }}">
                                <input type="hidden" name="_token"
                                       value="{{ csrf_token('approve_comment_' ~ comment.id) }}">
                                <input type="hidden" name="_status" value="{{ status }}">
                                <input type="hidden" name="_q" value="{{ q }}">
                                <button class="btn btn-sm btn-success" title="Approve">
                                    <i class="bi bi-check-lg"></i>
                                </button>
                            </form>
                            {% endif %}

                            {# Reject #}
                            {% if comment.status != 'rejected' %}
                            <form method="post" action="{{ path('comment_reject', {id: comment.id}) }}">
                                <input type="hidden" name="_token"
                                       value="{{ csrf_token('reject_comment_' ~ comment.id) }}">
                                <input type="hidden" name="_status" value="{{ status }}">
                                <input type="hidden" name="_q" value="{{ q }}">
                                <button class="btn btn-sm btn-warning" title="Reject">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </form>
                            {% endif %}

                            {# Delete #}
                            <form method="post" action="{{ path('comment_delete', {id: comment.id}) }}"
                                  onsubmit="return confirm('Permanently delete this comment?')">
                                <input type="hidden" name="_token"
                                       value="{{ csrf_token('delete_comment_' ~ comment.id) }}">
                                <button class="btn btn-sm btn-outline-danger" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{# ── Pagination ────────────────────────────────────────────── #}
{% if pagination.pageCount > 1 %}
<div class="d-flex justify-content-center mt-4">
    {{ knp_pagination_render(pagination) }}
</div>
{% endif %}

{% endif %}{# end table #}
{% endblock %}

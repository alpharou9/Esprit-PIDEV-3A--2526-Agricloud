{% extends 'base.html.twig' %}
{% block title %}{{ post.title }} — AgriCloud{% endblock %}

{% block stylesheets %}
<style>
.comment-avatar {
    width: 38px; height: 38px;
    border-radius: 50%;
    background: #198754;
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: .85rem; font-weight: 600;
    flex-shrink: 0;
}
.reply-avatar {
    width: 30px; height: 30px;
    border-radius: 50%;
    background: #6c757d;
    color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: .75rem; font-weight: 600;
    flex-shrink: 0;
}
.post-content { line-height: 1.85; white-space: pre-wrap; }
</style>
{% endblock %}

{% block body %}

{# ── Back nav ──────────────────────────────────────────────── #}
<div class="d-flex align-items-center gap-2 mb-4">
    <a href="{{ path('blog_index') }}" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left"></i>
    </a>
    <nav aria-label="breadcrumb" class="small text-muted">
        <a href="{{ path('blog_index') }}" class="text-decoration-none text-muted">Blog</a>
        <span class="mx-1">/</span>
        <span>{{ post.title|slice(0, 50) }}{% if post.title|length > 50 %}…{% endif %}</span>
    </nav>
</div>

<div class="row g-4">
    {# ── Main content ──────────────────────────────────────── #}
    <div class="col-lg-8">

        {# Cover image #}
        {% if post.image %}
        <img src="{{ asset('uploads/posts/' ~ post.image) }}"
             class="w-100 rounded-4 mb-4"
             style="max-height:380px;object-fit:cover" alt="{{ post.title|e('html_attr') }}">
        {% endif %}

        {# Status / category badges #}
        <div class="d-flex gap-2 flex-wrap align-items-center mb-3">
            {% if post.category %}
                <a href="{{ path('blog_index', {category: post.category}) }}"
                   class="badge bg-light text-dark border text-decoration-none">
                    {{ post.category }}
                </a>
            {% endif %}
            {% if post.status != 'published' %}
                <span class="badge {{ post.status == 'draft' ? 'bg-secondary' : 'bg-warning text-dark' }}">
                    {{ post.status|capitalize }}
                </span>
            {% endif %}
            <span class="text-muted small"><i class="bi bi-eye me-1"></i>{{ post.views }} views</span>
            <span class="text-muted small">
                <i class="bi bi-chat me-1"></i>{{ approvedComments|length }} comment{{ approvedComments|length != 1 ? 's' : '' }}
            </span>
        </div>

        {# Author + date #}
        <div class="d-flex flex-wrap gap-3 mb-4 text-muted small">
            <span><i class="bi bi-person me-1"></i>By <strong>{{ post.user.name }}</strong></span>
            <span>
                <i class="bi bi-calendar me-1"></i>
                {{ post.publishedAt ? post.publishedAt|date('d M Y') : post.createdAt|date('d M Y') }}
            </span>
            {% if post.updatedAt and post.updatedAt != post.createdAt %}
            <span class="fst-italic">
                <i class="bi bi-pencil me-1"></i>Updated {{ post.updatedAt|date('d M Y') }}
            </span>
            {% endif %}
        </div>

        {# Post body #}
        <div class="post-content mb-4">{{ post.content }}</div>

        {# Tags #}
        {% if post.tags %}
        <div class="mb-4">
            {% for tag in post.tags %}
                <a href="{{ path('blog_index', {q: tag}) }}"
                   class="badge bg-light text-muted border me-1 text-decoration-none">#{{ tag }}</a>
            {% endfor %}
        </div>
        {% endif %}

        {# Owner actions #}
        {% if post.user == app.user or is_granted('ROLE_ADMIN') %}
        <div class="d-flex gap-2 mb-5">
            <a href="{{ path('blog_edit', {id: post.id}) }}" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-pencil me-1"></i>Edit
            </a>
            <form method="post" action="{{ path('blog_delete', {id: post.id}) }}"
                  onsubmit="return confirm('Permanently delete this post and all its comments?')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_post_' ~ post.id) }}">
                <button class="btn btn-outline-danger btn-sm">
                    <i class="bi bi-trash me-1"></i>Delete
                </button>
            </form>
        </div>
        {% endif %}

        {# ── Comments ──────────────────────────────────────── #}
        <hr class="my-4">
        <h6 class="fw-bold mb-4">
            <i class="bi bi-chat-dots me-2"></i>
            Comments ({{ approvedComments|length }})
        </h6>

        {% if approvedComments is empty %}
        <p class="text-muted small">No comments yet. Be the first to comment below!</p>
        {% else %}

        {% for comment in approvedComments %}
        <div class="d-flex gap-3 mb-4" id="comment-{{ comment.id }}">
            <div class="comment-avatar">{{ comment.user.name|slice(0,1)|upper }}</div>
            <div class="flex-grow-1">
                {# Comment header #}
                <div class="d-flex justify-content-between align-items-center mb-1 flex-wrap gap-1">
                    <strong class="small">{{ comment.user.name }}</strong>
                    <div class="d-flex align-items-center gap-2">
                        <span class="text-muted" style="font-size:.75rem">
                            {{ comment.createdAt ? comment.createdAt|date('d M Y, H:i') : '' }}
                        </span>
                        {% if is_granted('ROLE_ADMIN') %}
                        <form method="post"
                              action="{{ path('comment_delete', {id: comment.id}) }}"
                              onsubmit="return confirm('Delete this comment?')">
                            <input type="hidden" name="_token"
                                   value="{{ csrf_token('delete_comment_' ~ comment.id) }}">
                            <button class="btn btn-danger btn-sm py-0 px-1" style="font-size:.7rem"
                                    title="Delete comment">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                        {% endif %}
                    </div>
                </div>

                {# Comment body #}
                <p class="mb-2 small">{{ comment.content }}</p>

                {# Approved replies #}
                {% for reply in comment.replies %}
                    {% if reply.status == 'approved' %}
                    <div class="d-flex gap-2 mt-2 ms-3 ps-3 border-start border-2 border-success-subtle">
                        <div class="reply-avatar">{{ reply.user.name|slice(0,1)|upper }}</div>
                        <div class="flex-grow-1">
                            <div class="d-flex justify-content-between align-items-center mb-1">
                                <strong class="small">{{ reply.user.name }}</strong>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="text-muted" style="font-size:.75rem">
                                        {{ reply.createdAt ? reply.createdAt|date('d M Y') : '' }}
                                    </span>
                                    {% if is_granted('ROLE_ADMIN') %}
                                    <form method="post"
                                          action="{{ path('comment_delete', {id: reply.id}) }}"
                                          onsubmit="return confirm('Delete this reply?')">
                                        <input type="hidden" name="_token"
                                               value="{{ csrf_token('delete_comment_' ~ reply.id) }}">
                                        <button class="btn btn-danger btn-sm py-0 px-1"
                                                style="font-size:.65rem">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                    {% endif %}
                                </div>
                            </div>
                            <p class="mb-0 small">{{ reply.content }}</p>
                        </div>
                    </div>
                    {% endif %}
                {% endfor %}

                {# Reply button + collapsible form #}
                {% if post.status == 'published' %}
                <button class="btn btn-link btn-sm p-0 text-muted mt-2 text-decoration-none"
                        data-bs-toggle="collapse"
                        data-bs-target="#reply-{{ comment.id }}"
                        aria-expanded="false">
                    <i class="bi bi-reply me-1"></i>Reply
                </button>
                <div class="collapse mt-2" id="reply-{{ comment.id }}">
                    <form method="post"
                          action="{{ path('blog_comment_add', {id: post.id}) }}"
                          class="d-flex gap-2">
                        <input type="hidden" name="parent_id" value="{{ comment.id }}">
                        <textarea name="comment[content]"
                                  class="form-control form-control-sm"
                                  rows="2"
                                  placeholder="Write a reply…"
                                  required></textarea>
                        <button class="btn btn-success btn-sm align-self-end">Post</button>
                    </form>
                </div>
                {% endif %}
            </div>
        </div>
        {% endfor %}

        {% endif %}{# end approvedComments #}

        {# ── New comment form ──────────────────────────────── #}
        {% if post.status == 'published' %}
        <div class="card border-0 bg-light rounded-4 p-3 mt-4">
            <h6 class="fw-semibold mb-3">
                <i class="bi bi-pencil me-1"></i>Leave a Comment
            </h6>
            {{ form_start(commentForm) }}
            {{ form_widget(commentForm.content) }}
            {{ form_errors(commentForm.content) }}
            <button type="submit" class="btn btn-success btn-sm mt-2">
                <i class="bi bi-send me-1"></i>Submit Comment
            </button>
            {{ form_end(commentForm) }}
            <div class="form-text mt-2 small">
                <i class="bi bi-info-circle me-1"></i>Comments are reviewed before appearing.
            </div>
        </div>
        {% elseif post.status == 'draft' %}
        <div class="alert alert-secondary small mt-4">
            <i class="bi bi-lock me-1"></i>Comments are disabled on draft posts.
        </div>
        {% endif %}

    </div>{# end col-lg-8 #}

    {# ── Sidebar ───────────────────────────────────────────── #}
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 p-3 mb-3 position-sticky" style="top:1rem">
            <h6 class="fw-semibold mb-3"><i class="bi bi-info-circle me-1"></i>Post Info</h6>
            <ul class="list-unstyled small text-muted mb-0">
                <li class="mb-2">
                    <i class="bi bi-person me-2"></i>{{ post.user.name }}
                </li>
                <li class="mb-2">
                    <i class="bi bi-calendar me-2"></i>Created {{ post.createdAt ? post.createdAt|date('d M Y') : '—' }}
                </li>
                {% if post.publishedAt %}
                <li class="mb-2">
                    <i class="bi bi-send me-2"></i>Published {{ post.publishedAt|date('d M Y') }}
                </li>
                {% endif %}
                <li class="mb-2">
                    <i class="bi bi-eye me-2"></i>{{ post.views }} views
                </li>
                <li class="mb-2">
                    <i class="bi bi-chat me-2"></i>{{ approvedComments|length }} comments
                </li>
                {% if post.category %}
                <li class="mb-2">
                    <i class="bi bi-tag me-2"></i>{{ post.category }}
                </li>
                {% endif %}
            </ul>

            {% if post.tags %}
            <hr class="my-2">
            <div>
                {% for tag in post.tags %}
                    <a href="{{ path('blog_index', {q: tag}) }}"
                       class="badge bg-light text-muted border me-1 mb-1 text-decoration-none small">
                        #{{ tag }}
                    </a>
                {% endfor %}
            </div>
            {% endif %}

            {% if is_granted('ROLE_ADMIN') %}
            <hr class="my-2">
            <a href="{{ path('blog_admin_comments') }}" class="btn btn-outline-secondary btn-sm w-100">
                <i class="bi bi-chat-dots me-1"></i>Moderate Comments
            </a>
            {% endif %}
        </div>
    </div>

</div>{# end row #}
{% endblock %}

{% extends 'base.html.twig' %}
{% block title %}Blog — AgriCloud{% endblock %}

{% block stylesheets %}
<style>
/* ── Card ──────────────────────────────────────────────────── */
.post-card {
    border-radius: 14px;
    border: none;
    box-shadow: 0 2px 10px rgba(0,0,0,.07);
    transition: transform .15s, box-shadow .15s;
    overflow: hidden;
}
.post-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(0,0,0,.12);
}
.post-img {
    height: 180px;
    object-fit: cover;
    width: 100%;
}
.post-img-placeholder {
    height: 180px;
    background: linear-gradient(135deg, #d1e7dd, #a3cfbb);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    color: #198754;
}

/* ── Category pills ─────────────────────────────────────────── */
.cat-pill {
    cursor: pointer;
    border-radius: 20px;
    padding: 4px 14px;
    font-size: .8rem;
    border: 1px solid #dee2e6;
    background: #fff;
    transition: all .15s;
    text-decoration: none;
    color: #495057;
    white-space: nowrap;
}
.cat-pill:hover, .cat-pill.active {
    background: #198754;
    color: #fff;
    border-color: #198754;
}
</style>
{% endblock %}

{% block body %}

{# ── Page header ───────────────────────────────────────────── #}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="fw-bold mb-0"><i class="bi bi-journal-richtext me-2"></i>Blog</h5>
    <div class="d-flex gap-2">
        <a href="{{ path('blog_my_posts') }}" class="btn btn-outline-success btn-sm">
            <i class="bi bi-pencil-square me-1"></i>My Posts
        </a>
        <a href="{{ path('blog_new') }}" class="btn btn-success btn-sm">
            <i class="bi bi-plus-lg me-1"></i>Write Post
        </a>
        {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('blog_admin_comments') }}" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-chat-dots me-1"></i>Moderate Comments
        </a>
        {% endif %}
    </div>
</div>

{# ── Search + sort bar ─────────────────────────────────────── #}
<form method="get" class="mb-3">
    <input type="hidden" name="category" value="{{ category }}">
    <div class="d-flex gap-2 flex-wrap" style="max-width:600px">
        <div class="input-group input-group-sm" style="max-width:320px">
            <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
            <input type="text" name="q" value="{{ q }}" class="form-control border-start-0"
                   placeholder="Search posts…" autocomplete="off">
            {% if q %}
            <button type="button" class="btn btn-outline-secondary"
                    onclick="this.closest('form').querySelector('[name=q]').value='';this.closest('form').submit()">
                <i class="bi bi-x"></i>
            </button>
            {% endif %}
        </div>

        <select name="sort" class="form-select form-select-sm" style="width:auto"
                onchange="this.form.submit()">
            <option value="newest"  {{ sort == 'newest'  ? 'selected' : '' }}>Newest first</option>
            <option value="oldest"  {{ sort == 'oldest'  ? 'selected' : '' }}>Oldest first</option>
            <option value="popular" {{ sort == 'popular' ? 'selected' : '' }}>Most viewed</option>
        </select>

        <button class="btn btn-outline-secondary btn-sm">Search</button>
        {% if q or category %}
        <a href="{{ path('blog_index') }}" class="btn btn-outline-danger btn-sm">
            <i class="bi bi-x-circle me-1"></i>Clear
        </a>
        {% endif %}
    </div>
</form>

{# ── Category filter pills ─────────────────────────────────── #}
<div class="d-flex gap-2 flex-wrap mb-4">
    <a href="{{ path('blog_index', {q: q, sort: sort}) }}"
       class="cat-pill {{ category == '' ? 'active' : '' }}">All</a>
    {% set allCats = ['News','Farming Guide','Tips & Tricks','Technology','Market','Other'] %}
    {% for cat in allCats %}
        <a href="{{ path('blog_index', {q: q, sort: sort, category: cat}) }}"
           class="cat-pill {{ category == cat ? 'active' : '' }}">{{ cat }}</a>
    {% endfor %}
</div>

{# ── Results ───────────────────────────────────────────────── #}
{% if pagination.totalItemCount == 0 %}
<div class="text-center text-muted py-5">
    <i class="bi bi-journal-richtext" style="font-size:3rem;opacity:.3"></i>
    <p class="mt-2">
        {% if q or category %}
            No posts matched your search. <a href="{{ path('blog_index') }}">Clear filters</a>
        {% else %}
            No posts published yet. <a href="{{ path('blog_new') }}">Write the first one →</a>
        {% endif %}
    </p>
</div>
{% else %}

<p class="text-muted small mb-3">
    {{ pagination.totalItemCount }} post{{ pagination.totalItemCount != 1 ? 's' : '' }} found
    {% if q %} for "<strong>{{ q }}</strong>"{% endif %}
    {% if category %} in <strong>{{ category }}</strong>{% endif %}
</p>

<div class="row g-3">
    {% for post in pagination %}
    <div class="col-md-4">
        <div class="card post-card h-100">
            {# Cover image #}
            {% if post.image %}
                <img src="{{ asset('uploads/posts/' ~ post.image) }}"
                     class="post-img" alt="{{ post.title|e('html_attr') }}">
            {% else %}
                <div class="post-img-placeholder">
                    <i class="bi bi-journal-text"></i>
                </div>
            {% endif %}

            <div class="card-body d-flex flex-column">
                {# Title + category #}
                <div class="d-flex justify-content-between align-items-start mb-1">
                    <h6 class="fw-bold mb-0 flex-grow-1 me-2 lh-sm">{{ post.title }}</h6>
                    {% if post.category %}
                        <span class="badge bg-light text-dark border small text-nowrap">{{ post.category }}</span>
                    {% endif %}
                </div>

                {# Excerpt / content preview #}
                <p class="text-muted small mb-2 flex-grow-1">
                    {{ (post.excerpt ?? post.content)|slice(0, 110) }}{% if (post.excerpt ?? post.content)|length > 110 %}…{% endif %}
                </p>

                {# Tags #}
                {% if post.tags %}
                <div class="mb-2">
                    {% for tag in post.tags|slice(0, 4) %}
                        <span class="badge bg-light text-muted border me-1 small">#{{ tag }}</span>
                    {% endfor %}
                </div>
                {% endif %}

                {# Meta footer #}
                <div class="mt-auto pt-1">
                    <div class="d-flex justify-content-between text-muted small">
                        <span><i class="bi bi-person me-1"></i>{{ post.user.name }}</span>
                        <span><i class="bi bi-eye me-1"></i>{{ post.views }}</span>
                    </div>
                    <div class="text-muted small mt-1">
                        <i class="bi bi-calendar me-1"></i>
                        {{ post.publishedAt ? post.publishedAt|date('d M Y') : '—' }}
                    </div>
                </div>
            </div>

            <div class="card-footer bg-white border-0 pb-3">
                <a href="{{ path('blog_show', {slug: post.slug}) }}"
                   class="btn btn-success btn-sm w-100">
                    <i class="bi bi-book me-1"></i>Read Post
                </a>
            </div>
        </div>
    </div>
    {% endfor %}
</div>

{# ── Pagination ────────────────────────────────────────────── #}
{% if pagination.pageCount > 1 %}
<div class="d-flex justify-content-center mt-4">
    {{ knp_pagination_render(pagination) }}
</div>
{% endif %}

{% endif %}{# end results #}
{% endblock %}
